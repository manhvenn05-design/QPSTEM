@model STEM.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";
}

<style>
    /* Ghi đè class auth-body cũ để full màn hình không bị bó hẹp */
    body.auth-body {
        background-color: #ffffff;
        display: block;
        padding: 0;
        margin: 0;
    }
</style>

<div class="min-h-screen w-full flex flex-col md:flex-row bg-white font-sans text-gray-800">
    
    <!-- Cột trái: Hình ảnh & Tiêu đề -->
    <!-- Cột trái: Ảnh thực tế + tagline -->
    <div class="hidden md:flex flex-1 relative overflow-hidden" style="background: linear-gradient(145deg, #0f2347 0%, #1a3a6e 55%, #1e4080 100%);">
        <!-- Overlay pattern -->
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, #f97316 0%, transparent 50%), radial-gradient(circle at 80% 20%, #ffffff 0%, transparent 40%);"></div>
        
        <!-- Ảnh thực tế -->
        <img
            src="https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?w=900&q=85&auto=format&fit=crop"
            alt="Lớp học TIPY STEM"
            class="absolute inset-0 w-full h-full object-cover opacity-30 mix-blend-luminosity"
        />
        
        <!-- Nội dung overlay -->
        <div class="relative z-10 flex flex-col justify-end p-10 pb-14 w-full">
            <!-- Logo -->
            <div class="mb-6 flex items-center gap-3">
                <div style="border-radius: 50%; overflow: hidden; width: 48px; height: 48px; box-shadow: 0 4px 16px rgba(249,115,22,0.4);">
                    <img src="/images/team/TIPY.jpg" alt="TIPY STEM" style="width:100%;height:100%;object-fit:cover;" />
                </div>
                <span style="color:#ffffff; font-size:1.3rem; font-weight:700; letter-spacing:-0.02em;">TIPY STEM</span>
            </div>
            <h1 style="color:#ffffff; font-size:clamp(1.6rem, 2.5vw, 2.2rem); font-weight:700; line-height:1.25; margin:0 0 14px; letter-spacing:-0.02em;">
                Nền tảng giáo dục STEM<br />
                <span style="color:#f97316;">hàng đầu Việt Nam</span>
            </h1>
            <p style="color:rgba(255,255,255,0.75); font-size:0.95rem; line-height:1.6; max-width:360px; margin:0 0 28px;">
                Kết nối học viên, giảng viên và quản trị trong một hệ thống thống nhất — mọi lúc, mọi nơi.
            </p>
            <!-- Trust badges -->
            <div class="flex gap-4 flex-wrap">
                <div style="background:rgba(255,255,255,0.12); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.2); border-radius:10px; padding:10px 16px; display:flex; align-items:center; gap:8px;">
                    <span class="material-symbols-outlined" style="color:#f97316; font-size:18px; font-variation-settings:'FILL' 1;">verified</span>
                    <span style="color:#fff; font-size:13px; font-weight:500;">Chứng chỉ được công nhận</span>
                </div>
                <div style="background:rgba(255,255,255,0.12); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.2); border-radius:10px; padding:10px 16px; display:flex; align-items:center; gap:8px;">
                    <span class="material-symbols-outlined" style="color:#f97316; font-size:18px; font-variation-settings:'FILL' 1;">groups</span>
                    <span style="color:#fff; font-size:13px; font-weight:500;">Giảng viên kinh nghiệm</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Cột phải: Form Đăng nhập -->
    <div class="flex-1 flex items-center justify-center p-4 sm:p-8 bg-[#fafbfe] md:bg-white relative">
        <div class="w-full max-w-[460px] bg-white rounded-xl shadow-[0_10px_40px_rgba(0,0,0,0.08)] overflow-hidden relative">
            
            <!-- Background sóng ở trên -->
            <div class="absolute top-0 left-0 right-0 h-[160px] bg-[#e8f0fb] overflow-hidden">
                <svg viewBox="0 0 1440 320" class="absolute bottom-[-2px] w-[110%] left-[-5%]" preserveAspectRatio="none" style="height: 70px;">
                    <path fill="#ffffff" fill-opacity="1" d="M0,128L80,133.3C160,139,320,149,480,138.7C640,128,800,96,960,101.3C1120,107,1280,149,1360,170.7L1440,192L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z"></path>
                </svg>
            </div>

            <!-- Nội dung Card -->
            <div class="relative z-10 px-8 pt-10 pb-10">
                
                <!-- Avatar Logo vòng tròn -->
                <div class="mx-auto w-[100px] h-[100px] rounded-full overflow-hidden shadow-[0_4px_20px_rgba(249,115,22,0.2)] border-[4px] border-white mb-6">
                    <img src="/images/team/TIPY.jpg" alt="TIPY STEM" class="w-full h-full object-cover" />
                </div>

                <div class="text-center mb-8">
                    <h2 class="text-[13px] font-semibold text-[#1a3a6e] uppercase mb-1">
                        Chào mừng đến với HỌC VIỆN CÔNG NGHỆ TIPY STEM
                    </h2>
                    <p class="text-[12px] text-gray-500">Vui lòng đăng nhập vào tài khoản của bạn</p>
                </div>

                <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-4">
                    <div asp-validation-summary="All" class="text-red-500 text-sm mb-4 p-3 bg-red-50 rounded" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div>
                        <label asp-for="UsernameOrEmail" class="block text-[13px] text-[#444] mb-1.5 ml-1">Email/Tên đăng nhập</label>
                        <input asp-for="UsernameOrEmail" type="text" class="w-full px-4 py-3 bg-[#eef2f8] border-none rounded-md focus:ring-2 focus:ring-[#1a3a6e] transition-all text-sm text-gray-700" placeholder=" " />
                    </div>

                    <div>
                        <label asp-for="Password" class="block text-[13px] text-[#444] mb-1.5 ml-1">Mật khẩu</label>
                        <input asp-for="Password" type="password" class="w-full px-4 py-3 bg-[#eef2f8] border-none rounded-md focus:ring-2 focus:ring-[#1a3a6e] transition-all text-sm text-gray-700" placeholder=" " />
                        <div class="text-right mt-2">
                            <a href="#" class="text-[12px] text-gray-500 hover:text-[#f97316] transition-colors">Quên mật khẩu</a>
                        </div>
                    </div>

                    <div class="hidden">
                        <input asp-for="RememberMe" type="checkbox" checked />
                    </div>

                    <button type="submit" class="w-full py-3 mt-3 bg-[#f97316] hover:bg-[#0f2347] text-white rounded-md font-semibold tracking-wide shadow-sm hover:shadow-md transition-all text-[14px]">
                        ĐĂNG NHẬP
                    </button>
                </form>

                <!-- Divider -->
                <div class="mt-8 mb-5 flex items-center justify-center space-x-3 opacity-70">
                    <div class="h-px bg-gray-300 w-10"></div>
                    <span class="text-[10px] text-gray-500">Cài đặt ứng dụng trên điện thoại</span>
                    <div class="h-px bg-gray-300 w-10"></div>
                </div>

                <!-- App Badges -->
                <div class="flex justify-center items-center gap-3">
                    <a href="#" class="inline-flex h-9 w-[120px] bg-white border border-gray-200 rounded shadow-sm hover:shadow-md transition-all items-center justify-center px-2">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg" alt="Google Play" class="h-[22px] object-contain" />
                    </a>
                    <a href="#" class="inline-flex h-9 w-[120px] bg-white border border-gray-200 rounded shadow-sm hover:shadow-md transition-all items-center justify-center px-2">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Download_on_the_App_Store_Badge.svg" alt="App Store" class="h-[22px] object-contain" />
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
