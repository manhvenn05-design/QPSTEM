@model STEM.Web.Models.StudentViewModels.StudentDashboardViewModel

@{
    ViewData["Title"] = "Cổng Học sinh & Phụ huynh";
    Layout = "_StudentLayout";
}

<section class="student-page">
    <div class="student-page-header">
        <div>
            <h1 class="student-page-title">Xin chào, @Model.Student.FullName!</h1>
            <p class="student-page-subtitle">Xem lịch học, nhận xét từ giáo viên và theo dõi học phí của bé tại đây.</p>
        </div>

        <div class="student-actions">
            <a asp-action="Schedule" class="student-btn-secondary">
                <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                <span>Xem lịch học</span>
            </a>
            <a asp-action="Evidence" class="student-btn-primary">
                <span class="material-symbols-outlined text-[18px]">rate_review</span>
                <span>Nhận xét &amp; Minh chứng</span>
            </a>
        </div>
    </div>

    <!-- KHU VỰC THỐNG KÊ (STATS GRID) -->
    <div class="student-stat-grid">
        <article class="student-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="student-stat-label">Buổi học tuần này</span>
                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">calendar_month</span>
            </div>
            <div>
                <div class="student-stat-value">@Model.SessionsThisWeekCount</div>
                <p class="student-kicker">Số ca học diễn ra trong tuần hiện tại.</p>
            </div>
        </article>

        <article class="student-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="student-stat-label">Minh chứng mới</span>
                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">photo_library</span>
            </div>
            <div>
                <div class="student-stat-value">@Model.NewMediaCount</div>
                <p class="student-kicker">Ảnh và video được cập nhật trong 7 ngày qua.</p>
            </div>
        </article>

        <article class="student-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="student-stat-label">Đánh giá mới từ giáo viên</span>
                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">rate_review</span>
            </div>
            <div>
                <div class="student-stat-value">@Model.NewFeedbackCount</div>
                <p class="student-kicker">Nhận xét từ giáo viên và AI trong 7 ngày qua.</p>
            </div>
        </article>

        <article class="student-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="student-stat-label">Tình trạng học phí</span>
                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">receipt_long</span>
            </div>
            <div>
                <div class="student-stat-value">@Model.PendingInvoiceCount</div>
                <p class="student-kicker">Hóa đơn đang chờ hoàn tất thanh toán.</p>
            </div>
        </article>
    </div>

    <div class="student-grid-two">
        <!-- CỘT TRÁI: LỊCH HỌC VÀ THƯ VIỆN -->
        <div class="space-y-6">
            
            <!-- LỊCH HỌC SẮP TỚI -->
            <div class="student-card">
                <div class="student-card-section">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <h2 class="student-section-title">Lịch học sắp tới</h2>
                            <p class="student-section-subtitle">Theo dõi lịch học của bé trong thời gian tới.</p>
                        </div>
                    </div>

                    <div class="student-list mt-4">
                        @if (!Model.UpcomingSessions.Any())
                        {
                            <div class="py-8 text-center text-sm text-[#73796b]">
                                Hiện tại không có lịch học nào sắp tới.
                            </div>
                        }
                        else
                        {
                            @foreach (var session in Model.UpcomingSessions)
                            {
                                var tagClass = session.Status == "Hôm nay" ? "student-tag--success" : "student-tag--neutral";
                                
                                <article class="student-list-item">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <p class="text-sm font-semibold text-[#1a1c19]">@session.CourseName · Lớp @session.ClassCode</p>
                                            <p class="mt-1 text-sm text-[#73796b]">
                                                Thứ @(session.Date.DayOfWeek == DayOfWeek.Sunday ? "CN" : ((int)session.Date.DayOfWeek + 1).ToString()), @session.Date.ToString("dd/MM/yyyy"), @session.StartTime.ToString("HH\\:mm") - @session.EndTime.ToString("HH\\:mm")
                                            </p>
                                        </div>
                                        <span class="student-tag @tagClass">@session.SessionLabel</span>
                                    </div>
                                    <div class="mt-4 flex flex-wrap items-center gap-3">
                                        <span class="text-sm text-[#42493d] font-medium mr-2">Chủ đề: @session.Topic</span>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- THƯ VIỆN SẢN PHẨM / MEDIA -->
            <div class="student-card">
                <div class="student-card-section">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <h2 class="student-section-title">Thư viện sản phẩm gần đây</h2>
                            <p class="student-section-subtitle">Hình ảnh và video thuyết trình của bé do giáo viên tải lên.</p>
                        </div>
                        <a asp-action="Evidence" class="text-sm font-semibold text-[#3b6722] hover:underline shrink-0">Xem tất cả</a>
                    </div>

                    <div class="student-media-grid">
                        @{
                            var sessionsWithMedia = Model.RecentFeedbacks.Where(x => x.MediaItems.Any()).ToList();
                        }

                        @if (!sessionsWithMedia.Any())
                        {
                            <div class="py-8 text-center text-sm text-[#73796b] col-span-full">
                                Chưa có hình ảnh hoặc video nào được cập nhật gần đây.
                            </div>
                        }
                        else
                        {
                            @foreach (var feedback in sessionsWithMedia)
                            {
                                var firstImage = feedback.MediaItems.FirstOrDefault(m => m.Type == "Image");
                                var firstVideo = feedback.MediaItems.FirstOrDefault(m => m.Type == "Video");
                                var imageCount = feedback.MediaItems.Count(m => m.Type == "Image");
                                var videoCount = feedback.MediaItems.Count(m => m.Type == "Video");

                                @* Tính YouTube thumbnail URL nếu có video *@
                                string? thumbSrc = null;
                                if (firstImage != null)
                                {
                                    thumbSrc = firstImage.Url;
                                }
                                else if (firstVideo != null)
                                {
                                    string vidUrl = firstVideo.Url;
                                    string? videoId = null;
                                    if (vidUrl.Contains("youtu.be/"))
                                        videoId = vidUrl.Split("youtu.be/").Last().Split('?').First();
                                    else if (vidUrl.Contains("youtube.com/watch"))
                                    {
                                        var qs = System.Web.HttpUtility.ParseQueryString(new Uri(vidUrl).Query);
                                        videoId = qs["v"];
                                    }
                                    if (!string.IsNullOrEmpty(videoId))
                                        thumbSrc = $"https://img.youtube.com/vi/{videoId}/hqdefault.jpg";
                                }

                                <a asp-action="Evidence" asp-route-sessionId="@feedback.SessionId" class="student-media-card group">
                                    @if (thumbSrc != null)
                                    {
                                        <div class="student-media-thumb relative overflow-hidden">
                                            <img src="@thumbSrc"
                                                 alt="Minh chứng buổi học"
                                                 class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                                                 loading="lazy"
                                                 onerror="this.parentElement.innerHTML='<div class=\'h-full flex items-center justify-center bg-[#dfead7]\'>\n<span class=\'material-symbols-outlined text-[36px] text-[#3b6722]\'>photo_camera</span></div>'" />
                                            @if (videoCount > 0)
                                            {
                                                <div class="absolute inset-0 flex items-center justify-center bg-black/20">
                                                    <span class="material-symbols-outlined text-[36px] text-white drop-shadow">play_circle</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="student-media-thumb">
                                            <span class="material-symbols-outlined text-[36px]">
                                                @(videoCount > 0 ? "smart_display" : "photo_camera")
                                            </span>
                                        </div>
                                    }
                                    <div class="student-media-body">
                                        <p class="text-sm font-semibold text-[#1a1c19]">@feedback.CourseName - @feedback.SessionLabel</p>
                                        <p class="mt-1 text-sm text-[#73796b]">
                                            @if(imageCount > 0) { <span>@imageCount ảnh</span> }
                                            @if(imageCount > 0 && videoCount > 0) { <span>, </span> }
                                            @if(videoCount > 0) { <span>@videoCount video</span> }
                                            &middot; Cập nhật ngày @feedback.Date.ToString("dd/MM/yyyy")
                                        </p>
                                    </div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- CỘT PHẢI: ĐÁNH GIÁ VÀ HỌC PHÍ -->
        <aside class="space-y-6">
            
            <!-- ĐÁNH GIÁ TỪ GIÁO VIÊN / AI -->
            <div class="student-card">
                <div class="student-card-section">
                    <h2 class="student-section-title">Đánh giá buổi học</h2>
                    <p class="student-section-subtitle">Nhận xét chi tiết từ giáo viên và trợ lý AI sau mỗi buổi học.</p>

                    <div class="student-list mt-4">
                        @if (!Model.RecentFeedbacks.Any())
                        {
                            <div class="py-8 text-center text-sm text-[#73796b]">
                                Hiện chưa có đánh giá nào từ giáo viên.
                            </div>
                        }
                        else
                        {
                            @foreach (var feedback in Model.RecentFeedbacks)
                            {
                                <article class="student-list-item">
                                    <p class="text-sm font-semibold text-[#1a1c19]">@feedback.CourseName · @feedback.SessionLabel</p>
                                    <p class="text-xs text-[#73796b] mt-1">Ngày học: @feedback.Date.ToString("dd/MM/yyyy")</p>
                                    
                                    @if (!string.IsNullOrWhiteSpace(feedback.AiEvaluation))
                                    {
                                        <div class="mt-3 rounded-md bg-[#f8faf7] p-3 text-sm leading-6 text-[#42493d] border border-[#e3e3de]">
                                            <div class="flex items-center gap-1.5 mb-1 text-[#3b6722] font-semibold text-xs">
                                                <span class="material-symbols-outlined text-[16px]">auto_awesome</span> Nhận xét tổng hợp từ AI
                                            </div>
                                            @feedback.AiEvaluation
                                        </div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(feedback.TeacherNote))
                                    {
                                        <div class="mt-3 text-sm leading-6 text-[#42493d]">
                                            @feedback.TeacherNote
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="mt-3 text-sm italic text-[#73796b]">Giáo viên chưa nhập nhận xét cho buổi học này.</p>
                                    }
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- HỌC PHÍ VÀ CÔNG NỢ -->
            <div class="student-card">
                <div class="student-card-section">
                    <h2 class="student-section-title">Học phí và công nợ</h2>
                    <p class="student-section-subtitle">Theo dõi trạng thái thanh toán học phí.</p>

                    <div class="mt-6 space-y-5">
                        @if (!Model.Invoices.Any())
                        {
                            <div class="py-4 text-center text-sm text-[#73796b]">
                                Chưa có dữ liệu học phí.
                            </div>
                        }
                        else
                        {
                            @foreach (var invoice in Model.Invoices)
                            {
                                var isOverdue = invoice.RemainingAmount > 0 && invoice.DueDate.HasValue && invoice.DueDate.Value < DateTime.Today;
                                var tagClass = invoice.RemainingAmount == 0 ? "student-tag--success" : (isOverdue ? "bg-[#ba1a1a] text-white" : "student-tag--warning");
                                var tagText = invoice.RemainingAmount == 0 ? "Hoàn tất" : (isOverdue ? "Quá hạn" : "Đang nợ");

                                <div>
                                    <div class="mb-2 flex items-center justify-between text-sm text-[#42493d] font-medium">
                                        <span>@invoice.CourseName</span>
                                        <span>@invoice.ProgressPercent%</span>
                                    </div>
                                    <div class="student-progress">
                                        <div class="student-progress-bar @(invoice.RemainingAmount == 0 ? "bg-[#6a994e]" : "")" style="width:@invoice.ProgressPercent%;"></div>
                                    </div>
                                    <p class="mt-2 text-sm text-[#73796b]">
                                        Đã thanh toán @invoice.PaidAmount.ToString("N0")đ / @invoice.TotalAmount.ToString("N0")đ
                                    </p>
                                </div>

                                <div class="student-list-item !mt-3 !p-3">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <p class="text-sm font-semibold text-[#1a1c19]">Mã HĐ: @invoice.InvoiceNo</p>
                                            @if (invoice.DueDate.HasValue && invoice.RemainingAmount > 0)
                                            {
                                                <p class="mt-1 text-sm @(isOverdue ? "text-[#ba1a1a] font-medium" : "text-[#73796b]")">
                                                    Hạn nộp: @invoice.DueDate.Value.ToString("dd/MM/yyyy")
                                                </p>
                                            }
                                        </div>
                                        <span class="student-tag @tagClass">@tagText</span>
                                    </div>
                                    @if (invoice.RemainingAmount > 0)
                                    {
                                        <p class="mt-2 text-sm font-medium text-[#ba1a1a]">Cần thanh toán: @invoice.RemainingAmount.ToString("N0")đ</p>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </aside>
    </div>
</section>
