    <section id="consultation" class="section">
        <div class="container">
            <div class="consultation-panel reveal">
                <div class="consultation-copy">
                    <h2>Đăng ký nhận tư vấn</h2>
                    <p>
                        Điền thông tin vào mẫu bên dưới. Bộ phận học vụ sẽ liên hệ để xếp lịch và tư vấn lớp học thực tế gần nhất.
                    </p>
                </div>

                <div class="consultation-form-card">
                    <form class="consultation-form" asp-controller="Leads" asp-action="Consultation" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="AcceptTerms" value="true" />
                        
                        <div class="form-field">
                            <label for="ParentName">Họ và tên</label>
                            <input id="ParentName" name="ParentName" type="text" placeholder="Nhập tên của bạn" required />
                        </div>

                        <div class="form-grid">
                            <div class="form-field">
                                <label for="Phone">Số điện thoại</label>
                                <input id="Phone" name="Phone" type="tel" placeholder="09xx xxx xxx" required />
                            </div>

                            <div class="form-field">
                                <label for="Email">Email</label>
                                <input id="Email" name="Email" type="email" placeholder="example@gmail.com" required />
                            </div>
                        </div>

                        <button class="button button-primary button-block" type="submit">Gửi thông tin</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</main>
