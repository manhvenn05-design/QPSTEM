@model STEM.Web.Models.HomeIndexViewModel

@{
    ViewData["Title"] = "Trang chủ";
    var topBanner = Model?.Banners?.FirstOrDefault();
}

    <link rel="stylesheet" href="~/css/news.css" />


<main>
    <section class="hero-section">
        <div class="container hero-grid">
            <div class="hero-copy">
                @if (topBanner != null)
                {
                    <h1>@topBanner.Title</h1>
                }
                else
                {
                    <h1>Học qua thực hành, vững bước tương lai</h1>
                }
                <p>
                    Hệ thống quản lý đào tạo STEM chuyên biệt — Kết nối chặt chẽ giữa nhà trường, giáo viên và phụ huynh để theo sát hành trình phát triển thực tế của học sinh.
                </p>
                <div class="hero-actions">
                    <a class="button button-primary" href="@(topBanner?.LinkUrl ?? Url.Action("Index", "Courses"))">
                        Khám phá ngay
                        <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                    </a>
                </div>
            </div>

            <div class="hero-media">
                <div class="hero-glow" aria-hidden="true"></div>
                <img
                    src="@(topBanner?.ImageUrl ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuBrow8sWiPCtb2NNeEAnPsNTlHlfzCkZZcm44fmznmoQE8HWBgAcXOlg562V8981OVZ1lGMLtcUpP-2I5lkYEFu35BM9n6UroCRzuPyFozIFJ0GEwb4SDowdMv8T2nU92MyoBJS8hUwDFztyc9nuRpxQb6tESh3P2ZdnyHxqIs3iasXuY_JtpJqfW73gG4bt6KVAp-k2MHoSm2BBTrRHKjUp4-Ar6Eu_Cke95f_kJaOSTfsa-9lTppHidasrGXVDMBtmBC4QxeyYhfn")"
                    alt="@(topBanner?.Title ?? "Lớp học STEM")" style="object-fit: cover; border-radius: 1rem;" />
            </div>
        </div>
    </section>

    <section id="features" class="section section-surface-white">
        <div class="container">
            <div class="section-heading reveal">
                <h2>Tính năng nổi bật</h2>
                <div class="heading-accent"></div>
            </div>

            <div class="card-grid card-grid-3">
                <article class="feature-card reveal delay-100">
                    <div class="feature-icon">
                        <span class="material-symbols-outlined" aria-hidden="true">analytics</span>
                    </div>
                    <h3>Đánh giá qua Video AI</h3>
                    <p>
                        Giáo viên nhận được các phân tích chuyên sâu tự động về điểm mạnh và kỹ năng cần cải thiện từ video thuyết trình của học sinh.
                    </p>
                </article>

                <article class="feature-card reveal delay-200">
                    <div class="feature-icon">
                        <span class="material-symbols-outlined" aria-hidden="true">photo_library</span>
                    </div>
                    <h3>Hồ sơ Minh chứng</h3>
                    <p>
                        Mọi hình ảnh, video thực hành dự án đều được số hóa, tạo thành một thư viện minh chứng học tập rõ ràng, minh bạch cho phụ huynh.
                    </p>
                </article>

                <article class="feature-card reveal delay-300">
                    <div class="feature-icon">
                        <span class="material-symbols-outlined" aria-hidden="true">fact_check</span>
                    </div>
                    <h3>Quản lý Lớp học</h3>
                    <p>
                        Nắm bắt ngay lập tức lịch giảng dạy, tình trạng điểm danh và đánh giá chi tiết cho từng buổi học trên một giao diện tối giản.
                    </p>
                </article>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="container">
            <div class="section-heading reveal">
                <h2>Hệ sinh thái kết nối</h2>
                <p>Tối ưu luồng thông tin giữa các vai trò trong môi trường giáo dục</p>
            </div>

            <div class="card-grid card-grid-3">
                <article class="audience-card reveal delay-100">
                    <div class="audience-image">
                        <img
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBrBiweQj_01Y1ngbbL_Srm5I8SPU6SFKXT0ub15nJF4JGudwnZJbq6MMV85gzTJckPQIDh5uCFjyWEq8gZZC2V5Wxr6Do9HUG-QOCZUR-6AQJcSPv2t5c6erAiwtEW_z_KOuSceh_sxIeilaEKHSRBwz6cotgpP1v6tkw5yiWaoMsvvGAO2cK_ihiPaqdju9-XYHxWg_e7sCUqdFSYtYIu0IkSNeOmxqZgswC7AxGw5Fvo4HdtvPr_-HM7AMudzAEJjui9NzuYSXwk"
                            alt="Nhóm học sinh cùng làm thí nghiệm trong lớp học STEM" />
                    </div>
                    <div class="audience-content">
                        <h3>Học sinh</h3>
                        <p>Tự hào theo dõi các dự án thực tế mình đã hoàn thành và xem lại các nhận xét để rút kinh nghiệm.</p>
                    </div>
                </article>

                <article class="audience-card reveal delay-200">
                    <div class="audience-image">
                        <img
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDK_ovUbGIrVPgNJwDV6bfrSvAANh06dGS22sSDssFkXbCwy3oh-ypccYBJY1SF2Uf3DLRSunxyp79QlNAYEP4P5djf1CuDAnviecaMIKtFzwCH5Xm9GbQ_YFgaSmhTBSeEPV7Z40yT3YvTLji3Vrb019hsX9S15LtIFn3fFGowGd_CoekTOC2uqQLiGfHm7cfMZrbQlgDchF_BeMzCZI7fL0z6Jg66JYRXfNmKi2bPcql_IflixTUwmLLbRBwO2UzCL7DcibYwfk59"
                            alt="Phụ huynh đồng hành cùng con học tập tại nhà" />
                    </div>
                    <div class="audience-content">
                        <h3>Phụ huynh</h3>
                        <p>Cập nhật liên tục về sự hiện diện, đánh giá năng lực của con qua các minh chứng video, hình ảnh xác thực.</p>
                    </div>
                </article>

                <article class="audience-card reveal delay-300">
                    <div class="audience-image">
                        <img
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCUcqzKc2FjYt9Uzp4dVdVZmh1-12zbqtEu772bZPMggzCNy0WmcMLFXFPAcDyzpyBsrZR5rx2YehXE2VqUG7C8EX0CIDmUmrI7xgy3RNqGqvW_vsc_vs-mEXF7QbKORwsMJJn-VjKmX3pPb6GGqg-WkWvZUzJz4Ck4G5jtMEN8uIhf5i_g7qj_uUKOJqfFdoi_MLQJqz3mriXpVQ8bm-6Y7_Xng84LsJmBjHXyTk85rIW3ucmEy4dfa3UKzRaTxZiphdishK5WdrLe"
                            alt="Giảng viên đang trình bày bài giảng trong không gian đào tạo hiện đại" />
                    </div>
                    <div class="audience-content">
                        <h3>Giáo viên</h3>
                        <p>Giải phóng khỏi thủ tục giấy tờ với sổ điểm danh số hóa, hỗ trợ viết nhận xét thông minh và quản lý thiết bị học cụ.</p>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section class="section section-process section-surface-white">
        <div class="container">
            <div class="section-heading reveal">
                <h2>Quy trình 3 bước</h2>
            </div>

            <div class="process-grid">
                <article class="process-step reveal delay-100">
                    <div class="process-number">1</div>
                    <h3>Ghi nhận thông tin</h3>
                    <p>Phụ huynh để lại thông tin nhu cầu cơ bản cho bộ phận học vụ qua hệ thống biểu mẫu trực tuyến.</p>
                </article>

                <article class="process-step reveal delay-200">
                    <div class="process-number">2</div>
                    <h3>Xếp lớp & Xếp lịch</h3>
                    <p>Ban giáo vụ tiến hành phân bổ học viên vào lớp phù hợp, đồng thời hệ thống cập nhật lịch học tức thời.</p>
                </article>

                <article class="process-step reveal delay-300">
                    <div class="process-number">3</div>
                    <h3>Đánh giá liên tục</h3>
                    <p>Quá trình học được số hóa qua các minh chứng cụ thể mỗi buổi, đảm bảo tiến trình phát triển thực chất.</p>
                </article>
            </div>
        </div>
    </section>
