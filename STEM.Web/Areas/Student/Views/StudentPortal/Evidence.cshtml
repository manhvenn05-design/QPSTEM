@model STEM.Web.Models.StudentViewModels.StudentEvidencePageViewModel

@{
    ViewData["Title"] = "Nhận xét & Minh chứng";
    Layout = "_StudentLayout";

    static string BuildLinkLabel(string url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return "Mở liên kết";
        }

        try
        {
            var path = Uri.TryCreate(url, UriKind.Absolute, out var absoluteUri)
                ? absoluteUri.AbsolutePath
                : url;
            var fileName = System.IO.Path.GetFileName(path);
            return string.IsNullOrWhiteSpace(fileName) ? url : fileName;
        }
        catch
        {
            return url;
        }
    }

    static bool IsDirectVideoLink(string url)
    {
        var normalized = url?.ToLowerInvariant() ?? string.Empty;
        return normalized.EndsWith(".mp4") || normalized.EndsWith(".webm") || normalized.EndsWith(".mov") || normalized.EndsWith(".ogg");
    }
}

<section class="student-page">
    <div class="student-page-header">
        <div>
            <h1 class="student-page-title">Nhận xét &amp; Minh chứng</h1>
            <p class="student-page-subtitle">Nhận xét của giáo viên và hình ảnh/video sản phẩm học tập của bé sau mỗi buổi học.</p>
        </div>

    </div>

    @* Filter theo lớp *@
    @if (Model.AvailableClasses.Count > 1)
    {
        <div class="flex flex-wrap items-center gap-2">
            <span class="text-sm font-medium text-[#73796b]">Lọc theo lớp:</span>
            <a asp-action="Evidence"
               class="inline-flex items-center rounded-lg px-3 h-9 text-sm font-semibold transition-colors
                      @(Model.SelectedClass == null ? "bg-[#0f2347] text-white" : "bg-white border border-[#c2c9b9] text-[#42493d] hover:bg-[#f2f7f0]")">
                Tất cả
            </a>
            @foreach (var cls in Model.AvailableClasses)
            {
                <a asp-action="Evidence" asp-route-classCode="@cls"
                   class="inline-flex items-center rounded-lg px-3 h-9 text-sm font-semibold transition-colors
                          @(Model.SelectedClass == cls ? "bg-[#0f2347] text-white" : "bg-white border border-[#c2c9b9] text-[#42493d] hover:bg-[#f2f7f0]")">
                    @cls
                </a>
            }
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div class="student-card">
            <div class="student-card-section py-20 text-center">
                <span class="material-symbols-outlined text-[56px] text-[#c2c9b9]">rate_review</span>
                <p class="mt-4 text-base font-semibold text-[#42493d]">Chưa có nhận xét nào</p>
                <p class="mt-1 text-sm text-[#73796b]">
                    @if (Model.SelectedClass != null)
                    {
                        <span>Lớp <strong>@Model.SelectedClass</strong> chưa có nhận xét nào.</span>
                    }
                    else
                    {
                        <span>Nhận xét và minh chứng sẽ xuất hiện ở đây sau khi giáo viên cập nhật.</span>
                    }
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="space-y-6">
            @foreach (var item in Model.Items)
            {
                @* id để scroll đến khi deep-link từ Schedule *@
                <article id="evidence-session-@item.SessionId"
                         class="student-card transition-shadow @(item.IsHighlighted ? "ring-2 ring-[#1a3a6e] ring-offset-2" : "")">
                    @* Header *@
                    <div class="flex items-center justify-between gap-4 border-b border-[#e3e3de] px-6 py-4">
                        <div>
                            <p class="text-sm font-semibold text-[#1a1c19]">
                                @item.CourseName
                                <span class="font-normal text-[#73796b]">&middot; Lớp @item.ClassCode &middot; Buổi @item.SessionNo.ToString("00")</span>
                            </p>
                            <p class="mt-0.5 text-xs text-[#73796b]">Ngày học: @item.SessionDate.ToString("dd/MM/yyyy")</p>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            @if (item.IsHighlighted)
                            {
                                <span class="inline-flex items-center gap-1 rounded-full bg-[#edf7e8] px-2.5 py-1 text-xs font-semibold text-[#456c3f]">
                                    <span class="material-symbols-outlined text-[12px]">bookmark</span>Buổi đã chọn
                                </span>
                            }
                            @if (item.MediaCount > 0)
                            {
                                <span class="inline-flex items-center gap-1.5 rounded-full bg-[#f2f7f0] px-3 py-1 text-xs font-semibold text-[#0f2347]">
                                    <span class="material-symbols-outlined text-[14px]">perm_media</span>
                                    @item.MediaCount minh chứng
                                </span>
                            }
                        </div>
                    </div>

                    <div class="student-card-section space-y-5">
                        @* Text Evidence: AI & Teacher Notes *@
                        @if (!string.IsNullOrWhiteSpace(item.AiEvaluation) || !string.IsNullOrWhiteSpace(item.TeacherRawNote))
                        {
                            <div class="grid gap-4 sm:grid-cols-2">
                                @if (!string.IsNullOrWhiteSpace(item.AiEvaluation))
                                {
                                    <div class="flex flex-col overflow-hidden rounded-xl border border-[#c8e0b8] bg-[#f5fbf3]">
                                        <div class="flex items-center justify-between border-b border-[#c8e0b8]/50 bg-[#edf7e8] px-4 py-2.5">
                                            <div class="flex items-center gap-1.5">
                                                <span class="material-symbols-outlined text-[18px] text-[#0f2347]">auto_awesome</span>
                                                <span class="text-xs font-bold uppercase tracking-wide text-[#0f2347]">Nhận xét tổng hợp từ AI</span>
                                            </div>
                                            <button type="button" class="inline-flex h-7 w-7 items-center justify-center rounded-md text-[#0f2347] hover:bg-[#c8e0b8] transition-colors js-zoom-text" data-title="Nhận xét tổng hợp từ AI" data-content="@item.AiEvaluation" title="Phóng to">
                                                <span class="material-symbols-outlined text-[16px]">zoom_out_map</span>
                                            </button>
                                        </div>
                                        <div class="p-4 flex-1">
                                            <p class="text-[15px] leading-relaxed text-[#2c3625] line-clamp-5">@item.AiEvaluation</p>
                                        </div>
                                    </div>
                                }
                                
                                @if (!string.IsNullOrWhiteSpace(item.TeacherRawNote))
                                {
                                    <div class="flex flex-col overflow-hidden rounded-xl border border-[#e3e3de] bg-[#fafaf4]">
                                        <div class="flex items-center justify-between border-b border-[#e3e3de] bg-[#f4f4ee] px-4 py-2.5">
                                            <div class="flex items-center gap-1.5">
                                                <span class="material-symbols-outlined text-[18px] text-[#5d6557]">edit_note</span>
                                                <span class="text-xs font-bold uppercase tracking-wide text-[#5d6557]">Ghi chú của giáo viên</span>
                                            </div>
                                            <button type="button" class="inline-flex h-7 w-7 items-center justify-center rounded-md text-[#5d6557] hover:bg-[#e3e3de] transition-colors js-zoom-text" data-title="Ghi chú của giáo viên" data-content="@item.TeacherRawNote" title="Phóng to">
                                                <span class="material-symbols-outlined text-[16px]">zoom_out_map</span>
                                            </button>
                                        </div>
                                        <div class="p-4 flex-1">
                                            <p class="text-[15px] leading-relaxed text-[#42493d] whitespace-pre-line line-clamp-5">@item.TeacherRawNote</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @if (string.IsNullOrWhiteSpace(item.AiEvaluation) && string.IsNullOrWhiteSpace(item.TeacherRawNote))
                        {
                            <p class="text-sm italic text-[#73796b]">Giáo viên chưa nhập nhận xét cho buổi học này.</p>
                        }

                        @* Media: Video YouTube *@
                        @if (item.VideoUrls.Any())
                        {
                            <div>
                                <div class="mb-3 flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[16px] text-[#73796b]">smart_display</span>
                                    <span class="text-xs font-semibold uppercase tracking-wide text-[#73796b]">Video minh chứng buổi học (@item.VideoUrls.Count)</span>
                                </div>
                                <div class="grid gap-4 @(item.VideoUrls.Count > 1 ? "sm:grid-cols-2" : "")">
                                    @foreach (var videoUrl in item.VideoUrls)
                                    {
                                        string embedUrl = videoUrl;
                                        bool isYoutube = false;
                                        if (videoUrl.Contains("youtu.be/"))
                                        {
                                            var videoId = videoUrl.Split("youtu.be/").Last().Split('?').First();
                                            embedUrl = $"https://www.youtube.com/embed/{videoId}";
                                            isYoutube = true;
                                        }
                                        else if (videoUrl.Contains("youtube.com/watch"))
                                        {
                                            var uri = new Uri(videoUrl);
                                            var qs = System.Web.HttpUtility.ParseQueryString(uri.Query);
                                            var videoId = qs["v"];
                                            if (!string.IsNullOrEmpty(videoId))
                                            {
                                                embedUrl = $"https://www.youtube.com/embed/{videoId}";
                                                isYoutube = true;
                                            }
                                        }

                                        <div class="aspect-video overflow-hidden rounded-lg border border-[#e3e3de] bg-[#1a1c19]">
                                            @if (isYoutube)
                                            {
                                                <iframe class="h-full w-full border-0"
                                                        src="@embedUrl"
                                                        title="YouTube video player"
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                        allowfullscreen></iframe>
                                            }
                                            else
                                            {
                                                <video class="h-full w-full object-contain" controls>
                                                    <source src="@videoUrl" />
                                                    Trình duyệt của bạn không hỗ trợ thẻ video.
                                                </video>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @* Media: Ảnh *@
                        @if (item.ImageUrls.Any())
                        {
                            <div>
                                <div class="mb-3 flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[16px] text-[#73796b]">photo_library</span>
                                    <span class="text-xs font-semibold uppercase tracking-wide text-[#73796b]">Ảnh minh chứng buổi học (@item.ImageUrls.Count)</span>
                                </div>
                                <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
                                    @foreach (var imgUrl in item.ImageUrls)
                                    {
                                        <a href="@imgUrl" target="_blank" rel="noopener noreferrer"
                                           class="group relative aspect-square overflow-hidden rounded-lg border border-[#e3e3de] bg-[#f4f4ee]">
                                            <img src="@imgUrl"
                                                 alt="Ảnh minh chứng buổi học"
                                                 class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                                                 loading="lazy"
                                                 onerror="this.parentElement.innerHTML='<div class=\'h-full flex items-center justify-center text-[#73796b]\' title=\'Không tải được ảnh\'><span class=\'material-symbols-outlined text-[32px]\'>broken_image</span></div>'" />
                                            <div class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 transition-opacity group-hover:opacity-100">
                                                <span class="material-symbols-outlined text-white text-[24px]">open_in_new</span>
                                            </div>
                                        </a>
                                    }
                                </div>
                            </div>
                        }

                        @* External Links (Google Drive, etc.) *@
                        @if (item.ExternalUrls.Any())
                        {
                            <div>
                                <div class="mb-2 flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-[16px] text-[#73796b]">link</span>
                                    <span class="text-xs font-semibold uppercase tracking-wide text-[#73796b]">Mở minh chứng</span>
                                </div>
                                <div class="grid gap-3 md:grid-cols-2">
                                    @foreach (var extUrl in item.ExternalUrls)
                                    {
                                        var isVideoLink = IsDirectVideoLink(extUrl);
                                        var linkLabel = BuildLinkLabel(extUrl);
                                        <a href="@extUrl" target="_blank" rel="noopener noreferrer"
                                           class="group flex items-center justify-between gap-4 rounded-xl border border-[#d7e4d1] bg-[#f8fcf6] px-4 py-3 text-sm text-[#0f2347] transition-all hover:-translate-y-0.5 hover:border-[#9fca8b] hover:bg-[#f2f9ee] hover:shadow-sm">
                                            <div class="flex min-w-0 items-center gap-3">
                                                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white text-[#456c3f] ring-1 ring-[#d7e4d1]">
                                                    <span class="material-symbols-outlined text-[22px]">@(isVideoLink ? "play_circle" : "open_in_new")</span>
                                                </div>
                                                <div class="min-w-0">
                                                    <p class="truncate font-semibold text-[#1a1c19]">@linkLabel</p>
                                                    <p class="mt-1 text-xs text-[#5f6b57]">@(isVideoLink ? "Nhấn để xem video minh chứng" : "Nhấn để mở liên kết minh chứng")</p>
                                                </div>
                                            </div>
                                            <span class="inline-flex shrink-0 items-center gap-1 rounded-full bg-white px-3 py-1 text-xs font-semibold text-[#0f2347] ring-1 ring-[#d7e4d1] group-hover:bg-[#0f2347] group-hover:text-white group-hover:ring-[#0f2347]">
                                                @(isVideoLink ? "Xem video" : "Mở liên kết")
                                                <span class="material-symbols-outlined text-[14px]">arrow_outward</span>
                                            </span>
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </article>
            }
        </div>

        @* Pagination *@
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-between gap-4 pt-2">
                <p class="text-sm text-[#73796b]">
                    Trang @Model.Page / @Model.TotalPages
                    &middot; <span class="font-medium">@Model.TotalCount</span> buổi học
                </p>
                <div class="flex items-center gap-2">
                    @if (Model.HasPrev)
                    {
                        <a asp-action="Evidence"
                           asp-route-classCode="@Model.SelectedClass"
                           asp-route-page="@(Model.Page - 1)"
                           class="inline-flex items-center gap-1 rounded-lg border border-[#c2c9b9] bg-white px-3 h-9 text-sm font-semibold text-[#42493d] hover:bg-[#f2f7f0] transition-colors">
                            <span class="material-symbols-outlined text-[16px]">chevron_left</span>
                            Trước
                        </a>
                    }
                    @if (Model.HasNext)
                    {
                        <a asp-action="Evidence"
                           asp-route-classCode="@Model.SelectedClass"
                           asp-route-page="@(Model.Page + 1)"
                           class="inline-flex items-center gap-1 rounded-lg border border-[#c2c9b9] bg-white px-3 h-9 text-sm font-semibold text-[#42493d] hover:bg-[#f2f7f0] transition-colors">
                            Tiếp
                            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                        </a>
                    }
                </div>
            </div>
        }
    }
</section>

@* Modal phóng to nội dung *@
<div id="text-zoom-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-[#141713]/60 p-4 backdrop-blur-sm transition-opacity opacity-0" aria-modal="true" role="dialog">
    <div class="relative w-full max-w-2xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all scale-95">
        <div class="flex items-center justify-between border-b border-[#e3e3de] bg-[#fafaf4] px-6 py-4">
            <h3 class="text-lg font-bold text-[#1a1c19]" id="text-zoom-title">Nhận xét</h3>
            <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-full text-[#73796b] hover:bg-[#e3e3de] hover:text-[#1a1c19] transition-colors js-close-zoom">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
        <div class="max-h-[70vh] overflow-y-auto px-6 py-5">
            <p class="text-[16px] leading-8 text-[#2c3625] whitespace-pre-line" id="text-zoom-content"></p>
        </div>
        <div class="border-t border-[#e3e3de] bg-[#fafaf4] px-6 py-4 text-right">
            <button type="button" class="inline-flex h-10 items-center justify-center rounded-lg bg-[#0f2347] px-6 text-sm font-semibold text-white hover:bg-[#2d5019] transition-colors js-close-zoom">
                Đóng
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            // Auto-scroll logic cho deep-link
            @if (Model.HighlightSession.HasValue)
            {
                <text>
                var el = document.getElementById('evidence-session-@Model.HighlightSession.Value');
                if (el) {
                    setTimeout(function () {
                        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }, 200);
                }
                </text>
            }

            // Logic phóng to văn bản (Zoom Modal)
            const zoomModal = document.getElementById('text-zoom-modal');
            const zoomModalContainer = zoomModal.querySelector('.transform');
            const zoomTitle = document.getElementById('text-zoom-title');
            const zoomContent = document.getElementById('text-zoom-content');
            
            function openZoomModal(title, content) {
                zoomTitle.textContent = title;
                zoomContent.textContent = content;
                
                zoomModal.classList.remove('hidden');
                // Allow browser to render display:block before applying opacity transition
                requestAnimationFrame(() => {
                    zoomModal.classList.remove('opacity-0');
                    zoomModalContainer.classList.remove('scale-95');
                    zoomModalContainer.classList.add('scale-100');
                });
                document.body.style.overflow = 'hidden';
            }
            
            function closeZoomModal() {
                zoomModal.classList.add('opacity-0');
                zoomModalContainer.classList.remove('scale-100');
                zoomModalContainer.classList.add('scale-95');
                
                setTimeout(() => {
                    zoomModal.classList.add('hidden');
                    document.body.style.overflow = '';
                }, 200); // Matches transition duration
            }

            document.querySelectorAll('.js-zoom-text').forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    const title = this.getAttribute('data-title');
                    const content = this.getAttribute('data-content');
                    openZoomModal(title, content);
                });
            });

            document.querySelectorAll('.js-close-zoom').forEach(btn => {
                btn.addEventListener('click', closeZoomModal);
            });

            zoomModal.addEventListener('click', function(e) {
                if (e.target === zoomModal) {
                    closeZoomModal();
                }
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && !zoomModal.classList.contains('hidden')) {
                    closeZoomModal();
                }
            });
        })();
    </script>
}
