@model STEM.Web.Models.StudentViewModels.StudentFinancePageViewModel

@{
    ViewData["Title"] = "Học phí";
    Layout = "_StudentLayout";
}

<section class="student-page">
    <div class="student-page-header">
        <div>
            <h1 class="student-page-title">Học phí</h1>
            <p class="student-page-subtitle">Theo dõi trạng thái thanh toán học phí và lịch sử các lần thu.</p>
        </div>
    </div>

    @* KPI Stats *@
    <div class="student-stat-grid">
        <article class="student-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="student-stat-label">Tổng học phí</span>
                <span class="material-symbols-outlined text-[20px] text-[#1a3a6e]">receipt_long</span>
            </div>
            <div>
                <div class="student-stat-value">@Model.TotalBilled.ToString("N0")₫</div>
                <p class="student-kicker">Tổng các khoản học phí đã được lập hóa đơn.</p>
            </div>
        </article>

        <article class="student-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="student-stat-label">Đã thanh toán</span>
                <span class="material-symbols-outlined text-[20px] text-[#456c3f]">payments</span>
            </div>
            <div>
                <div class="student-stat-value">@Model.TotalPaid.ToString("N0")₫</div>
                <p class="student-kicker">Tổng số tiền đã nộp.</p>
            </div>
        </article>

        <article class="student-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="student-stat-label">Còn lại cần nộp</span>
                <span class="material-symbols-outlined text-[20px] @(Model.TotalRemaining > 0 ? "text-[#ba1a1a]" : "text-[#456c3f]")">
                    @(Model.TotalRemaining > 0 ? "warning" : "check_circle")
                </span>
            </div>
            <div>
                <div class="student-stat-value @(Model.TotalRemaining > 0 ? "text-[#ba1a1a]" : "")">
                    @Model.TotalRemaining.ToString("N0")₫
                </div>
                <p class="student-kicker">
                    @(Model.TotalRemaining <= 0 ? "Tất cả học phí đã được thanh toán đầy đủ." :
                      $"{Model.PendingCount} hóa đơn chưa hoàn tất thanh toán.")
                </p>
            </div>
        </article>

        <article class="student-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="student-stat-label">Hóa đơn chưa đủ</span>
                <span class="material-symbols-outlined text-[20px] text-[#9b682f]">pending_actions</span>
            </div>
            <div>
                <div class="student-stat-value">@Model.PendingCount</div>
                <p class="student-kicker">Số hóa đơn còn công nợ.</p>
            </div>
        </article>
    </div>

    @* Invoice List *@
    @if (!Model.Invoices.Any())
    {
        <div class="student-card">
            <div class="student-card-section py-16 text-center">
                <span class="material-symbols-outlined text-[48px] text-[#c2c9b9]">receipt_long</span>
                <p class="mt-4 text-sm font-medium text-[#73796b]">Chưa có dữ liệu học phí nào.</p>
            </div>
        </div>
    }
    else
    {
        <div class="space-y-5">
            @foreach (var invoice in Model.Invoices)
            {
                <article class="student-card @(invoice.IsOverdue ? "border-[#ffb4ab]" : "")">
                    @* Invoice header *@
                    <div class="flex items-start justify-between gap-4 border-b border-[#e3e3de] px-6 py-4">
                        <div>
                            <div class="flex items-center gap-2 flex-wrap">
                                <p class="text-sm font-semibold text-[#1a1c19]">
                                    @(invoice.CourseName ?? "Khóa học tổng hợp")
                                    @if (!string.IsNullOrWhiteSpace(invoice.ClassCode))
                                    {
                                        <span class="font-normal text-[#73796b]">· Lớp @invoice.ClassCode</span>
                                    }
                                </p>
                            </div>
                            <p class="mt-0.5 text-xs text-[#73796b]">Mã HĐ: <span class="font-mono font-medium">@invoice.InvoiceNo</span></p>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            @if (invoice.IsOverdue)
                            {
                                <span class="inline-flex items-center gap-1 rounded-full bg-[#ffdad6] px-2.5 py-1 text-xs font-semibold text-[#ba1a1a]">
                                    <span class="material-symbols-outlined text-[12px]">warning</span>Quá hạn
                                </span>
                            }
                            <span class="student-tag @invoice.StatusBadgeClass">@invoice.StatusLabel</span>
                        </div>
                    </div>

                    <div class="student-card-section space-y-4">
                        @* Progress bar *@
                        <div>
                            <div class="mb-2 flex items-center justify-between text-sm">
                                <span class="text-[#42493d]">
                                    Đã nộp: <strong>@invoice.PaidAmount.ToString("N0")₫</strong>
                                    / @invoice.FinalAmount.ToString("N0")₫
                                </span>
                                <span class="font-semibold text-[#0f2347]">@invoice.ProgressPercent%</span>
                            </div>
                            <div class="student-progress">
                                <div class="student-progress-bar @(invoice.RemainingAmount <= 0 ? "bg-[#1a3a6e]" : "bg-[#9b682f]")"
                                     style="width:@invoice.ProgressPercent%"></div>
                            </div>
                            @if (invoice.RemainingAmount > 0)
                            {
                                <p class="mt-2 text-sm font-medium @(invoice.IsOverdue ? "text-[#ba1a1a]" : "text-[#9b682f]")">
                                    Cần thanh toán thêm: @invoice.RemainingAmount.ToString("N0")₫
                                    @if (invoice.DueDate.HasValue)
                                    {
                                        <span class="font-normal"> · Hạn: @invoice.DueDate.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                </p>
                            }
                        </div>

                        @* Payment history *@
                        @if (invoice.Payments.Any())
                        {
                            <div>
                                <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-[#73796b]">Lịch sử thu tiền</p>
                                <div class="divide-y divide-[#e3e3de] rounded-lg border border-[#e3e3de] overflow-hidden">
                                    @foreach (var payment in invoice.Payments)
                                    {
                                        <div class="flex items-center justify-between px-4 py-2.5 text-sm bg-[#fafaf4]">
                                            <div class="flex items-center gap-2">
                                                <span class="material-symbols-outlined text-[16px] text-[#1a3a6e]">check_circle</span>
                                                <span class="text-[#42493d]">@payment.TransDate.ToString("dd/MM/yyyy")</span>
                                                <span class="rounded bg-[#eeeee9] px-1.5 py-0.5 text-xs text-[#73796b]">@payment.PaymentMethodLabel</span>
                                            </div>
                                            <span class="font-semibold text-[#456c3f]">+@payment.Amount.ToString("N0")₫</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-sm italic text-[#73796b]">Chưa có lần thu tiền nào.</p>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>
