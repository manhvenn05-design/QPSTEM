@model STEM.Web.Areas.Teacher.Models.TeacherBorrowEquipmentViewModel

@{
    ViewData["Title"] = "Mượn / Trả thiết bị";
}

<section class="teacher-page">
    <div class="teacher-page-header">
        <div>
            <h1 class="teacher-page-title">Tạo phiếu mượn</h1>
        </div>

        <div class="teacher-actions">
            <a asp-area="Teacher" asp-controller="Equipment" asp-action="Index" class="teacher-btn-secondary">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                <span>Quay lại</span>
            </a>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="teacher-alert teacher-alert--error"></div>
    }

    <form asp-area="Teacher" asp-controller="Equipment" asp-action="Borrow" method="post" class="teacher-card">
        @Html.AntiForgeryToken()
        <div class="teacher-card-section">
            <div class="teacher-form-grid teacher-form-grid--2">
                <div class="teacher-field">
                    <label for="SelectedEquipmentId">Thiết bị</label>
                    <select asp-for="SelectedEquipmentId" asp-items="Model.EquipmentOptions">
                        <option value="">Chọn thiết bị</option>
                    </select>
                    <span asp-validation-for="SelectedEquipmentId" class="teacher-field-error"></span>
                </div>

                <div class="teacher-field">
                    <label for="SessionId">Buổi học</label>
                    <select asp-for="SessionId" asp-items="Model.SessionOptions">
                        <option value="">Chọn buổi học</option>
                    </select>
                    <span asp-validation-for="SessionId" class="teacher-field-error"></span>
                </div>

                <div class="teacher-field">
                    <label for="BorrowTime">Thời gian mượn</label>
                    <input asp-for="BorrowTime" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" />
                    <span asp-validation-for="BorrowTime" class="teacher-field-error"></span>
                </div>
            </div>

            <div class="mt-8 flex flex-wrap justify-end gap-3">
                <a asp-area="Teacher" asp-controller="Equipment" asp-action="Index" class="teacher-btn-secondary">Hủy</a>
                <button type="submit" class="teacher-btn-primary">Lưu phiếu mượn</button>
            </div>
        </div>
    </form>
</section>
