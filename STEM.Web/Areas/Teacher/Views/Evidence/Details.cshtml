@model STEM.Web.Areas.Teacher.Models.TeacherEvidenceDetailsViewModel

@{
    ViewData["Title"] = "Minh chứng";
}

<section class="teacher-page">
    <div class="teacher-page-header">
        <div>
            <h1 class="teacher-page-title">@Model.StudentName</h1>
            <p class="teacher-page-subtitle">@Model.StudentUsername · @Model.ClassCode · @Model.CourseName · @Model.SessionLabel</p>
        </div>

        <div class="teacher-actions">
            <a asp-area="Teacher" asp-controller="Attendances" asp-action="Board" asp-route-sessionId="@Model.SessionId" class="teacher-btn-primary">
                <span class="material-symbols-outlined text-[18px]">edit</span>
                <span>Chỉnh sửa trong điểm danh</span>
            </a>
        </div>
    </div>

    <div class="teacher-panel-grid">
        <div class="teacher-stack">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Ghi chú giáo viên</h2>
                    <p class="teacher-list-note mt-4">@(!string.IsNullOrWhiteSpace(Model.TeacherRawNote) ? Model.TeacherRawNote : "Chưa có ghi chú.")</p>
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Media đã lưu</h2>
                    <p class="teacher-section-subtitle">Mỗi mục mở ở tab mới để kiểm tra nhanh.</p>

                    <div class="teacher-media-grid mt-6">
                        @if (Model.MediaUrls.Count == 0)
                        {
                            <p class="teacher-empty">Bản ghi này chưa có media.</p>
                        }
                        else
                        {
                            var index = 1;
                            foreach (var url in Model.MediaUrls)
                            {
                                <a href="@url" target="_blank" rel="noreferrer" class="teacher-media-link">
                                    <span class="material-symbols-outlined text-[20px]">open_in_new</span>
                                    <span class="truncate">Media @index</span>
                                </a>
                                index++;
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="teacher-stack">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Thông tin buổi học</h2>
                    <div class="teacher-info-grid mt-6">
                        <dl class="teacher-key-value">
                            <dt>Buổi học</dt>
                            <dd>@Model.SessionLabel</dd>
                        </dl>
                        <dl class="teacher-key-value">
                            <dt>Lịch học</dt>
                            <dd>@Model.ScheduleText</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Thao tác nhanh</h2>
                    <div class="teacher-stack mt-6">
                        <a asp-area="Teacher" asp-controller="Attendances" asp-action="Board" asp-route-sessionId="@Model.SessionId" class="teacher-btn-primary w-full">Mở buổi học</a>
                        <a asp-area="Teacher" asp-controller="Evidence" asp-action="Index" class="teacher-btn-secondary w-full">Quay lại minh chứng</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
