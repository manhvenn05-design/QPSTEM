@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using STEM.Web.Data
@inject ApplicationDbContext DbContext

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - QPSTEM Teacher</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        :root {
            --teacher-bg: #fafaf4;
            --teacher-surface: #ffffff;
            --teacher-surface-soft: #f4f4ee;
            --teacher-border: #e3e3de;
            --teacher-border-strong: #c2c9b9;
            --teacher-text: #1a1c19;
            --teacher-text-muted: #42493d;
            --teacher-text-soft: #73796b;
            --teacher-primary: #6a994e;
            --teacher-primary-strong: #3b6722;
            --teacher-primary-soft: #f2f7f0;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        html, body {
            background: var(--teacher-bg);
            color: var(--teacher-text);
            font-family: 'Inter', sans-serif;
        }

        .teacher-shell {
            min-height: 100vh;
            background: linear-gradient(180deg, #f8f8f1 0%, #fafaf4 100%);
        }

        .teacher-sidebar {
            background: rgba(255, 255, 255, 0.92);
            border-right: 1px solid var(--teacher-border);
            backdrop-filter: blur(12px);
        }

        .teacher-logo {
            align-items: center;
            display: inline-flex;
            gap: 12px;
        }

        .teacher-logo-mark {
            align-items: center;
            background: var(--teacher-primary-strong);
            border-radius: 12px;
            color: #fff;
            display: inline-flex;
            height: 52px;
            justify-content: center;
            width: 52px;
        }

        .teacher-logo-wordmark {
            color: var(--teacher-primary);
            font-size: 2rem;
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 1;
        }

        .teacher-logo-subtitle {
            color: #8b8f85;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.14em;
            line-height: 16px;
            margin-top: 4px;
        }

        .teacher-nav-link {
            align-items: center;
            border-radius: 8px;
            color: var(--teacher-text-muted);
            display: flex;
            gap: 12px;
            min-height: 48px;
            padding: 12px 16px;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .teacher-nav-link:hover {
            background: var(--teacher-surface-soft);
            color: var(--teacher-primary-strong);
        }

        .teacher-nav-link.is-active {
            background: var(--teacher-primary-soft);
            box-shadow: inset 3px 0 0 var(--teacher-primary);
            color: var(--teacher-primary-strong);
            font-weight: 600;
        }

        .teacher-badge {
            background: var(--teacher-primary-soft);
            border-radius: 9999px;
            color: var(--teacher-primary-strong);
            font-size: 12px;
            font-weight: 600;
            margin-left: auto;
            padding: 6px 10px;
        }

        .teacher-body {
            margin-left: 18rem;
            min-height: 100vh;
        }

        .teacher-header {
            background: rgba(255, 255, 255, 0.92);
            border-bottom: 1px solid var(--teacher-border);
            backdrop-filter: blur(12px);
        }

        .teacher-container {
            padding: 96px 32px 48px;
        }

        @@media (min-width: 1440px) {
            .teacher-container {
                padding-left: 40px;
                padding-right: 40px;
            }
        }

        .teacher-page {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .teacher-page-header {
            display: flex;
            flex-direction: column;
            gap: 16px;
            justify-content: space-between;
        }

        @@media (min-width: 1024px) {
            .teacher-page-header {
                align-items: flex-start;
                flex-direction: row;
            }
        }

        .teacher-page-title {
            font-size: 32px;
            font-weight: 600;
            letter-spacing: -0.01em;
            line-height: 40px;
            margin: 0;
        }

        .teacher-page-subtitle {
            color: var(--teacher-text-soft);
            font-size: 16px;
            line-height: 24px;
            margin-top: 8px;
            max-width: 760px;
        }

        .teacher-actions,
        .teacher-toolbar,
        .teacher-filter-list,
        .teacher-search-form,
        .teacher-meta-row,
        .teacher-session-card,
        .teacher-board-student,
        .teacher-checkbox,
        .teacher-inline-list {
            display: flex;
        }

        .teacher-actions,
        .teacher-filter-list,
        .teacher-inline-list {
            flex-wrap: wrap;
            gap: 12px;
        }

        .teacher-toolbar {
            flex-direction: column;
            gap: 16px;
        }

        @@media (min-width: 1180px) {
            .teacher-toolbar {
                align-items: center;
                flex-direction: row;
                justify-content: space-between;
            }
        }

        .teacher-btn-primary,
        .teacher-btn-secondary {
            align-items: center;
            border-radius: 8px;
            display: inline-flex;
            font-size: 14px;
            font-weight: 600;
            gap: 8px;
            height: 48px;
            justify-content: center;
            padding: 0 20px;
        }

        .teacher-btn-primary {
            background: var(--teacher-primary);
            color: #fff;
        }

        .teacher-btn-secondary {
            background: #fff;
            border: 1px solid var(--teacher-border-strong);
            color: var(--teacher-text-muted);
        }

        .teacher-card,
        .teacher-stat-card {
            background: var(--teacher-surface);
            border: 1px solid var(--teacher-border);
            border-radius: 8px;
        }

        .teacher-card-section,
        .teacher-stat-card {
            padding: 24px;
        }

        .teacher-stat-grid {
            display: grid;
            gap: 24px;
        }

        @@media (min-width: 768px) {
            .teacher-stat-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (min-width: 1280px) {
            .teacher-stat-grid.teacher-stat-grid--4 {
                grid-template-columns: repeat(4, minmax(0, 1fr));
            }

            .teacher-stat-grid.teacher-stat-grid--6 {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
        }

        .teacher-stat-card {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 160px;
        }

        .teacher-stat-label {
            color: var(--teacher-text-soft);
            font-size: 14px;
            font-weight: 500;
            line-height: 20px;
        }

        .teacher-stat-value {
            font-size: 32px;
            font-weight: 600;
            letter-spacing: -0.01em;
            line-height: 40px;
            margin-top: 24px;
        }

        .teacher-kicker {
            color: var(--teacher-text-soft);
            font-size: 14px;
            line-height: 20px;
            margin-top: 8px;
        }

        .teacher-section-title {
            font-size: 20px;
            font-weight: 600;
            line-height: 28px;
            margin: 0;
        }

        .teacher-section-subtitle {
            color: var(--teacher-text-soft);
            font-size: 14px;
            line-height: 20px;
            margin-top: 4px;
        }

        .teacher-list,
        .teacher-board,
        .teacher-stack {
            display: grid;
            gap: 16px;
        }

        .teacher-panel-grid {
            display: grid;
            gap: 24px;
        }

        @@media (min-width: 1280px) {
            .teacher-panel-grid {
                grid-template-columns: minmax(0, 1.4fr) minmax(320px, 0.9fr);
            }
        }

        .teacher-search-form {
            width: 100%;
        }

        @@media (min-width: 1180px) {
            .teacher-search-form {
                max-width: 360px;
            }
        }

        .teacher-search-box {
            align-items: center;
            background: #fff;
            border: 1px solid var(--teacher-border-strong);
            border-radius: 8px;
            display: flex;
            gap: 12px;
            height: 48px;
            padding: 0 16px;
        }

        .teacher-search-box input {
            background: transparent;
            border: 0;
            color: var(--teacher-text);
            outline: 0;
            width: 100%;
        }

        .teacher-filter {
            align-items: center;
            background: #fff;
            border: 1px solid var(--teacher-border);
            border-radius: 9999px;
            color: var(--teacher-text-muted);
            display: inline-flex;
            font-size: 14px;
            font-weight: 600;
            height: 40px;
            padding: 0 16px;
        }

        .teacher-filter.is-active {
            background: var(--teacher-primary);
            border-color: var(--teacher-primary);
            color: #fff;
        }

        .teacher-tag {
            border-radius: 9999px;
            display: inline-flex;
            font-size: 12px;
            font-weight: 600;
            line-height: 16px;
            padding: 8px 12px;
        }

        .teacher-tag--success {
            background: #edf7e8;
            color: #456c3f;
        }

        .teacher-tag--warning {
            background: #fff4e8;
            color: #9b682f;
        }

        .teacher-tag--neutral {
            background: #eeeee9;
            color: #42493d;
        }

        .teacher-session-card {
            align-items: center;
            flex-direction: column;
            gap: 20px;
        }

        @@media (min-width: 1180px) {
            .teacher-session-card {
                align-items: stretch;
                flex-direction: row;
                justify-content: space-between;
            }
        }

        .teacher-session-main {
            flex: 1 1 auto;
        }

        .teacher-session-side {
            align-items: center;
            display: flex;
            min-width: 220px;
        }

        .teacher-meta-row {
            color: var(--teacher-text-muted);
            flex-wrap: wrap;
            gap: 16px;
            font-size: 14px;
            line-height: 20px;
        }

        .teacher-board-row,
        .teacher-data-row {
            background: var(--teacher-surface-soft);
            border: 1px solid var(--teacher-border);
            border-radius: 8px;
            display: grid;
            gap: 20px;
            padding: 20px;
        }

        @@media (min-width: 1180px) {
            .teacher-board-row {
                grid-template-columns: minmax(240px, 280px) minmax(0, 1fr);
            }
        }

        .teacher-board-student {
            align-items: center;
            gap: 16px;
        }

        .teacher-board-fields,
        .teacher-form-grid,
        .teacher-info-grid {
            display: grid;
            gap: 16px;
        }

        @@media (min-width: 900px) {
            .teacher-form-grid.teacher-form-grid--2,
            .teacher-info-grid.teacher-info-grid--2 {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        .teacher-toggle {
            align-items: center;
            display: flex;
        }

        .teacher-checkbox {
            align-items: center;
            gap: 10px;
            color: var(--teacher-text-muted);
            font-size: 14px;
            font-weight: 600;
        }

        .teacher-checkbox input {
            accent-color: var(--teacher-primary);
            height: 18px;
            width: 18px;
        }

        .teacher-field {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .teacher-field label {
            color: var(--teacher-text-muted);
            font-size: 14px;
            font-weight: 600;
            line-height: 20px;
        }

        .teacher-field input,
        .teacher-field select,
        .teacher-field textarea {
            background: #fff;
            border: 1px solid var(--teacher-border-strong);
            border-radius: 8px;
            color: var(--teacher-text);
            padding: 14px 16px;
            resize: vertical;
        }

        .teacher-field input:focus,
        .teacher-field select:focus,
        .teacher-field textarea:focus {
            border-color: var(--teacher-primary);
            box-shadow: 0 0 0 3px rgba(106, 153, 78, 0.12);
            outline: none;
        }

        .teacher-field-hint,
        .teacher-empty,
        .teacher-list-note {
            color: var(--teacher-text-soft);
            font-size: 14px;
            line-height: 20px;
            margin: 0;
        }

        .teacher-field-error {
            color: #ba1a1a;
            font-size: 13px;
            line-height: 18px;
        }

        .teacher-alert {
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            line-height: 20px;
            padding: 14px 16px;
        }

        .teacher-alert--success {
            background: #edf7e8;
            border: 1px solid #c9ddbf;
            color: #456c3f;
        }

        .teacher-alert--error {
            background: #fff1ef;
            border: 1px solid #f2c4bc;
            color: #ba1a1a;
        }

        .teacher-key-value {
            background: var(--teacher-surface-soft);
            border: 1px solid var(--teacher-border);
            border-radius: 8px;
            padding: 16px;
        }

        .teacher-key-value dt {
            color: var(--teacher-text-soft);
            font-size: 13px;
            font-weight: 600;
            line-height: 18px;
        }

        .teacher-key-value dd {
            color: var(--teacher-text);
            font-size: 15px;
            line-height: 22px;
            margin-top: 8px;
        }

        .teacher-media-grid {
            display: grid;
            gap: 12px;
        }

        @@media (min-width: 900px) {
            .teacher-media-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        .teacher-media-link {
            align-items: center;
            background: var(--teacher-surface-soft);
            border: 1px solid var(--teacher-border);
            border-radius: 8px;
            color: var(--teacher-text-muted);
            display: flex;
            gap: 12px;
            min-height: 56px;
            padding: 14px 16px;
        }

        .teacher-media-link:hover {
            border-color: var(--teacher-primary);
            color: var(--teacher-primary-strong);
        }

        .teacher-avatar {
            border: 1px solid var(--teacher-border);
            border-radius: 9999px;
            height: 44px;
            object-fit: cover;
            width: 44px;
        }

        .teacher-avatar-fallback {
            align-items: center;
            background: var(--teacher-primary-soft);
            border: 1px solid var(--teacher-border);
            border-radius: 9999px;
            color: var(--teacher-primary-strong);
            display: inline-flex;
            font-size: 14px;
            font-weight: 700;
            height: 44px;
            justify-content: center;
            width: 44px;
        }

        .teacher-divider {
            border-top: 1px solid var(--teacher-border);
        }

        .teacher-modal-backdrop {
            align-items: center;
            background: rgba(26, 28, 25, 0.28);
            display: none;
            inset: 0;
            justify-content: center;
            padding: 24px;
            position: fixed;
            z-index: 70;
        }

        .teacher-modal-backdrop.is-open {
            display: flex;
        }

        .teacher-modal {
            background: #fff;
            border: 1px solid var(--teacher-border);
            border-radius: 8px;
            max-width: 420px;
            width: 100%;
        }

        .teacher-modal-content {
            padding: 24px;
        }
    </style>
</head>
<body class="teacher-shell">
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentUserIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
        var currentUserId = int.TryParse(currentUserIdClaim, out var parsedUserId) ? parsedUserId : (int?)null;
        var currentTeacherProfile = currentUserId.HasValue
            ? await DbContext.Users.AsNoTracking()
                .Where(x => x.Id == currentUserId.Value)
                .Select(x => new { x.FullName, x.AvatarUrl })
                .FirstOrDefaultAsync()
            : null;
        var currentTeacherName = currentTeacherProfile?.FullName ?? User.FindFirstValue(ClaimTypes.GivenName) ?? User.Identity?.Name ?? "Giáo viên";
        var currentTeacherAvatarUrl = currentTeacherProfile?.AvatarUrl;
        string NavClass(string controller) => currentController == controller ? "teacher-nav-link is-active" : "teacher-nav-link";
    }

    <aside class="teacher-sidebar fixed left-0 top-0 flex h-screen w-72 flex-col py-6">
        <div class="mb-8 px-6">
            <div class="teacher-logo">
                <div class="teacher-logo-mark">
                    <span class="material-symbols-outlined text-[24px]">school</span>
                </div>
                <div>
                    <div class="teacher-logo-wordmark">QPSTEM</div>
                    <div class="teacher-logo-subtitle">GIÁO VIÊN</div>
                </div>
            </div>
        </div>

        <nav class="flex-1 overflow-y-auto px-4">
            <div class="flex flex-col gap-1">
                <a class="@NavClass("Dashboard")" asp-area="Teacher" asp-controller="Dashboard" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">dashboard</span>
                    <span>Bảng điều khiển</span>
                </a>
                <a class="@NavClass("Schedule")" asp-area="Teacher" asp-controller="Schedule" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">calendar_month</span>
                    <span>Lịch dạy</span>
                </a>
                <a class="@NavClass("Attendances")" asp-area="Teacher" asp-controller="Attendances" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">fact_check</span>
                    <span>Điểm danh</span>
                </a>
                <a class="@NavClass("Evidence")" asp-area="Teacher" asp-controller="Evidence" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">photo_library</span>
                    <span>Minh chứng</span>
                </a>
                <a class="@NavClass("AICopilot")" asp-area="Teacher" asp-controller="AICopilot" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">auto_awesome</span>
                    <span>AI Copilot</span>
                    <span class="teacher-badge">Chuẩn bị</span>
                </a>
                <a class="@NavClass("Equipment")" asp-area="Teacher" asp-controller="Equipment" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">inventory_2</span>
                    <span>Mượn / Trả thiết bị</span>
                </a>
            </div>
        </nav>

        <div class="mt-auto border-t border-[#e3e3de] px-4 pt-6">
            <div class="flex items-center gap-3 px-2">
                @if (!string.IsNullOrWhiteSpace(currentTeacherAvatarUrl))
                {
                    <img alt="@currentTeacherName" class="teacher-avatar" src="@currentTeacherAvatarUrl" />
                }
                else
                {
                    <div class="teacher-avatar-fallback">
                        @currentTeacherName.Trim()[0].ToString().ToUpperInvariant()
                    </div>
                }
                <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-[#1a1c19]">@currentTeacherName</p>
                    <p class="text-xs text-[#73796b]">Giáo viên</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="teacher-body">
        <header class="teacher-header fixed right-0 top-0 z-40 flex h-16 w-[calc(100%-18rem)] items-center justify-between px-8 text-sm">
            <div class="flex items-center gap-2 text-[#73796b]">
                <span>Teacher</span>
                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                <span class="font-semibold text-[#3b6722]">@ViewData["Title"]</span>
            </div>

            <div class="flex items-center gap-3">
                <a asp-area="Teacher" asp-controller="Schedule" asp-action="Index" class="teacher-btn-secondary !h-10 !px-4">
                    <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                    <span>Lịch dạy</span>
                </a>
                <a asp-area="Teacher" asp-controller="Attendances" asp-action="Index" class="teacher-btn-secondary !h-10 !px-4">
                    <span class="material-symbols-outlined text-[18px]">fact_check</span>
                    <span>Điểm danh</span>
                </a>
                <button type="button" class="teacher-btn-secondary !h-10 !px-4" data-teacher-logout-open>
                    <span class="material-symbols-outlined text-[18px]">logout</span>
                    <span>Đăng xuất</span>
                </button>
            </div>
        </header>

        <div class="teacher-container">
            @RenderBody()
        </div>
    </main>

    <div class="teacher-modal-backdrop" data-teacher-logout-modal>
        <div class="teacher-modal">
            <div class="teacher-modal-content">
                <h2 class="teacher-section-title">Đăng xuất</h2>
                <p class="teacher-page-subtitle mt-3 max-w-none">Bạn có muốn đăng xuất khỏi khu vực giáo viên không?</p>
                <div class="mt-6 flex justify-end gap-3">
                    <button type="button" class="teacher-btn-secondary" data-teacher-logout-close>Ở lại</button>
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="teacher-btn-primary">Đăng xuất</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        (() => {
            const modal = document.querySelector('[data-teacher-logout-modal]');
            const openButton = document.querySelector('[data-teacher-logout-open]');
            const closeButtons = document.querySelectorAll('[data-teacher-logout-close]');

            if (!modal || !openButton) {
                return;
            }

            const openModal = () => modal.classList.add('is-open');
            const closeModal = () => modal.classList.remove('is-open');

            openButton.addEventListener('click', openModal);
            closeButtons.forEach(button => button.addEventListener('click', closeModal));
            modal.addEventListener('click', event => {
                if (event.target === modal) {
                    closeModal();
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
