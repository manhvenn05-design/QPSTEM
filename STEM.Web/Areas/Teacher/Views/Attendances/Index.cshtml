@model STEM.Web.Areas.Teacher.Models.TeacherAttendanceIndexViewModel

@{
    ViewData["Title"] = "Điểm danh";
}

<section class="teacher-page">
    <div class="teacher-page-header">
        <div>
            <h1 class="teacher-page-title">Điểm danh</h1>
            <p class="teacher-page-subtitle">Chọn buổi học để ghi nhận nhanh toàn bộ học viên trong lớp.</p>
        </div>

        <div class="teacher-actions">
            <a asp-area="Teacher" asp-controller="Dashboard" asp-action="Index" class="teacher-btn-secondary">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                <span>Về bảng điều khiển</span>
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="teacher-alert teacher-alert--success">@successMessage</div>
    }

    <div class="teacher-card">
        <div class="teacher-card-section">
            <div class="teacher-toolbar">
                <div class="teacher-filter-list">
                    @foreach (var filter in Model.Filters)
                    {
                        <a asp-area="Teacher"
                           asp-controller="Attendances"
                           asp-action="Index"
                           asp-route-filter="@filter.Key"
                           asp-route-q="@Model.SearchTerm"
                           class="@(Model.SelectedFilter == filter.Key ? "teacher-filter is-active" : "teacher-filter")">
                            @filter.Label
                        </a>
                    }
                </div>

                <form method="get" class="teacher-search-form">
                    <input type="hidden" name="filter" value="@Model.SelectedFilter" />
                    <label class="sr-only" for="teacher-attendance-search">Tìm buổi học</label>
                    <div class="teacher-search-box">
                        <span class="material-symbols-outlined text-[20px] text-[#73796b]">search</span>
                        <input id="teacher-attendance-search"
                               name="q"
                               value="@Model.SearchTerm"
                               type="search"
                               placeholder="Tìm theo lớp, khóa học hoặc chủ đề" />
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="teacher-list">
        @if (Model.Sessions.Count == 0)
        {
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <p class="teacher-empty">Chưa có buổi học nào phù hợp với bộ lọc này.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var session in Model.Sessions)
            {
                <article class="teacher-card">
                    <div class="teacher-card-section">
                        <div class="teacher-session-card">
                            <div class="teacher-session-main">
                                <div class="flex flex-wrap items-center gap-3">
                                    <span class="@session.StatusBadgeClass">@session.StatusLabel</span>
                                    <span class="teacher-tag teacher-tag--neutral">@session.SessionLabel</span>
                                </div>
                                <h2 class="teacher-section-title mt-4">@session.ClassCode · @session.CourseName</h2>
                                <p class="teacher-section-subtitle mt-1">@session.Topic</p>
                                <div class="teacher-meta-row mt-4">
                                    <span>@session.ScheduleText</span>
                                    <span>@session.StudentCount học viên</span>
                                </div>
                                <p class="teacher-kicker mt-3">@session.CompletionText</p>
                            </div>

                            <div class="teacher-session-side">
                                <a asp-area="Teacher"
                                   asp-controller="Attendances"
                                   asp-action="Board"
                                   asp-route-sessionId="@session.SessionId"
                                   class="teacher-btn-primary w-full justify-center">
                                    <span class="material-symbols-outlined text-[18px]">fact_check</span>
                                    <span>Mở sổ điểm danh</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </article>
            }
        }
    </div>
</section>
