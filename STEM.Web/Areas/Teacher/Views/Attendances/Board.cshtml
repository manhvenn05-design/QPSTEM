@model STEM.Web.Areas.Teacher.Models.TeacherAttendanceBoardViewModel

@{
    ViewData["Title"] = "Điểm danh";
}

<section class="teacher-page">
    <div class="teacher-page-header">
        <div>
            <h1 class="teacher-page-title">@Model.SessionLabel · @Model.ClassCode</h1>
            <p class="teacher-page-subtitle">@Model.CourseName · @Model.ScheduleText</p>
        </div>

        <div class="teacher-actions">
            @if (!string.IsNullOrWhiteSpace(Model.TeachingMaterialUrl))
            {
                <a asp-area="Teacher" asp-controller="Schedule" asp-action="Viewer" asp-route-id="@Model.SessionId" class="teacher-btn-secondary !text-[#f97316] !border-[#f97316] hover:!bg-[#fff7ed]">
                    <span class="material-symbols-outlined text-[18px]">smart_display</span>
                    <span>Trình chiếu</span>
                </a>
            }
            <a asp-area="Teacher" asp-controller="Attendances" asp-action="Index" class="teacher-btn-secondary">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                <span>Quay lại danh sách</span>
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="teacher-alert teacher-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="teacher-alert teacher-alert--error">@errorMessage</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="teacher-alert teacher-alert--error"></div>
    }

    @if (Model.IsReadOnly && !string.IsNullOrWhiteSpace(Model.EditLockMessage))
    {
        <div class="teacher-alert teacher-alert--error">@Model.EditLockMessage</div>
    }

    <div class="teacher-board-stat-bar">
        <div class="teacher-board-stat-item">
            <span class="teacher-board-stat-value">@Model.StudentCount</span>
            <span class="teacher-board-stat-label">Sĩ số lớp</span>
        </div>
        <div class="teacher-board-stat-divider"></div>
        <div class="teacher-board-stat-item">
            <span class="teacher-board-stat-value">@Model.AttendanceCount</span>
            <span class="teacher-board-stat-label">Đã ghi nhận</span>
        </div>
        <div class="teacher-board-stat-divider"></div>
        <div class="teacher-board-stat-item teacher-board-stat-item--warn">
            <span class="teacher-board-stat-value">@Model.MissingCount</span>
            <span class="teacher-board-stat-label">Chưa ghi nhận</span>
        </div>
        <div class="teacher-board-stat-divider"></div>
        <div class="teacher-board-stat-item teacher-board-stat-item--present">
            <span class="teacher-board-stat-value">@Model.PresentCount</span>
            <span class="teacher-board-stat-label">Có mặt</span>
        </div>
        <div class="teacher-board-stat-divider"></div>
        <div class="teacher-board-stat-item teacher-board-stat-item--absent">
            <span class="teacher-board-stat-value">@Model.AbsentCount</span>
            <span class="teacher-board-stat-label">Vắng</span>
        </div>
    </div>

    @if (!Model.HasStudents)
    {
        <div class="teacher-card">
            <div class="teacher-card-section">
                <p class="teacher-empty">Lớp này chưa có học viên. Hãy ghi danh học viên trước khi điểm danh.</p>
            </div>
        </div>
    }
    else
    {
        <div class="teacher-card">
            <div class="teacher-card-section">
                <div class="teacher-toolbar">
                    <div>
                        <h2 class="teacher-section-title">Sổ điểm danh</h2>
                        <p class="teacher-section-subtitle">Ghi nhận trạng thái, nhận xét và minh chứng video cho từng học viên.</p>
                    </div>
                    <form asp-area="Teacher" asp-controller="Attendances" asp-action="MarkAllPresent" asp-route-sessionId="@Model.SessionId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="teacher-btn-secondary" disabled="@Model.IsReadOnly">
                            <span class="material-symbols-outlined text-[18px]">done_all</span>
                            <span>Đánh dấu nhanh cả lớp có mặt</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <form asp-area="Teacher" asp-controller="Attendances" asp-action="Board" method="post" class="teacher-card" id="attendance-board-form" data-read-only="@Model.IsReadOnly.ToString().ToLowerInvariant()">
            @Html.AntiForgeryToken()
            <input asp-for="SessionId" type="hidden" />

            <div class="teacher-card-section">
                <div class="teacher-board">
                    @for (var i = 0; i < Model.Rows.Count; i++)
                    {
                        <article class="teacher-board-row" data-row-index="@i">
                            <input asp-for="Rows[@i].AttendanceId" type="hidden" id="Rows_@(i)__AttendanceId" />
                            <input asp-for="Rows[@i].StudentId" type="hidden" id="Rows_@(i)__StudentId" />
                            <input asp-for="Rows[@i].StudentName" type="hidden" />
                            <input asp-for="Rows[@i].StudentUsername" type="hidden" />
                            <input asp-for="Rows[@i].StudentAvatarUrl" type="hidden" />
                            <input asp-for="Rows[@i].MediaHint" type="hidden" />
                            <input asp-for="Rows[@i].HasAttendance" type="hidden" id="Rows_@(i)__HasAttendance" />
                            <input asp-for="Rows[@i].ProductMediaUrls" type="hidden" id="Rows_@(i)__ProductMediaUrls" />
                            <input asp-for="Rows[@i].IsPresent" type="hidden" id="Rows_@(i)__IsPresent" />
                            <input asp-for="Rows[@i].IsExcused" type="hidden" id="Rows_@(i)__IsExcused" />

                            <div class="teacher-board-student">
                                @if (!string.IsNullOrWhiteSpace(Model.Rows[i].StudentAvatarUrl))
                                {
                                    <img src="@Model.Rows[i].StudentAvatarUrl" alt="@Model.Rows[i].StudentName" class="teacher-avatar" />
                                }
                                else
                                {
                                    <div class="teacher-avatar-fallback">@Model.Rows[i].StudentName.Trim()[0].ToString().ToUpperInvariant()</div>
                                }

                                <div>
                                    <p class="text-sm font-semibold text-[#1a1c19]">@Model.Rows[i].StudentName</p>
                                    <p class="mt-1 text-sm text-[#73796b]">@Model.Rows[i].StudentUsername</p>
                                    <div class="mt-3 flex flex-wrap items-center gap-3">
                                        <span class="@Model.Rows[i].StatusBadgeClass">@Model.Rows[i].StatusLabel</span>
                                    </div>
                                </div>
                            </div>

                            <div class="teacher-board-fields">
                                <div class="teacher-toggle flex flex-wrap gap-4">
                                    <label class="teacher-radio flex items-center gap-2 cursor-pointer">
                                        <input type="radio" name="Rows[@i].AttendanceStatus" value="Present" class="accent-[#0f2347]" onchange="updateAttendanceStatus(@i, 'Present'); autoSaveBoard();" @(Model.Rows[i].IsPresent ? "checked" : null) disabled="@Model.IsReadOnly" />
                                        <span class="text-sm font-medium">Có mặt</span>
                                    </label>
                                    <label class="teacher-radio flex items-center gap-2 cursor-pointer">
                                        <input type="radio" name="Rows[@i].AttendanceStatus" value="Absent" class="accent-[#ba1a1a]" onchange="updateAttendanceStatus(@i, 'Absent'); autoSaveBoard();" @(!Model.Rows[i].IsPresent && !Model.Rows[i].IsExcused && Model.Rows[i].HasAttendance ? "checked" : null) disabled="@Model.IsReadOnly" />
                                        <span class="text-sm font-medium">Vắng</span>
                                    </label>
                                    <label class="teacher-radio flex items-center gap-2 cursor-pointer">
                                        <input type="radio" name="Rows[@i].AttendanceStatus" value="Excused" class="accent-[#006e1c]" onchange="updateAttendanceStatus(@i, 'Excused'); autoSaveBoard();" @(!Model.Rows[i].IsPresent && Model.Rows[i].IsExcused ? "checked" : null) disabled="@Model.IsReadOnly" />
                                        <span class="text-sm font-medium">Vắng phép</span>
                                    </label>
                                </div>
                                <span asp-validation-for="Rows[@i].HasAttendance" class="teacher-field-error"></span>

                                <div class="teacher-field relative">
                                    <div class="mb-2 flex items-center justify-between">
                                        <label asp-for="Rows[@i].TeacherRawNote">Ghi chú giáo viên</label>
                                        <button type="button" id="btn-refine-@(i)" class="text-xs font-semibold text-[#1a3a6e] hover:text-[#0f2347] transition-colors disabled:opacity-50" onclick="refineNote(@i)" disabled="@(Model.IsReadOnly || !Model.Rows[i].IsPresent)">
                                            Nhờ AI viết lại
                                        </button>
                                    </div>
                                    <textarea asp-for="Rows[@i].TeacherRawNote" rows="3" placeholder="Ghi chú ngắn về tiến độ, thái độ hoặc điều cần lưu ý." class="transition-all duration-300 w-full disabled:opacity-50 disabled:bg-[#f5f7fb]" style="min-height: 80px; max-height: 300px; resize: vertical; overflow-y: auto;" oninput="this.style.height=''; this.style.height=this.scrollHeight + 'px';" onchange="autoSaveBoard();" readonly="@Model.IsReadOnly" disabled="@(!Model.Rows[i].IsPresent)"></textarea>
                                    <span asp-validation-for="Rows[@i].TeacherRawNote" class="teacher-field-error"></span>
                                </div>

                                <div class="teacher-field relative mt-4">
                                    <label class="font-medium text-[#1a1c19]">Tải lên video sản phẩm</label>

                                    <div class="mt-2 flex cursor-pointer justify-center rounded-lg border-2 border-dashed border-[#c2c9b9] bg-[#f8faf7] transition-colors hover:border-[#0f2347] hover:bg-[#f2f7f0] px-6 py-6 @(!Model.Rows[i].IsPresent ? "opacity-50 pointer-events-none" : "")" id="upload-area-@(i)" onclick="openUploadPicker(@i)" ondragover="handleUploadDragOver(event)" ondragleave="handleUploadDragLeave(event)" ondrop="handleUploadDrop(event, @i)">
                                        <div class="text-center">
                                            <span class="material-symbols-outlined text-[36px] text-[#73796b]">cloud_upload</span>
                                            <div class="mt-2 flex justify-center text-sm leading-6 text-[#42493f]">
                                                <label for="file-upload-@(i)" class="relative cursor-pointer rounded-md font-semibold text-[#0f2347] hover:text-[#2d4f19]" onclick="event.stopPropagation()">
                                                    <span>Tải video từ máy</span>
                                                    <input id="file-upload-@(i)" type="file" class="sr-only" accept="video/*" onchange="uploadVideoAsync(this.files?.[0], @i); this.value='';" disabled="@(Model.IsReadOnly || !Model.Rows[i].IsPresent)" />
                                                </label>
                                                <p class="pl-1">hoặc kéo thả vào đây</p>
                                            </div>
                                            <p class="text-xs leading-5 text-[#73796b]">Hỗ trợ video MP4, MOV, AVI, M4V, WEBM dưới 50MB</p>
                                        </div>
                                    </div>

                                    <div id="video-preview-@(i)" class="mt-3 hidden items-center justify-between rounded-lg border border-[#c2c9b9] bg-white p-3 shadow-sm">
                                        <div class="flex items-center gap-3 overflow-hidden">
                                            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded bg-[#e3e3de] text-[#42493f]">
                                                <span class="material-symbols-outlined text-[24px]">movie</span>
                                            </div>
                                            <div class="min-w-0 flex-1">
                                                <p class="truncate text-sm font-semibold text-[#1a1c19]" id="video-filename-@(i)">video.mp4</p>
                                                <div class="mt-1 flex items-center gap-2">
                                                    <div class="h-1.5 w-24 overflow-hidden rounded-full bg-[#e3e3de]">
                                                        <div id="video-progress-@(i)" class="h-full rounded-full bg-[#0f2347]" style="width: 0%"></div>
                                                    </div>
                                                    <span id="video-status-@(i)" class="text-[10px] font-medium text-[#0f2347]">Đang chờ tải lên</span>
                                                </div>
                                            </div>
                                        </div>
                                        <button type="button" class="ml-4 shrink-0 text-[#ba1a1a] transition-colors hover:text-[#93000a]" onclick="removeVideo(@i)" title="Xóa video này" disabled="@Model.IsReadOnly">
                                            <span class="material-symbols-outlined">delete</span>
                                        </button>
                                    </div>

                                    <span asp-validation-for="Rows[@i].ProductMediaUrls" class="teacher-field-error"></span>

                                    <button type="button" id="btn-ai-@(i)" class="mt-3 flex w-full items-center justify-center gap-2 rounded-lg bg-[#1a3a6e] px-4 py-2.5 text-sm font-bold text-white transition-all hover:bg-[#0f2347] active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed" onclick="analyzeVideoInline(this, @i)" disabled="@(Model.IsReadOnly || !Model.Rows[i].IsPresent)">
                                        <span class="material-symbols-outlined text-[20px] ai-action-icon">auto_awesome</span>
                                        <span class="ai-action-label">Đánh giá video (AI)</span>
                                    </button>

                                    <div id="ai-result-@(i)" class="mt-4 hidden overflow-hidden rounded-lg border border-[#e3e3de] bg-white shadow-sm" data-ai-evaluation="@Model.Rows[i].AiEvaluation">
                                        <div class="border-b border-[#e3e3de] bg-[#f2f7f0] px-4 py-3">
                                            <h4 class="flex items-center gap-2 text-sm font-bold text-[#0f2347]">
                                                <span class="material-symbols-outlined text-[18px]">analytics</span>
                                                Kết quả đánh giá
                                            </h4>
                                        </div>

                                        <div class="ai-loading-state hidden min-h-[180px] flex-col items-center justify-center py-8 text-center">
                                            <div class="h-10 w-10 animate-spin rounded-full border-4 border-[#f2f7f0] border-t-[#1a3a6e]"></div>
                                            <p class="mt-4 text-sm font-medium text-[#73796b]">Đang xử lý dữ liệu...</p>
                                        </div>

                                        <div class="ai-analysis-content hidden p-4" id="ai-analysis-content-@(i)">
                                            <div class="mb-5 flex items-center justify-between rounded-lg bg-[#f2f7f0] p-3">
                                                <span class="text-xs font-bold uppercase text-[#42493f]">Điểm đánh giá chung</span>
                                                <div class="flex items-center gap-3">
                                                    <div class="h-2 w-32 overflow-hidden rounded-full bg-[#e3e3de]">
                                                        <div id="ai-score-bar-@(i)" class="h-full w-[0%] rounded-full bg-[#0f2347]"></div>
                                                    </div>
                                                    <span id="ai-score-@(i)" class="text-base font-black text-[#1a1c19]">--/100</span>
                                                </div>
                                            </div>

                                            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                                                <div class="rounded-lg border border-[#e3e3de] p-3 shadow-sm">
                                                    <h5 class="mb-2 text-xs font-bold text-[#0f2347]">Điểm sáng</h5>
                                                    <ul id="ai-strengths-@(i)" class="list-disc space-y-1 pl-5 text-sm text-[#42493f]"></ul>
                                                </div>
                                                <div class="rounded-lg border border-[#e3e3de] p-3 shadow-sm">
                                                    <h5 class="mb-2 text-xs font-bold text-[#ba1a1a]">Cần cải thiện</h5>
                                                    <ul id="ai-weaknesses-@(i)" class="list-disc space-y-1 pl-5 text-sm text-[#42493f]"></ul>
                                                </div>
                                            </div>

                                            <div class="mt-4 rounded-lg border border-[#d2e3fc] bg-[#f5f9fc] p-4">
                                                <div class="mb-2 flex items-center justify-between gap-3">
                                                    <strong class="text-sm text-[#1a1c19]">Gợi ý phản hồi</strong>
                                                    <button type="button" class="rounded bg-[#1a73e8] px-2 py-1 text-xs font-medium text-white transition-colors hover:bg-[#1557b0]" onclick="applyAIComment(@i)" disabled="@Model.IsReadOnly">
                                                        Chép vào ghi chú
                                                    </button>
                                                </div>
                                                <p id="ai-suggestion-@(i)" class="whitespace-pre-line text-sm italic text-[#42493f]"></p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </article>
                    }
                </div>

                <div class="mt-8 flex flex-wrap justify-end gap-3">
                    <a asp-area="Teacher" asp-controller="Attendances" asp-action="Index" class="teacher-btn-secondary">
                        <span>Quay lại</span>
                    </a>
                    <button type="submit" class="teacher-btn-primary" disabled="@Model.IsReadOnly">
                        <span class="material-symbols-outlined text-[18px]">save</span>
                        <span>Lưu điểm danh</span>
                    </button>
                </div>
            </div>
        </form>
    }
</section>

<div class="teacher-modal-backdrop" id="aiRewriteModal">
    <div class="teacher-modal shadow-xl" style="width: 100%; max-width: 760px;">
        <div class="teacher-modal-content relative">
            <button type="button" class="absolute right-4 top-4 text-[#73796b] hover:text-[#1a1c19]" onclick="closeAiRewriteModal()">
                <span class="material-symbols-outlined">close</span>
            </button>

            <div class="mb-4 flex items-center gap-2 text-[#1a3a6e]">
                <span class="material-symbols-outlined">auto_awesome</span>
                <h2 class="text-lg font-semibold text-[#1a1c19]">AI viết lại nhận xét</h2>
            </div>

            <p class="teacher-page-subtitle mt-0 max-w-none">AI đã viết lại nhận xét theo văn phong phụ huynh dễ đọc hơn. Anh có thể xem trước rồi áp dụng thay thế.</p>

            <div class="mt-5 rounded-lg border border-[#dce6f5] bg-[#f8fbff] p-4">
                <label class="mb-2 block text-sm font-semibold text-[#1a3a6e]">Bản gợi ý</label>
                <textarea id="aiRewriteSuggestion" class="w-full rounded-lg border border-[#b0c4de] bg-white p-4 text-[15px] leading-7 text-[#1a1c19]" rows="8" readonly></textarea>
            </div>

            <div class="mt-6 flex justify-end gap-3">
                <button type="button" class="teacher-btn-secondary" onclick="closeAiRewriteModal()">Đóng</button>
                <button type="button" class="teacher-btn-primary" onclick="applyAiRewriteSuggestion()">Áp dụng thay thế</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentRewriteTargetId = null;
        const aiCooldownTimers = new Map();

        function showAlert(options) {
            if (window.TeacherDialog?.alert) {
                return window.TeacherDialog.alert(options || {});
            }

            const fallbackMessage = options?.text || options?.title || '\u0110\u00e3 x\u1ea3y ra l\u1ed7i.';
            window.alert(fallbackMessage);
            return Promise.resolve({ isConfirmed: true });
        }
        function isReadOnlyBoard() {
            return document.getElementById('attendance-board-form')?.dataset.readOnly === 'true';
        }

        function getRequestVerificationToken() {
            return document.querySelector('#attendance-board-form input[name="__RequestVerificationToken"]')?.value || '';
        }

        function extractRetrySeconds(message) {
            if (!message) {
                return null;
            }

            const match = String(message).match(/(?:sau|retry(?:\s+after)?)[^\d]*(\d+)\s*(?:s|gi)/i)
                || String(message).match(/(\d+)\s*(?:s|gi)/i);
            if (!match) {
                return null;
            }

            const seconds = parseInt(match[1], 10);
            return Number.isFinite(seconds) && seconds > 0 ? seconds : null;
        }

        function setButtonDisabledState(button, disabled) {
            if (!button) {
                return;
            }

            button.disabled = disabled;
        }

        function startAiCooldown(key, button, buildLabel, seconds) {
            if (!button || !seconds || seconds <= 0) {
                return;
            }

            const previousTimer = aiCooldownTimers.get(key);
            if (previousTimer) {
                window.clearInterval(previousTimer.intervalId);
            }

            let remainingSeconds = seconds;
            setButtonDisabledState(button, true);
            buildLabel(button, remainingSeconds);

            const intervalId = window.setInterval(() => {
                remainingSeconds -= 1;

                if (remainingSeconds <= 0) {
                    window.clearInterval(intervalId);
                    aiCooldownTimers.delete(key);
                    buildLabel(button, 0);
                    setButtonDisabledState(button, isReadOnlyBoard());
                    return;
                }

                buildLabel(button, remainingSeconds);
            }, 1000);

            aiCooldownTimers.set(key, { intervalId });
        }

        function setTextContent(id, value) {
            const element = document.getElementById(id);
            if (element) {
                element.textContent = value ?? '';
            }
        }

        function replaceListItems(listElement, items) {
            if (!listElement) {
                return;
            }

            const values = Array.isArray(items) ? items : [];
            listElement.replaceChildren(...values.map(item => {
                const li = document.createElement('li');
                li.textContent = item ?? '';
                return li;
            }));
        }

        function openUploadPicker(index) {
            if (isReadOnlyBoard()) {
                return;
            }

            document.getElementById(`file-upload-${index}`)?.click();
        }

        function updateAttendanceStatus(index, status) {
            const isPresent = document.getElementById(`Rows_${index}__IsPresent`);
            const isExcused = document.getElementById(`Rows_${index}__IsExcused`);
            const hasAttendance = document.getElementById(`Rows_${index}__HasAttendance`);
            if (!isPresent || !isExcused || !hasAttendance) {
                return;
            }

            hasAttendance.value = 'true';

            if (status === 'Present') {
                isPresent.value = 'true';
                isExcused.value = 'false';
                toggleInputs(index, true);
                return;
            }

            if (status === 'Excused') {
                isPresent.value = 'false';
                isExcused.value = 'true';
                toggleInputs(index, false);
                return;
            }

            isPresent.value = 'false';
            isExcused.value = 'false';
            toggleInputs(index, false);
        }

        function toggleInputs(index, isPresent) {
            if (isReadOnlyBoard()) return;
            const disabled = !isPresent;
            
            const txtNote = document.getElementById(`Rows_${index}__TeacherRawNote`);
            if (txtNote) {
                txtNote.disabled = disabled;
                if (disabled) txtNote.value = '';
            }
            
            const btnRefine = document.getElementById(`btn-refine-${index}`);
            if (btnRefine) btnRefine.disabled = disabled;

            const fileUpload = document.getElementById(`file-upload-${index}`);
            if (fileUpload) {
                fileUpload.disabled = disabled;
                if (disabled) fileUpload.value = '';
            }

            const btnAi = document.getElementById(`btn-ai-${index}`);
            if (btnAi) btnAi.disabled = disabled;
            
            const uploadArea = document.getElementById(`upload-area-${index}`);
            if (uploadArea) {
                if (disabled) {
                    uploadArea.classList.add('opacity-50', 'pointer-events-none');
                } else {
                    uploadArea.classList.remove('opacity-50', 'pointer-events-none');
                }
            }
            if (disabled) {
                document.getElementById(`Rows_${index}__ProductMediaUrls`).value = '';
                resetAiResult(index);
                hideVideoPreview(index);
            }
        }

        function findRowIndexByStudentId(studentId) {
            const studentInputs = document.querySelectorAll('input[id$="__StudentId"]');
            for (let index = 0; index < studentInputs.length; index++) {
                if (String(studentInputs[index].value) === String(studentId)) {
                    return index;
                }
            }

            return -1;
        }

        async function saveBoardAsync() {
            if (isReadOnlyBoard()) {
                return null;
            }

            const form = document.getElementById('attendance-board-form');
            if (!form) {
                return null;
            }

            const response = await fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            const data = await response.json().catch(() => null);
            if (!response.ok || !data?.success) {
                throw new Error(data?.message || 'Khong the luu diem danh.');
            }

            (data.rows || []).forEach(row => {
                const rowIndex = findRowIndexByStudentId(row.studentId);
                if (rowIndex < 0) {
                    return;
                }

                const attendanceInput = document.getElementById(`Rows_${rowIndex}__AttendanceId`);
                const hasAttendanceInput = document.getElementById(`Rows_${rowIndex}__HasAttendance`);
                if (attendanceInput) {
                    attendanceInput.value = row.id;
                }
                if (hasAttendanceInput) {
                    hasAttendanceInput.value = 'true';
                }
            });

            return data;
        }

        function autoSaveBoard() {
            saveBoardAsync().catch(error => console.error('Auto-save failed', error));
        }

        function showVideoPreview(index, fileName, progressText, progressPercent) {
            document.getElementById(`upload-area-${index}`)?.classList.add('hidden');
            const preview = document.getElementById(`video-preview-${index}`);
            preview?.classList.remove('hidden');
            preview?.classList.add('flex');
            setTextContent(`video-filename-${index}`, fileName);
            setTextContent(`video-status-${index}`, progressText);

            const progressBar = document.getElementById(`video-progress-${index}`);
            if (progressBar) {
                progressBar.style.width = `${progressPercent}%`;
            }
        }

        function hideVideoPreview(index) {
            document.getElementById(`video-preview-${index}`)?.classList.add('hidden');
            document.getElementById(`video-preview-${index}`)?.classList.remove('flex');
            document.getElementById(`upload-area-${index}`)?.classList.remove('hidden');
        }

        function resetAiResult(index) {
            const resultContainer = document.getElementById(`ai-result-${index}`);
            if (!resultContainer) {
                return;
            }

            resultContainer.dataset.aiEvaluation = '';
            resultContainer.classList.add('hidden');
            resultContainer.querySelector('.ai-loading-state')?.classList.add('hidden');
            resultContainer.querySelector('.ai-loading-state')?.classList.remove('flex');
            resultContainer.querySelector('.ai-analysis-content')?.classList.add('hidden');

            const label = document.querySelector(`#btn-ai-${index} .ai-action-label`);
            if (label) {
                label.textContent = 'Đánh giá video (AI)';
            }
        }

        function updateAnalyzeButtonLabel(button, remainingSeconds) {
            const icon = button?.querySelector('.ai-action-icon');
            const label = button?.querySelector('.ai-action-label');
            if (!label) {
                return;
            }

            if (remainingSeconds > 0) {
                if (icon) {
                    icon.textContent = 'schedule';
                    icon.classList.remove('animate-spin');
                }
                label.textContent = `Chờ ${remainingSeconds}s để thử lại`;
                return;
            }

            if (icon) {
                icon.textContent = 'auto_awesome';
                icon.classList.remove('animate-spin');
            }
            label.textContent = 'Đánh giá video (AI)';
        }

        function updateRefineButtonLabel(button, remainingSeconds) {
            if (!button) {
                return;
            }

            if (remainingSeconds < 0) {
                button.textContent = 'Đang xử lý...';
                return;
            }

            button.textContent = remainingSeconds > 0
                ? `Chờ ${remainingSeconds}s để thử lại`
                : 'Nhờ AI viết lại';
        }

        function normalizeAiResult(result) {
            if (!result || typeof result !== 'object') {
                return null;
            }

            const source = result.result ?? result.Result ?? result.data ?? result.Data ?? result;
            const strengths = source.strengths ?? source.Strengths ?? [];
            const weaknesses = source.weaknesses ?? source.Weaknesses ?? [];

            return {
                score: source.score ?? source.Score ?? '0',
                strengths: Array.isArray(strengths) ? strengths : [],
                weaknesses: Array.isArray(weaknesses) ? weaknesses : [],
                suggestion: source.suggestion ?? source.Suggestion ?? ''
            };
        }

        function renderAiResult(index, result) {
            const normalizedResult = normalizeAiResult(result);
            if (!normalizedResult) {
                return;
            }

            const scoreText = String(normalizedResult.score).replace(/\/100/g, '').trim();
            const scoreValue = parseInt(scoreText, 10) || 0;

            setTextContent(`ai-score-${index}`, `${scoreValue}/100`);
            setTextContent(`ai-suggestion-${index}`, normalizedResult.suggestion);
            replaceListItems(document.getElementById(`ai-strengths-${index}`), normalizedResult.strengths);
            replaceListItems(document.getElementById(`ai-weaknesses-${index}`), normalizedResult.weaknesses);

            const scoreBar = document.getElementById(`ai-score-bar-${index}`);
            if (scoreBar) {
                scoreBar.style.width = `${scoreValue}%`;
                scoreBar.style.backgroundColor = scoreValue >= 80 ? '#0f2347' : scoreValue >= 60 ? '#b26a00' : '#ba1a1a';
            }

            const resultContainer = document.getElementById(`ai-result-${index}`);
            if (resultContainer) {
                resultContainer.dataset.aiEvaluation = JSON.stringify(normalizedResult);
            }
            resultContainer?.classList.remove('hidden');
            resultContainer?.querySelector('.ai-loading-state')?.classList.add('hidden');
            resultContainer?.querySelector('.ai-loading-state')?.classList.remove('flex');
            resultContainer?.querySelector('.ai-analysis-content')?.classList.remove('hidden');
        }

        async function uploadVideoAsync(file, index) {
            if (!file || isReadOnlyBoard()) {
                return;
            }

            if (file.size > 50 * 1024 * 1024) {
                await showAlert({ icon: 'error', title: 'File quá lớn', text: 'Vui lòng chọn video dưới 50MB.', confirmButtonColor: '#1a3a6e' });
                return;
            }

            showVideoPreview(index, `Đang tải lên: ${file.name}`, 'Đang chuẩn bị tải lên', 0);

            const formData = new FormData();
            formData.append('file', file);

            const xhr = new XMLHttpRequest();
            xhr.open('POST', '/Teacher/Attendances/UploadVideo');
            const token = getRequestVerificationToken();
            if (token) {
                xhr.setRequestHeader('RequestVerificationToken', token);
            }

            xhr.upload.addEventListener('progress', event => {
                if (!event.lengthComputable) {
                    return;
                }

                const percent = Math.round((event.loaded / event.total) * 100);
                showVideoPreview(index, file.name, `Đang tải lên ${percent}%`, percent);
            });

            xhr.onload = async () => {
                try {
                    const result = JSON.parse(xhr.responseText || '{}');
                    if (xhr.status < 200 || xhr.status >= 300 || !result.success) {
                        throw new Error(result.message || 'Upload thất bại.');
                    }

                    document.getElementById(`Rows_${index}__ProductMediaUrls`).value = result.url || '';
                    resetAiResult(index);
                    showVideoPreview(index, file.name, 'Đã tải lên xong', 100);
                    await saveBoardAsync();
                } catch (error) {
                    console.error(error);
                    await showAlert({ icon: 'error', title: 'Upload thất bại', text: error.message || 'Không thể tải video lên server.', confirmButtonColor: '#1a3a6e' });
                    removeVideo(index);
                }
            };

            xhr.onerror = async () => {
                await showAlert({ icon: 'error', title: 'Upload thất bại', text: 'Không thể tải video lên server.', confirmButtonColor: '#1a3a6e' });
                removeVideo(index);
            };

            xhr.send(formData);
        }

        function removeVideo(index) {
            if (isReadOnlyBoard()) {
                return;
            }

            const fileInput = document.getElementById(`file-upload-${index}`);
            if (fileInput) {
                fileInput.value = '';
            }

            document.getElementById(`Rows_${index}__ProductMediaUrls`).value = '';
            resetAiResult(index);
            hideVideoPreview(index);
            autoSaveBoard();
        }

        async function analyzeVideoInline(button, index) {
            if (isReadOnlyBoard()) {
                return;
            }

            const mediaInput = document.getElementById(`Rows_${index}__ProductMediaUrls`);
            if (!mediaInput?.value) {
                await showAlert({ icon: 'info', title: 'Chưa có video', text: 'Vui lòng tải lên một video trước khi yêu cầu AI phân tích.', confirmButtonColor: '#b26a00' });
                return;
            }

            try {
                let attendanceId = document.getElementById(`Rows_${index}__AttendanceId`)?.value;
                if (!attendanceId) {
                    await saveBoardAsync();
                    attendanceId = document.getElementById(`Rows_${index}__AttendanceId`)?.value;
                }

                if (!attendanceId) {
                    throw new Error('Không thể tạo bản ghi điểm danh để gắn kết quả AI.');
                }

                const resultContainer = document.getElementById(`ai-result-${index}`);
                const loadingState = resultContainer?.querySelector('.ai-loading-state');
                const analysisContent = resultContainer?.querySelector('.ai-analysis-content');
                const icon = button.querySelector('.ai-action-icon');
                const label = button.querySelector('.ai-action-label');

                resultContainer?.classList.remove('hidden');
                loadingState?.classList.remove('hidden');
                loadingState?.classList.add('flex');
                analysisContent?.classList.add('hidden');
                button.disabled = true;

                if (icon) {
                    icon.textContent = 'sync';
                    icon.classList.add('animate-spin');
                }
                if (label) {
                    label.textContent = 'Đang phân tích...';
                }

                const response = await fetch('/Teacher/AICopilot/AnalyzeVideo', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getRequestVerificationToken()
                    },
                    body: JSON.stringify({
                        attendanceId: parseInt(attendanceId, 10),
                        videoUrl: mediaInput.value
                    })
                });

                const data = await response.json().catch(() => null);
                if (!response.ok || !data?.success) {
                    throw new Error(data?.message || 'Không thể phân tích video.');
                }

                renderAiResult(index, data.result || {});
                if (label) {
                    label.textContent = 'Phân tích lại video';
                }
            } catch (error) {
                console.error(error);
                const retrySeconds = extractRetrySeconds(error.message);
                if (retrySeconds) {
                    startAiCooldown(`analyze-${index}`, button, updateAnalyzeButtonLabel, retrySeconds);
                }
                await showAlert({ icon: 'error', title: 'Phân tích thất bại', text: error.message || 'Không thể kết nối đến hệ thống AI.', confirmButtonColor: '#b26a00' });
                resetAiResult(index);
            } finally {
                const hasCooldown = aiCooldownTimers.has(`analyze-${index}`);
                if (!hasCooldown) {
                    button.disabled = isReadOnlyBoard();
                    const icon = button.querySelector('.ai-action-icon');
                    if (icon) {
                        icon.textContent = 'auto_awesome';
                        icon.classList.remove('animate-spin');
                    }
                }
            }
        }

        async function refineNote(index) {
            if (isReadOnlyBoard()) {
                return;
            }

            const button = document.getElementById(`btn-refine-${index}`);
            const textarea = document.getElementById(`Rows_${index}__TeacherRawNote`);
            const currentText = textarea?.value?.trim();
            if (!currentText || currentText.length < 10) {
                await showAlert({ icon: 'warning', title: 'Ghi chú quá ngắn', text: 'Vui lòng nhập ít nhất 10 ký tự để AI có cơ sở viết lại.', confirmButtonColor: '#1a3a6e' });
                return;
            }

            try {
                setButtonDisabledState(button, true);
                updateRefineButtonLabel(button, -1);
                const response = await fetch('/Teacher/AICopilot/RefineNote', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getRequestVerificationToken()
                    },
                    body: JSON.stringify({ rawNote: currentText })
                });

                const data = await response.json().catch(() => null);
                if (!response.ok || !data?.success) {
                    throw new Error(data?.message || 'AI không thể viết lại ghi chú.');
                }

                openAiRewriteModal(`Rows_${index}__TeacherRawNote`, data.suggestion || '');
            } catch (error) {
                console.error(error);
                const retrySeconds = extractRetrySeconds(error.message);
                if (retrySeconds) {
                    startAiCooldown(`refine-${index}`, button, updateRefineButtonLabel, retrySeconds);
                }
                await showAlert({ icon: 'error', title: 'Có lỗi xảy ra', text: error.message || 'Không thể gọi AI hỗ trợ ghi chú.', confirmButtonColor: '#1a3a6e' });
            } finally {
                if (!aiCooldownTimers.has(`refine-${index}`)) {
                    updateRefineButtonLabel(button, 0);
                    setButtonDisabledState(button, isReadOnlyBoard());
                }
            }
        }

        function openAiRewriteModal(targetId, suggestion) {
            currentRewriteTargetId = targetId;
            const modal = document.getElementById('aiRewriteModal');
            const suggestionBox = document.getElementById('aiRewriteSuggestion');
            if (suggestionBox) {
                suggestionBox.value = suggestion || '';
            }
            modal?.classList.add('is-open');
        }

        function closeAiRewriteModal() {
            currentRewriteTargetId = null;
            document.getElementById('aiRewriteModal')?.classList.remove('is-open');
        }

        function applyAiRewriteSuggestion() {
            if (!currentRewriteTargetId) {
                closeAiRewriteModal();
                return;
            }

            const textarea = document.getElementById(currentRewriteTargetId);
            const suggestionBox = document.getElementById('aiRewriteSuggestion');
            if (textarea && suggestionBox) {
                textarea.value = suggestionBox.value || '';
                autoSaveBoard();
            }

            closeAiRewriteModal();
        }

        function applyAIComment(index) {
            if (isReadOnlyBoard()) {
                return;
            }

            const textarea = document.getElementById(`Rows_${index}__TeacherRawNote`);
            const suggestion = document.getElementById(`ai-suggestion-${index}`)?.textContent?.trim();
            if (!textarea || !suggestion) {
                return;
            }

            textarea.value = suggestion;
            autoSaveBoard();
        }

        function handleUploadDragOver(event) {
            if (isReadOnlyBoard()) {
                return;
            }

            event.preventDefault();
            event.currentTarget.classList.add('border-[#0f2347]', 'bg-[#f2f7f0]');
        }

        function handleUploadDragLeave(event) {
            event.preventDefault();
            event.currentTarget.classList.remove('border-[#0f2347]', 'bg-[#f2f7f0]');
        }

        function handleUploadDrop(event, index) {
            if (isReadOnlyBoard()) {
                return;
            }

            event.preventDefault();
            event.currentTarget.classList.remove('border-[#0f2347]', 'bg-[#f2f7f0]');
            const file = event.dataTransfer?.files?.[0];
            if (file) {
                uploadVideoAsync(file, index);
            }
        }

        function initializeExistingRows() {
            document.querySelectorAll('input[id$="__ProductMediaUrls"]').forEach((input, index) => {
                if (input.value) {
                    const fileName = input.value.split('/').pop() || 'video-da-luu';
                    showVideoPreview(index, fileName, 'Đã lưu trên hệ thống', 100);
                }

                const resultContainer = document.getElementById(`ai-result-${index}`);
                const rawAi = resultContainer?.dataset.aiEvaluation;
                if (!rawAi) {
                    return;
                }

                try {
                    renderAiResult(index, JSON.parse(rawAi));
                    const label = document.querySelector(`#btn-ai-${index} .ai-action-label`);
                    if (label) {
                        label.textContent = 'Phân tích lại video';
                    }
                } catch (error) {
                    console.error('Cannot parse existing AI evaluation', error);
                }
            });
        }

        window.refineNote = refineNote;
        window.updateAttendanceStatus = updateAttendanceStatus;
        window.uploadVideoAsync = uploadVideoAsync;
        window.removeVideo = removeVideo;
        window.analyzeVideoInline = analyzeVideoInline;
        window.applyAIComment = applyAIComment;
        window.handleUploadDragOver = handleUploadDragOver;
        window.handleUploadDragLeave = handleUploadDragLeave;
        window.handleUploadDrop = handleUploadDrop;
        window.openUploadPicker = openUploadPicker;
        window.autoSaveBoard = autoSaveBoard;
        window.closeAiRewriteModal = closeAiRewriteModal;
        window.applyAiRewriteSuggestion = applyAiRewriteSuggestion;

        document.addEventListener('DOMContentLoaded', initializeExistingRows);
    </script>
}
