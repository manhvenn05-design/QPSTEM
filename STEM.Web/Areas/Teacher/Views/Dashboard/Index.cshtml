@model STEM.Web.Areas.Teacher.Models.TeacherDashboardViewModel

@{
    ViewData["Title"] = "Bảng điều khiển";
}

<section class="teacher-page">
    <div class="teacher-page-header">
        <div>
            <h1 class="teacher-page-title">Bảng điều khiển</h1>
            <p class="teacher-page-subtitle">Theo dõi lịch dạy, điểm danh, minh chứng và thiết bị</p>
        </div>

        <div class="teacher-actions">
            <a asp-area="Teacher" asp-controller="Schedule" asp-action="Index" class="teacher-btn-secondary">
                <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                <span>Xem lịch dạy</span>
            </a>
            <a asp-area="Teacher" asp-controller="Attendances" asp-action="Index" class="teacher-btn-primary">
                <span class="material-symbols-outlined text-[18px]">fact_check</span>
                <span>Mở điểm danh</span>
            </a>
        </div>
    </div>

    <div class="teacher-card">
        <div class="teacher-card-section">
            <div class="teacher-inline-list items-center justify-between">
                <div>
                    <p class="teacher-section-title">@Model.TodayLabel</p>
                </div>
                <div class="teacher-inline-list">
                    <a asp-area="Teacher" asp-controller="Evidence" asp-action="Index" class="teacher-filter">Minh chứng</a>
                    <a asp-area="Teacher" asp-controller="Equipment" asp-action="Index" class="teacher-filter">Thiết bị</a>
                </div>
            </div>
        </div>
    </div>

    <div class="teacher-stat-grid teacher-stat-grid--6">
        <article class="teacher-stat-card">
            <span class="teacher-stat-label">Lớp đang phụ trách</span>
            <div class="teacher-stat-value">@Model.ActiveClassCount</div>
            <p class="teacher-kicker">Các lớp đang trong thời gian học.</p>
        </article>
        <article class="teacher-stat-card">
            <span class="teacher-stat-label">Học viên đang theo lớp</span>
            <div class="teacher-stat-value">@Model.TotalStudentCount</div>
            <p class="teacher-kicker">Tổng số học viên trong các lớp bạn phụ trách.</p>
        </article>
        <article class="teacher-stat-card">
            <span class="teacher-stat-label">Buổi học hôm nay</span>
            <div class="teacher-stat-value">@Model.TodaySessionCount</div>
            <p class="teacher-kicker">Theo lịch dạy trong ngày.</p>
        </article>
        <article class="teacher-stat-card">
            <span class="teacher-stat-label">Buổi chưa đủ điểm danh</span>
            <div class="teacher-stat-value">@Model.PendingAttendanceCount</div>
            <p class="teacher-kicker">Nên xử lý trước khi kết thúc ngày.</p>
        </article>
        <article class="teacher-stat-card">
            <span class="teacher-stat-label">Buổi sắp tới</span>
            <div class="teacher-stat-value">@Model.UpcomingSessionCount</div>
            <p class="teacher-kicker">Các buổi học tiếp theo của bạn.</p>
        </article>
        <article class="teacher-stat-card">
            <span class="teacher-stat-label">Thiết bị đang mượn</span>
            <div class="teacher-stat-value">@Model.ActiveBorrowCount</div>
            <p class="teacher-kicker">Theo dõi để trả đúng buổi.</p>
        </article>
    </div>

    <div class="teacher-panel-grid">
        <div class="teacher-stack">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <div class="teacher-page-header !gap-6 !flex-col lg:!flex-row lg:!items-center">
                        <div>
                            <h2 class="teacher-section-title">Buổi học hôm nay</h2>
                            <p class="teacher-section-subtitle">Mở nhanh điểm danh hoặc xem giáo án.</p>
                        </div>
                        <a asp-area="Teacher" asp-controller="Attendances" asp-action="Index" asp-route-filter="today" class="teacher-btn-secondary">
                            <span class="material-symbols-outlined text-[18px]">fact_check</span>
                            <span>Xem tất cả</span>
                        </a>
                    </div>

                    <div class="teacher-list mt-6">
                        @if (Model.TodaySessions.Count == 0)
                        {
                            <p class="teacher-empty">Hôm nay chưa có buổi học nào trong lịch của bạn.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.TodaySessions)
                            {
                                <article class="teacher-data-row">
                                    <div class="teacher-session-card">
                                        <div class="teacher-session-main">
                                            <div class="flex flex-wrap items-center gap-3">
                                                <span class="teacher-tag teacher-tag--success">@item.SessionLabel</span>
                                                <span class="teacher-tag teacher-tag--neutral">@item.AttendancePercent%</span>
                                            </div>
                                            <h3 class="teacher-section-title mt-4">@item.ClassCode · @item.CourseName</h3>
                                            <p class="teacher-section-subtitle mt-1">@item.Topic</p>
                                            <div class="teacher-meta-row mt-4">
                                                <span>@item.ScheduleText</span>
                                                <span>@item.StudentCount học viên</span>
                                                <span>@item.AttendanceCount đã ghi nhận</span>
                                            </div>
                                        </div>
                                        <div class="teacher-session-side !min-w-[260px]">
                                            <div class="teacher-inline-list w-full justify-end">
                                                <a asp-area="Teacher" asp-controller="Schedule" asp-action="Details" asp-route-id="@item.SessionId" class="teacher-btn-secondary">Chi tiết</a>
                                                <a asp-area="Teacher" asp-controller="Attendances" asp-action="Board" asp-route-sessionId="@item.SessionId" class="teacher-btn-primary">Điểm danh</a>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <div class="teacher-page-header !gap-6 !flex-col lg:!flex-row lg:!items-center">
                        <div>
                            <h2 class="teacher-section-title">Lịch gần tới</h2>
                            <p class="teacher-section-subtitle">Xem trước chủ đề và chuẩn bị giáo án cho các buổi kế tiếp.</p>
                        </div>
                        <a asp-area="Teacher" asp-controller="Schedule" asp-action="Index" asp-route-filter="upcoming" class="teacher-btn-secondary">
                            <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                            <span>Mở lịch dạy</span>
                        </a>
                    </div>

                    <div class="teacher-list mt-6">
                        @if (Model.UpcomingSessions.Count == 0)
                        {
                            <p class="teacher-empty">Chưa có buổi học nào trong 7 ngày tới.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.UpcomingSessions)
                            {
                                <article class="teacher-data-row">
                                    <div class="teacher-session-card">
                                        <div class="teacher-session-main">
                                            <div class="flex flex-wrap items-center gap-3">
                                                <span class="teacher-tag teacher-tag--warning">@item.SessionLabel</span>
                                            </div>
                                            <h3 class="teacher-section-title mt-4">@item.ClassCode · @item.CourseName</h3>
                                            <p class="teacher-section-subtitle mt-1">@item.Topic</p>
                                            <div class="teacher-meta-row mt-4">
                                                <span>@item.ScheduleText</span>
                                                <span>@item.StudentCount học viên</span>
                                            </div>
                                        </div>
                                        <div class="teacher-session-side !min-w-[200px]">
                                            <a asp-area="Teacher" asp-controller="Schedule" asp-action="Details" asp-route-id="@item.SessionId" class="teacher-btn-secondary w-full">Xem chi tiết</a>
                                        </div>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="teacher-stack">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Minh chứng cần bổ sung</h2>
                    <p class="teacher-section-subtitle">Ưu tiên hoàn tất các buổi còn thiếu ghi chú hoặc media.</p>

                    <div class="teacher-list mt-6">
                        @if (Model.EvidenceQueue.Count == 0)
                        {
                            <p class="teacher-empty">Các buổi gần đây đã có đủ ghi chú và media.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.EvidenceQueue)
                            {
                                <a asp-area="Teacher" asp-controller="Evidence" asp-action="Details" asp-route-id="@item.AttendanceId" class="teacher-data-row">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <p class="text-sm font-semibold text-[#1a1c19]">@item.StudentName</p>
                                            <p class="teacher-section-subtitle mt-1">@item.ClassCode · @item.SessionLabel</p>
                                        </div>
                                        <span class="@item.StatusBadgeClass">@item.StatusLabel</span>
                                    </div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Thiết bị đang giữ</h2>
                    <p class="teacher-section-subtitle">Theo dõi để trả đúng buổi hoặc chuyển buổi khi cần.</p>

                    <div class="teacher-list mt-6">
                        @if (Model.ActiveBorrows.Count == 0)
                        {
                            <p class="teacher-empty">Hiện tại bạn chưa có thiết bị nào đang mượn.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.ActiveBorrows)
                            {
                                <article class="teacher-data-row">
                                    <div class="flex items-start gap-4">
                                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                        {
                                            <img class="h-14 w-14 rounded-xl border border-[#e3e3de] object-cover" src="@item.ImageUrl" alt="@item.EquipmentSerialNumber" />
                                        }
                                        else
                                        {
                                            <div class="flex h-14 w-14 items-center justify-center rounded-xl border border-[#e3e3de] bg-[#f2f7f0] text-[#3b6722]">
                                                <span class="material-symbols-outlined text-[22px]">inventory_2</span>
                                            </div>
                                        }
                                        <div>
                                            <p class="text-sm font-semibold text-[#1a1c19]">@item.EquipmentSerialNumber</p>
                                            <p class="teacher-section-subtitle mt-1">@item.SessionLabel</p>
                                            <p class="teacher-list-note mt-2">Mượn lúc @item.BorrowTimeText</p>
                                        </div>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
