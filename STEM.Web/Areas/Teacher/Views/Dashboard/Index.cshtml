@model STEM.Web.Areas.Teacher.Models.TeacherDashboardViewModel

@{
    ViewData["Title"] = "Bảng điều khiển";
}

<section class="teacher-page">
    <div class="teacher-page-header">
        <div>
            <h1 class="teacher-page-title">Bảng điều khiển</h1>
        </div>

        <div class="teacher-actions">
            <a asp-area="Teacher" asp-controller="Schedule" asp-action="Index" class="teacher-btn-secondary">
                <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                <span>Lịch dạy</span>
            </a>
            <a asp-area="Teacher" asp-controller="Attendances" asp-action="Index" class="teacher-btn-primary">
                <span class="material-symbols-outlined text-[18px]">fact_check</span>
                <span>Điểm danh</span>
            </a>
        </div>
    </div>

    <div class="teacher-card">
        <div class="teacher-card-section">
            <div class="flex items-center justify-between flex-wrap gap-4">
                <div class="flex items-center gap-3">
                    <div style="width:40px;height:40px;border-radius:50%;overflow:hidden;flex-shrink:0;box-shadow:0 2px 8px rgba(249,115,22,0.25);">
                        <img src="/images/team/TIPY.jpg" alt="TIPY" style="width:100%;height:100%;object-fit:cover;" />
                    </div>
                    <div>
                        <p class="text-[11px] font-bold uppercase tracking-widest text-[#6b7c99] mb-0.5">@Model.TodayLabel</p>
                        <h2 class="text-lg font-bold text-[#0f1e38] m-0">Xin chào, @Model.TeacherName! 👋</h2>
                    </div>
                </div>
                <div class="teacher-inline-list">
                    <a asp-area="Teacher" asp-controller="Evidence" asp-action="Index" class="teacher-btn-secondary">Minh chứng</a>
                    <a asp-area="Teacher" asp-controller="Equipment" asp-action="Index" class="teacher-btn-secondary">Thiết bị</a>
                </div>
            </div>

            <!-- Stat strip compact -->
            <div class="mt-4 flex flex-wrap gap-2">
                <div class="flex items-center gap-2 rounded-lg border border-[#dce6f5] bg-[#f5f7fb] px-4 py-2.5 hover:border-[#1a3a6e] transition-colors">
                    <span class="material-symbols-outlined text-[16px] text-[#1a3a6e]" style="font-variation-settings:'FILL' 1;">today</span>
                    <span class="text-xs text-[#3a4f6e] font-medium">Hôm nay</span>
                    <span class="text-base font-bold text-[#0f1e38] ml-1">@Model.TodaySessionCount</span>
                    <span class="text-xs text-[#6b7c99]">buổi</span>
                </div>
                <div class="flex items-center gap-2 rounded-lg border @(Model.PendingAttendanceCount > 0 ? "border-[#fed7aa] bg-[#fff7ed]" : "border-[#dce6f5] bg-[#f5f7fb]") px-4 py-2.5 hover:border-[#f97316] transition-colors">
                    <span class="material-symbols-outlined text-[16px] @(Model.PendingAttendanceCount > 0 ? "text-[#f97316]" : "text-[#6b7c99]")" style="font-variation-settings:'FILL' 1;">pending_actions</span>
                    <span class="text-xs text-[#3a4f6e] font-medium">Chưa điểm danh</span>
                    <span class="text-base font-bold @(Model.PendingAttendanceCount > 0 ? "text-[#f97316]" : "text-[#0f1e38]") ml-1">@Model.PendingAttendanceCount</span>
                    <span class="text-xs text-[#6b7c99]">buổi</span>
                </div>
                <div class="flex items-center gap-2 rounded-lg border border-[#dce6f5] bg-[#f5f7fb] px-4 py-2.5 hover:border-[#a78bfa] transition-colors">
                    <span class="material-symbols-outlined text-[16px] text-[#a78bfa]" style="font-variation-settings:'FILL' 1;">upcoming</span>
                    <span class="text-xs text-[#3a4f6e] font-medium">Sắp tới</span>
                    <span class="text-base font-bold text-[#0f1e38] ml-1">@Model.UpcomingSessionCount</span>
                    <span class="text-xs text-[#6b7c99]">buổi</span>
                </div>
                <div class="flex items-center gap-2 rounded-lg border @(Model.ActiveBorrowCount > 0 ? "border-[#bfdbfe] bg-[#eff6ff]" : "border-[#dce6f5] bg-[#f5f7fb]") px-4 py-2.5 hover:border-[#60a5fa] transition-colors">
                    <span class="material-symbols-outlined text-[16px] @(Model.ActiveBorrowCount > 0 ? "text-[#60a5fa]" : "text-[#6b7c99]")" style="font-variation-settings:'FILL' 1;">inventory_2</span>
                    <span class="text-xs text-[#3a4f6e] font-medium">Đang mượn</span>
                    <span class="text-base font-bold @(Model.ActiveBorrowCount > 0 ? "text-[#60a5fa]" : "text-[#0f1e38]") ml-1">@Model.ActiveBorrowCount</span>
                    <span class="text-xs text-[#6b7c99]">phiếu</span>
                </div>
            </div>
        </div>
    </div>

    <div class="teacher-panel-grid">
        <div class="teacher-stack">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <div class="teacher-toolbar">
                        <div>
                            <h2 class="teacher-section-title">Buổi hôm nay</h2>
                            <p class="teacher-section-subtitle">Mở nhanh để điểm danh hoặc xem chi tiết.</p>
                        </div>
                        <a asp-area="Teacher" asp-controller="Attendances" asp-action="Index" class="teacher-btn-secondary">Xem tất cả</a>
                    </div>

                    <div class="teacher-list mt-6">
                        @if (Model.TodaySessions.Count == 0)
                        {
                            <p class="teacher-empty">Hôm nay chưa có buổi học.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.TodaySessions)
                            {
                                <article class="teacher-card border border-[#e3e3de] shadow-none">
                                    <div class="teacher-card-section">
                                        <div class="teacher-session-card">
                                            <div class="teacher-session-main">
                                                <div class="flex flex-wrap items-center gap-3">
                                                    <span class="teacher-tag teacher-tag--success">@item.SessionLabel</span>
                                                    <span class="teacher-tag teacher-tag--neutral">@item.AttendancePercent%</span>
                                                </div>
                                                <h3 class="teacher-section-title mt-4">@item.ClassCode · @item.CourseName</h3>
                                                <p class="teacher-section-subtitle mt-1">@item.Topic</p>
                                                <div class="teacher-meta-row mt-4">
                                                    <span>@item.ScheduleText</span>
                                                    <span>@item.StudentCount học viên</span>
                                                    <span>@item.AttendanceCount đã ghi nhận</span>
                                                </div>
                                            </div>
                                            <div class="teacher-session-side !min-w-[240px]">
                                                <div class="teacher-inline-list w-full justify-end">
                                                    <a asp-area="Teacher" asp-controller="Schedule" asp-action="Details" asp-route-id="@item.SessionId" class="teacher-btn-secondary">Chi tiết</a>
                                                    <a asp-area="Teacher" asp-controller="Attendances" asp-action="Board" asp-route-sessionId="@item.SessionId" class="teacher-btn-primary">Điểm danh</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <div class="teacher-toolbar">
                        <div>
                            <h2 class="teacher-section-title">Sắp tới</h2>
                            <p class="teacher-section-subtitle">Xem trước lịch dạy gần nhất.</p>
                        </div>
                        <a asp-area="Teacher" asp-controller="Schedule" asp-action="Index" asp-route-filter="upcoming" class="teacher-btn-secondary">Mở lịch</a>
                    </div>

                    <div class="teacher-list mt-6">
                        @if (Model.UpcomingSessions.Count == 0)
                        {
                            <p class="teacher-empty">Chưa có buổi học sắp tới.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.UpcomingSessions)
                            {
                                <article class="teacher-data-row">
                                    <div class="teacher-session-card">
                                        <div class="teacher-session-main">
                                            <div class="flex flex-wrap items-center gap-3">
                                                <span class="teacher-tag teacher-tag--warning">@item.SessionLabel</span>
                                            </div>
                                            <h3 class="teacher-section-title mt-4">@item.ClassCode · @item.CourseName</h3>
                                            <div class="teacher-meta-row mt-4">
                                                <span>@item.ScheduleText</span>
                                                <span>@item.StudentCount học viên</span>
                                            </div>
                                        </div>
                                        <div class="teacher-session-side !min-w-[180px]">
                                            <a asp-area="Teacher" asp-controller="Schedule" asp-action="Details" asp-route-id="@item.SessionId" class="teacher-btn-secondary w-full">Chi tiết</a>
                                        </div>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="teacher-stack">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <div class="teacher-toolbar">
                        <div>
                            <h2 class="teacher-section-title">Minh chứng</h2>
                            <p class="teacher-section-subtitle">Các bản ghi nên kiểm tra lại.</p>
                        </div>
                        <a asp-area="Teacher" asp-controller="Evidence" asp-action="Index" class="teacher-btn-secondary">Mở mục này</a>
                    </div>

                    <div class="teacher-list mt-6">
                        @if (Model.EvidenceQueue.Count == 0)
                        {
                            <p class="teacher-empty">Không có bản ghi nào đang chờ bổ sung.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.EvidenceQueue)
                            {
                                <a asp-area="Teacher" asp-controller="Evidence" asp-action="Details" asp-route-id="@item.AttendanceId" class="teacher-data-row">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <p class="text-sm font-semibold text-[#1a1c19]">@item.StudentName</p>
                                            <p class="teacher-section-subtitle mt-1">@item.ClassCode · @item.SessionLabel</p>
                                        </div>
                                        <span class="@item.StatusBadgeClass">@item.StatusLabel</span>
                                    </div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <div class="teacher-toolbar">
                        <div>
                            <h2 class="teacher-section-title">Thiết bị đang giữ</h2>
                            <p class="teacher-section-subtitle">Các phiếu mượn đang mở.</p>
                        </div>
                        <a asp-area="Teacher" asp-controller="Equipment" asp-action="Index" class="teacher-btn-secondary">Mở thiết bị</a>
                    </div>

                    <div class="teacher-list mt-6">
                        @if (Model.ActiveBorrows.Count == 0)
                        {
                            <p class="teacher-empty">Bạn chưa có thiết bị nào đang mượn.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.ActiveBorrows)
                            {
                                <article class="teacher-data-row">
                                    <div class="flex items-start gap-4">
                                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                        {
                                            <img class="h-14 w-14 rounded-xl border border-[#e3e3de] object-cover" src="@item.ImageUrl" alt="@item.EquipmentSerialNumber" />
                                        }
                                        else
                                        {
                                            <div class="flex h-14 w-14 items-center justify-center rounded-xl border border-[#e3e3de] bg-[#f2f7f0] text-[#0f2347]">
                                                <span class="material-symbols-outlined text-[22px]">inventory_2</span>
                                            </div>
                                        }
                                        <div>
                                            <p class="text-sm font-semibold text-[#1a1c19]">@item.EquipmentSerialNumber</p>
                                            <p class="teacher-section-subtitle mt-1">@item.SessionLabel</p>
                                            <p class="teacher-list-note mt-2">@item.BorrowTimeText</p>
                                        </div>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
