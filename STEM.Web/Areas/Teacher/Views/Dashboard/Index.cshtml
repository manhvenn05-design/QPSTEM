@{
    ViewData["Title"] = "Bảng điều khiển";
}

<section class="teacher-page">
    <div class="teacher-page-header">
        <div>
            <h1 class="teacher-page-title">Bảng điều khiển giáo viên</h1>
            <p class="teacher-page-subtitle">Tập trung vào các use case đã xác định: xem lịch dạy, mở giáo án, điểm danh, tải minh chứng sản phẩm, dùng AI tạo nhận xét và quản lý mượn trả thiết bị cho từng buổi học.</p>
        </div>

        <div class="teacher-actions">
            <button type="button" class="teacher-btn-secondary">
                <span class="material-symbols-outlined text-[18px]">menu_book</span>
                <span>Mở giáo án gần nhất</span>
            </button>
            <button type="button" class="teacher-btn-primary">
                <span class="material-symbols-outlined text-[18px]">fact_check</span>
                <span>Điểm danh buổi hiện tại</span>
            </button>
        </div>
    </div>

    <div class="teacher-stat-grid">
        <article class="teacher-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="teacher-stat-label">Buổi dạy hôm nay</span>
                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">calendar_month</span>
            </div>
            <div>
                <div class="teacher-stat-value">3</div>
                <p class="teacher-kicker">1 buổi đang diễn ra, 2 buổi tiếp theo trong ngày.</p>
            </div>
        </article>

        <article class="teacher-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="teacher-stat-label">Học sinh cần điểm danh</span>
                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">groups</span>
            </div>
            <div>
                <div class="teacher-stat-value">34</div>
                <p class="teacher-kicker">Tổng số học sinh của các buổi còn lại hôm nay.</p>
            </div>
        </article>

        <article class="teacher-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="teacher-stat-label">Minh chứng cần tải lên</span>
                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">photo_library</span>
            </div>
            <div>
                <div class="teacher-stat-value">8</div>
                <p class="teacher-kicker">Ảnh hoặc video sản phẩm còn thiếu ở 2 buổi gần nhất.</p>
            </div>
        </article>

        <article class="teacher-stat-card">
            <div class="flex items-start justify-between gap-4">
                <span class="teacher-stat-label">Nhận xét AI chờ hoàn tất</span>
                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">auto_awesome</span>
            </div>
            <div>
                <div class="teacher-stat-value">5</div>
                <p class="teacher-kicker">Các raw note đã nhập nhưng chưa gửi bản hoàn chỉnh cho phụ huynh.</p>
            </div>
        </article>
    </div>

    <div class="teacher-grid-two">
        <div class="space-y-6">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <h2 class="teacher-section-title">Lịch dạy hôm nay</h2>
                            <p class="teacher-section-subtitle">Từ use case “Xem lịch dạy” và “Mở tài liệu giáo án”.</p>
                        </div>
                        <span class="teacher-tag teacher-tag--neutral">03/05/2026</span>
                    </div>

                    <div class="teacher-list">
                        <article class="teacher-list-item">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <p class="text-sm font-semibold text-[#1a1c19]">RBX-2405-A · Robotics Explorer</p>
                                    <p class="mt-1 text-sm text-[#73796b]">08:00 - 10:00 · Phòng STEM 01 · 12 học sinh</p>
                                </div>
                                <span class="teacher-tag teacher-tag--success">Đang diễn ra</span>
                            </div>
                            <div class="mt-4 flex flex-wrap gap-3">
                                <button type="button" class="teacher-btn-primary !h-10">Mở giáo án</button>
                                <button type="button" class="teacher-btn-secondary !h-10">Điểm danh</button>
                            </div>
                        </article>

                        <article class="teacher-list-item">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <p class="text-sm font-semibold text-[#1a1c19]">SCR-2405-B · Scratch Creative Lab</p>
                                    <p class="mt-1 text-sm text-[#73796b]">13:30 - 15:30 · Phòng STEM 02 · 15 học sinh</p>
                                </div>
                                <span class="teacher-tag teacher-tag--warning">Sắp bắt đầu</span>
                            </div>
                            <div class="mt-4 flex flex-wrap gap-3">
                                <button type="button" class="teacher-btn-secondary !h-10">Chuẩn bị giáo án</button>
                                <button type="button" class="teacher-btn-secondary !h-10">Xem danh sách lớp</button>
                            </div>
                        </article>

                        <article class="teacher-list-item">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <p class="text-sm font-semibold text-[#1a1c19]">AIJ-2406-C · AI Junior Builder</p>
                                    <p class="mt-1 text-sm text-[#73796b]">16:00 - 18:00 · Phòng STEM Lab · 7 học sinh</p>
                                </div>
                                <span class="teacher-tag teacher-tag--neutral">Cuối ngày</span>
                            </div>
                            <div class="mt-4 flex flex-wrap gap-3">
                                <button type="button" class="teacher-btn-secondary !h-10">Mượn thiết bị</button>
                                <button type="button" class="teacher-btn-secondary !h-10">Mở checklist buổi học</button>
                            </div>
                        </article>
                    </div>
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Tác vụ trọng tâm cuối buổi</h2>
                    <p class="teacher-section-subtitle">Bám đúng activity flow đã xác định: điểm danh, upload media, nhập raw note và sinh đánh giá AI.</p>

                    <div class="teacher-quick-grid">
                        <article class="teacher-quick-card">
                            <div class="flex items-center justify-between gap-3">
                                <h3 class="text-base font-semibold text-[#1a1c19]">Điểm danh học sinh</h3>
                                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">fact_check</span>
                            </div>
                            <p>Chọn buổi học kết thúc, đánh dấu có mặt/vắng và ghi nhận tình trạng tham gia của từng học sinh.</p>
                            <button type="button" class="teacher-btn-primary mt-auto !h-10">Mở danh sách điểm danh</button>
                        </article>

                        <article class="teacher-quick-card">
                            <div class="flex items-center justify-between gap-3">
                                <h3 class="text-base font-semibold text-[#1a1c19]">Tải ảnh / video sản phẩm</h3>
                                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">upload</span>
                            </div>
                            <p>Tải minh chứng thực hành của từng bé hoặc ảnh không khí cả lớp lên cloud để trả URL về hệ thống.</p>
                            <button type="button" class="teacher-btn-secondary mt-auto !h-10">Chuẩn bị thư viện minh chứng</button>
                        </article>

                        <article class="teacher-quick-card">
                            <div class="flex items-center justify-between gap-3">
                                <h3 class="text-base font-semibold text-[#1a1c19]">AI tạo nhận xét</h3>
                                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">auto_awesome</span>
                            </div>
                            <p>Nhập các ý chính giáo viên muốn nói, sau đó AI sinh đoạn đánh giá mượt mà để gửi cho phụ huynh.</p>
                            <button type="button" class="teacher-btn-secondary mt-auto !h-10">Mở AI Copilot</button>
                        </article>

                        <article class="teacher-quick-card">
                            <div class="flex items-center justify-between gap-3">
                                <h3 class="text-base font-semibold text-[#1a1c19]">Mượn / trả thiết bị</h3>
                                <span class="material-symbols-outlined text-[20px] text-[#6a994e]">inventory_2</span>
                            </div>
                            <p>Theo dõi các bộ kit đã mượn cho từng session, cập nhật trạng thái trả lại hoặc báo hỏng nếu cần.</p>
                            <button type="button" class="teacher-btn-secondary mt-auto !h-10">Mở phiếu thiết bị</button>
                        </article>
                    </div>
                </div>
            </div>
        </div>

        <aside class="space-y-6">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Tiến độ hoàn tất hôm nay</h2>
                    <p class="teacher-section-subtitle">Tóm tắt nhanh các đầu việc giáo viên cần đóng trong ngày.</p>

                    <div class="mt-6 space-y-5">
                        <div>
                            <div class="mb-2 flex items-center justify-between text-sm text-[#42493d]">
                                <span>Điểm danh</span>
                                <span>68%</span>
                            </div>
                            <div class="teacher-progress">
                                <div class="teacher-progress-bar" style="width:68%;"></div>
                            </div>
                        </div>
                        <div>
                            <div class="mb-2 flex items-center justify-between text-sm text-[#42493d]">
                                <span>Minh chứng sản phẩm</span>
                                <span>45%</span>
                            </div>
                            <div class="teacher-progress">
                                <div class="teacher-progress-bar" style="width:45%;"></div>
                            </div>
                        </div>
                        <div>
                            <div class="mb-2 flex items-center justify-between text-sm text-[#42493d]">
                                <span>Nhận xét AI</span>
                                <span>32%</span>
                            </div>
                            <div class="teacher-progress">
                                <div class="teacher-progress-bar" style="width:32%;"></div>
                            </div>
                        </div>
                        <div>
                            <div class="mb-2 flex items-center justify-between text-sm text-[#42493d]">
                                <span>Đối soát thiết bị</span>
                                <span>80%</span>
                            </div>
                            <div class="teacher-progress">
                                <div class="teacher-progress-bar" style="width:80%;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Nhắc việc theo use case</h2>
                    <div class="teacher-list">
                        <article class="teacher-list-item">
                            <p class="text-sm font-semibold text-[#1a1c19]">Buổi Robotics A1 còn thiếu 3 ảnh sản phẩm</p>
                            <p class="mt-1 text-sm text-[#73796b]">Cần upload trước 11:00 để phụ huynh xem trong ngày.</p>
                        </article>
                        <article class="teacher-list-item">
                            <p class="text-sm font-semibold text-[#1a1c19]">Session 04 đã có raw note, chưa sinh AI evaluation</p>
                            <p class="mt-1 text-sm text-[#73796b]">Ưu tiên hoàn tất để gửi đánh giá chuyên nghiệp cho phụ huynh.</p>
                        </article>
                        <article class="teacher-list-item">
                            <p class="text-sm font-semibold text-[#1a1c19]">Laptop LTP-014 chưa xác nhận trả</p>
                            <p class="mt-1 text-sm text-[#73796b]">Kiểm tra lại phiếu mượn trả thiết bị sau buổi chiều.</p>
                        </article>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</section>
