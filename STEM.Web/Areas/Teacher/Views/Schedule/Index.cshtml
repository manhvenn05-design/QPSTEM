@model STEM.Web.Areas.Teacher.Models.TeacherScheduleIndexViewModel

@{
    ViewData["Title"] = "Lịch dạy";
    const int calendarStartHour = 6;
    const int calendarEndHour = 22;
    const int slotMinutes = 30;
    var totalSlots = (calendarEndHour - calendarStartHour) * 60 / slotMinutes;
    var isCalendarView = Model.SelectedView == "calendar";
    var isListView = Model.SelectedView == "list";
}

<section class="teacher-page">
    <div class="teacher-page-header flex-wrap items-center justify-between gap-4">
        <div>
            <h1 class="teacher-page-title">Lịch giảng dạy</h1>
            <p class="teacher-page-subtitle mt-1 flex items-center gap-2">
                <span class="material-symbols-outlined text-[16px] text-[#73796b]">calendar_today</span>
                @(Model.IsCurrentWeek ? "Tuần hiện tại" : "Tuần đang xem") (@Model.WeekLabel)
            </p>
        </div>

        <div class="flex items-center gap-4">
            <div class="flex items-center rounded-lg border border-[#c2c9b9] bg-white shadow-sm">
                <a href="@Url.Action("Index", new { filter = Model.SelectedFilter, q = Model.SearchTerm, date = Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd"), view = Model.SelectedView })"
                   class="flex h-12 w-12 items-center justify-center border-r border-[#c2c9b9] text-[#42493f] transition-colors hover:bg-[#f2f7f0]"
                   aria-label="Tuần trước">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </a>
                <div class="min-w-[150px] px-4 text-center text-sm font-semibold text-[#1a1c19]">
                    @Model.WeekLabel
                </div>
                <a href="@Url.Action("Index", new { filter = Model.SelectedFilter, q = Model.SearchTerm, date = Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd"), view = Model.SelectedView })"
                   class="flex h-12 w-12 items-center justify-center border-l border-[#c2c9b9] text-[#42493f] transition-colors hover:bg-[#f2f7f0]"
                   aria-label="Tuần sau">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </a>
            </div>

            <div class="flex items-center rounded-lg bg-[#e3e3de] p-1">
                <button type="button" id="btn-view-calendar" class="flex items-center gap-2 rounded-md px-3 py-1.5 text-sm transition-colors @(isCalendarView ? "bg-white font-semibold text-[#1a1c19] shadow-sm" : "font-medium text-[#42493f] hover:text-[#1a1c19]")" onclick="toggleScheduleView('calendar')">
                    <span class="material-symbols-outlined text-[18px]">calendar_view_week</span> Lịch
                </button>
                <button type="button" id="btn-view-list" class="flex items-center gap-2 rounded-md px-3 py-1.5 text-sm transition-colors @(isListView ? "bg-white font-semibold text-[#1a1c19] shadow-sm" : "font-medium text-[#42493f] hover:text-[#1a1c19]")" onclick="toggleScheduleView('list')">
                    <span class="material-symbols-outlined text-[18px]">view_agenda</span> Danh sách
                </button>
            </div>
        </div>
    </div>

    <div id="schedule-calendar-view" class="mt-6 @(isCalendarView ? "block" : "hidden")">
        <div class="overflow-x-auto rounded-xl border border-[#c2c9b9] bg-white shadow-sm">
            <div class="min-w-[980px]">
                <div class="grid grid-cols-[74px_repeat(7,_minmax(0,_1fr))] border-b border-[#c2c9b9] bg-[#f8faf7] text-center text-sm">
                    <div class="border-r border-[#c2c9b9] py-3 text-[#73796b]">Giờ</div>

                    @for (int i = 0; i < 7; i++)
                    {
                        var currentDate = Model.WeekStart.AddDays(i);
                        var isToday = currentDate.Date == DateTime.Today;
                        var dayName = i == 6 ? "Chủ nhật" : $"Thứ {i + 2}";
                        var borderClass = i == 6 ? string.Empty : "border-r border-[#e3e3de]";
                        var textClass = isToday ? "text-[#0f2347]" : i == 6 ? "text-[#ba1a1a]" : "text-[#42493f]";
                        var dateClass = isToday ? "text-[#0f2347]" : i == 6 ? "text-[#ba1a1a]" : "text-[#1a1c19]";
                        var bgClass = isToday ? "bg-[#edf7e8]" : string.Empty;

                        <div class="@borderClass @bgClass py-3">
                            <div class="text-[11px] font-bold uppercase tracking-wider @textClass">@dayName</div>
                            <div class="mt-1 text-lg font-bold @dateClass">@currentDate.Day</div>
                            <div class="mt-1 text-[10px] font-medium @(isToday ? "text-[#0f2347]" : "text-transparent")">@(isToday ? "• Hôm nay" : "•")</div>
                        </div>
                    }
                </div>

                <div class="relative">
                    <div class="grid grid-cols-[74px_repeat(7,_minmax(0,_1fr))]" style="grid-template-rows: repeat(@totalSlots, 30px);">
                        @for (int slot = 0; slot < totalSlots; slot++)
                        {
                            var totalMinutes = calendarStartHour * 60 + (slot * slotMinutes);
                            var hour = totalMinutes / 60;
                            var minute = totalMinutes % 60;
                            var isHourLine = minute == 0;
                            <div class="border-r border-b @(isHourLine ? "border-[#d7ddd0]" : "border-[#eef2ea]") bg-[#f8faf7] px-3 pt-1 text-sm @(isHourLine ? "font-medium text-[#5f6759]" : "text-transparent")">
                                @(isHourLine ? $"{hour:00}:00" : string.Empty)
                            </div>

                            for (int day = 0; day < 7; day++)
                            {
                                var isTodayColumn = Model.WeekStart.AddDays(day).Date == DateTime.Today;
                                var borderClass = day == 6 ? string.Empty : "border-r";
                                <div class="@borderClass border-b @(isHourLine ? "border-[#d7ddd0]" : "border-[#eef2ea]") @(isTodayColumn ? "bg-[#fcfdfb]" : "bg-white")"></div>
                            }
                        }
                    </div>

                    <div class="pointer-events-none absolute inset-0 grid grid-cols-[74px_repeat(7,_minmax(0,_1fr))]" style="grid-template-rows: repeat(@totalSlots, 30px);">
                        @foreach (var session in Model.CalendarSessions)
                        {
                            var sessionDate = session.Date.Date;
                            var dayOffset = (sessionDate - Model.WeekStart.Date).Days;
                            if (dayOffset < 0 || dayOffset > 6) { continue; }

                            var startOff = ((session.StartTime.Hour * 60) + session.StartTime.Minute) - (calendarStartHour * 60);
                            var endOff   = ((session.EndTime.Hour   * 60) + session.EndTime.Minute)   - (calendarStartHour * 60);
                            var safeStart = Math.Max(0, startOff);
                            var safeEnd   = Math.Min(totalSlots * slotMinutes, Math.Max(safeStart + slotMinutes, endOff));
                            var rowStart  = (int)Math.Floor(safeStart / (double)slotMinutes) + 1;
                            var rowEnd    = (int)Math.Ceiling(safeEnd  / (double)slotMinutes) + 1;
                            var col       = dayOffset + 2;

                            // ── Màu card theo trạng thái + substitute ──────────────────────
                            string cardStyle, borderColor, timeColor, badgeBg;
                            if (session.IsSubstituteAssignedToMe) {
                                cardStyle   = "background:#f0f7ff;border-left:4px solid #2563eb;";
                                borderColor = "#2563eb";
                                timeColor   = "#1d4ed8";
                                badgeBg     = "background:#dbeafe;color:#1e40af;";
                            } else if (session.IsSubstituteAssignedToOther) {
                                cardStyle   = "background:#faf9fb;border-left:4px solid #9ca3af;opacity:0.80;";
                                borderColor = "#9ca3af";
                                timeColor   = "#6b7280";
                                badgeBg     = "background:#f3f4f6;color:#6b7280;";
                            } else if (session.StatusBadgeClass == "today") {
                                cardStyle   = "background:#f0fdf4;border-left:3px solid #16a34a;";
                                borderColor = "#16a34a";
                                timeColor   = "#15803d";
                                badgeBg     = "background:#dcfce7;color:#15803d;";
                            } else if (session.StatusBadgeClass == "upcoming") {
                                cardStyle   = "background:#fff7ed;border-left:3px solid #ea580c;";
                                borderColor = "#ea580c";
                                timeColor   = "#c2410c";
                                badgeBg     = "background:#ffedd5;color:#c2410c;";
                            } else {
                                cardStyle   = "background:#f5f5f4;border-left:3px solid #a8a29e;";
                                borderColor = "#a8a29e";
                                timeColor   = "#78716c";
                                badgeBg     = "background:#e7e5e4;color:#78716c;";
                            }

                            var dayLabel = session.Date.DayOfWeek switch {
                                DayOfWeek.Monday    => "Thứ Hai",
                                DayOfWeek.Tuesday   => "Thứ Ba",
                                DayOfWeek.Wednesday => "Thứ Tư",
                                DayOfWeek.Thursday  => "Thứ Năm",
                                DayOfWeek.Friday    => "Thứ Sáu",
                                DayOfWeek.Saturday  => "Thứ Bảy",
                                _                   => "Chủ Nhật"
                            };
                            var attLabel = session.StatusBadgeClass == "past"
                                ? (session.AttendanceCount > 0 ? $"Điểm danh: {session.AttendancePercent}% có mặt" : "Chưa điểm danh")
                                : (session.StatusBadgeClass == "today" ? "Chưa điểm danh" : "—");

                            <button type="button"
                                    class="popup-trigger pointer-events-auto z-10 mx-0.5 my-[2px] flex min-h-0 w-full flex-col overflow-hidden rounded-md text-left shadow-sm hover:shadow-md transition-shadow"
                                    style="grid-column: @col; grid-row: @rowStart / @rowEnd; @cardStyle"
                                    data-session-id="@session.SessionId"
                                    data-day-label="@dayLabel, @session.Date.ToString("dd/MM/yyyy")"
                                    data-course="@session.CourseName"
                                    data-class="@session.ClassCode"
                                    data-session-label="@session.SessionLabel"
                                    data-time="@session.ScheduleText"
                                    data-teacher="@session.TeacherName"
                                    data-room="@(session.RoomName ?? "Chưa xếp phòng")"
                                    data-topic="@session.Topic"
                                    data-students="@session.StudentCount"
                                    data-status="@session.StatusLabel"
                                    data-badge-bg="@badgeBg"
                                    data-att-label="@attLabel"
                                    data-detail-url="@Url.Action("Details", "Schedule", new { area = "Teacher", id = session.SessionId })">
                                <div class="flex min-h-0 flex-1 flex-col overflow-hidden px-2 py-1.5">
                                    @if (session.IsSubstituteAssignedToMe) {
                                        <div class="mb-0.5 truncate text-[10px] font-semibold tracking-wide" style="color:#2563eb;">Dạy thay</div>
                                    } else if (session.IsSubstituteAssignedToOther) {
                                        <div class="mb-0.5 truncate text-[10px] font-medium" style="color:#9ca3af;">Đã giao dạy thay</div>
                                    }
                                    <div class="truncate text-[11px] font-bold leading-tight" style="color:@timeColor">@session.ScheduleText</div>
                                    <div class="truncate text-[12px] font-semibold leading-snug mt-0.5" style="color:@(session.IsSubstituteAssignedToOther ? "#6b7280" : "#1c1c1e")">
                                        @session.CourseName
                                    </div>
                                    <div class="truncate text-[10px] leading-tight mt-0.5" style="color:@(session.IsSubstituteAssignedToOther ? "#9ca3af" : "#78716c")">
                                        Lớp @session.ClassCode &middot; @session.Topic
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(session.RoomName)) {
                                        <div class="mt-0.5 flex items-center gap-0.5 truncate text-[10px]" style="color:@borderColor">
                                            <span class="material-symbols-outlined text-[10px]">meeting_room</span>
                                            @session.RoomName
                                        </div>
                                    }
                                </div>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 flex items-center justify-between text-sm text-[#42493f]">
            <div class="flex items-center gap-4 text-xs">
                <div class="flex items-center gap-1.5"><div class="h-3 w-3 rounded" style="background:#16a34a"></div> Hôm nay</div>
                <div class="flex items-center gap-1.5"><div class="h-3 w-3 rounded" style="background:#ea580c"></div> Sắp tới</div>
                <div class="flex items-center gap-1.5"><div class="h-3 w-3 rounded bg-[#a8a29e]"></div> Đã dạy</div>
            </div>
            <div class="flex items-center gap-2 rounded-lg bg-[#e8f0e5] px-4 py-2 font-medium text-[#2d4f19]">
                <span class="material-symbols-outlined text-[18px]">info</span>
                Tổng số ca dạy tuần này: @Model.CalendarSessions.Count ca
            </div>
        </div>
    </div>

    @* Session Popup Modal *@
    <div id="session-popup-overlay" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 p-4" onclick="closeSessionPopup(event)">
        <div id="session-popup" class="relative w-full max-w-lg rounded-2xl bg-white shadow-2xl" onclick="event.stopPropagation()">
            <div class="border-b border-[#e5e7eb] px-6 pt-6 pb-4">
                <p id="popup-day" class="text-lg font-bold text-[#1c1c1e]"></p>
                <p id="popup-count" class="mt-0.5 text-sm text-[#6b7280]"></p>
            </div>
            <div id="popup-card" class="m-4 rounded-xl border p-4">
                <div class="flex flex-wrap items-start justify-between gap-2">
                    <div>
                        <p class="text-base font-bold text-[#1c1c1e]" id="popup-course"></p>
                        <p class="mt-0.5 text-sm text-[#6b7280]" id="popup-subtitle"></p>
                    </div>
                    <div class="flex items-center gap-2">
                        <span id="popup-status-badge" class="rounded-full px-3 py-1 text-xs font-semibold"></span>
                        <span id="popup-att-badge" class="rounded-full bg-[#f3f4f6] px-3 py-1 text-xs text-[#6b7280]"></span>
                    </div>
                </div>
                <div class="mt-4 grid grid-cols-3 gap-4">
                    <div>
                        <p class="text-xs text-[#9ca3af]">Giờ học</p>
                        <p class="mt-1 text-base font-bold text-[#1c1c1e]" id="popup-time"></p>
                    </div>
                    <div>
                        <p class="text-xs text-[#9ca3af]">Giáo viên</p>
                        <p class="mt-1 text-sm font-semibold text-[#1c1c1e]" id="popup-teacher"></p>
                    </div>
                    <div>
                        <p class="text-xs text-[#9ca3af]">Phòng học</p>
                        <p class="mt-1 text-sm font-semibold text-[#1c1c1e]" id="popup-room"></p>
                    </div>
                </div>
                <div class="mt-4">
                    <p class="text-xs text-[#9ca3af]">Học phần / nội dung học</p>
                    <p class="mt-1 text-sm font-semibold text-[#1c1c1e]" id="popup-topic"></p>
                </div>
            </div>
            <div class="flex justify-end gap-3 px-6 pb-5">
                <button onclick="closeSessionPopup()" class="rounded-lg border border-[#d1d5db] px-4 py-2 text-sm text-[#374151] hover:bg-[#f9fafb] transition-colors">Đóng</button>
                <a id="popup-detail-link" href="#" class="rounded-lg bg-[#1a3a6e] px-4 py-2 text-sm font-semibold text-white hover:bg-[#15306a] transition-colors">Xem chi tiết →</a>
            </div>
            <button onclick="closeSessionPopup()" class="absolute right-4 top-4 rounded-full p-1 text-[#9ca3af] hover:bg-[#f3f4f6] hover:text-[#374151] transition-colors">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
    </div>

    <div id="schedule-list-view" class="mt-6 @(isListView ? "block" : "hidden")">
        <div class="teacher-card">
            <div class="teacher-card-section">
                <div class="teacher-toolbar">
                    <div class="teacher-filter-list">
                        @foreach (var filter in Model.Filters)
                        {
                            <a asp-area="Teacher"
                               asp-controller="Schedule"
                               asp-action="Index"
                               asp-route-filter="@filter.Key"
                               asp-route-q="@Model.SearchTerm"
                               asp-route-date="@Model.TargetDate.ToString("yyyy-MM-dd")"
                               asp-route-view="@Model.SelectedView"
                               class="@(Model.SelectedFilter == filter.Key ? "teacher-filter is-active" : "teacher-filter")">
                                @filter.Label
                            </a>
                        }
                    </div>

                    <form method="get" class="teacher-search-form">
                        <input type="hidden" name="filter" value="@Model.SelectedFilter" />
                        <input type="hidden" name="date" value="@Model.TargetDate.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="view" value="@Model.SelectedView" />
                        <label class="sr-only" for="teacher-schedule-search">Tìm buổi học</label>
                        <div class="teacher-search-box">
                            <span class="material-symbols-outlined text-[20px] text-[#73796b]">search</span>
                            <input id="teacher-schedule-search"
                                   name="q"
                                   value="@Model.SearchTerm"
                                   type="search"
                                   placeholder="Tìm theo lớp, khóa học hoặc chủ đề" />
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="teacher-list">
            @if (Model.Sessions.Count == 0)
            {
                <div class="teacher-card">
                    <div class="teacher-card-section">
                        <p class="teacher-empty">Chưa có buổi học nào phù hợp với bộ lọc này.</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var session in Model.Sessions)
                {
                    <article class="teacher-card">
                        <div class="teacher-card-section">
                            <div class="teacher-session-card">
                                <div class="teacher-session-main">
                                    <div class="flex flex-wrap items-center gap-3">
                                        <span class="@session.StatusBadgeClass">@session.StatusLabel</span>
                                        <span class="teacher-tag teacher-tag--neutral">@session.SessionLabel</span>
                                        @if (session.HasTeachingMaterial)
                                        {
                                            <span class="teacher-tag teacher-tag--success">Có giáo án</span>
                                        }
                                        @if(session.IsSubstituteAssignedToMe)
                                        {
                                            <span class="teacher-tag !text-[#1e40af] !bg-[#dbeafe]">Dạy thay</span>
                                        }
                                        @if(session.IsSubstituteAssignedToOther)
                                        {
                                            <span class="teacher-tag !text-[#6b7280] !bg-[#f3f4f6]">Đã giao dạy thay</span>
                                        }
                                    </div>
                                    <h2 class="teacher-section-title mt-4">@session.ClassCode · @session.CourseName</h2>
                                    <p class="teacher-section-subtitle mt-1">@session.Topic</p>
                                    <div class="teacher-meta-row mt-4">
                                        <span>@session.ScheduleText</span>
                                        <span>@session.StudentCount học viên</span>
                                        <span>@session.AttendanceCount đã ghi nhận</span>
                                    </div>
                                    <p class="teacher-kicker mt-3">Tiến độ điểm danh: @session.AttendancePercent%</p>
                                </div>

                                <div class="teacher-session-side !min-w-[280px]">
                                    <div class="teacher-inline-list w-full justify-end">
                                        @if (session.HasTeachingMaterial)
                                        {
                                            <a asp-area="Teacher" asp-controller="Schedule" asp-action="Viewer" asp-route-id="@session.SessionId" class="teacher-btn-secondary text-[#f97316] border-[#f97316] hover:bg-[#fff7ed]">Trình chiếu</a>
                                        }
                                        <a asp-area="Teacher" asp-controller="Schedule" asp-action="Details" asp-route-id="@session.SessionId" class="teacher-btn-secondary">Chi tiết</a>
                                        <a asp-area="Teacher" asp-controller="Attendances" asp-action="Board" asp-route-sessionId="@session.SessionId" class="teacher-btn-primary">Điểm danh</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </article>
                }
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function toggleScheduleView(viewType) {
            const url = new URL(window.location.href);
            url.searchParams.set('view', viewType);
            window.location.href = url.toString();
        }

        function applyScheduleViewState(viewType) {
            const calendarView = document.getElementById('schedule-calendar-view');
            const listView = document.getElementById('schedule-list-view');
            const btnCalendar = document.getElementById('btn-view-calendar');
            const btnList = document.getElementById('btn-view-list');

            if (viewType === 'calendar') {
                calendarView.classList.remove('hidden');
                calendarView.classList.add('block');
                listView.classList.remove('block');
                listView.classList.add('hidden');
                btnCalendar.classList.add('bg-white', 'shadow-sm', 'text-[#1a1c19]');
                btnCalendar.classList.add('font-semibold');
                btnCalendar.classList.remove('text-[#42493f]');
                btnList.classList.remove('bg-white', 'shadow-sm', 'text-[#1a1c19]');
                btnList.classList.remove('font-semibold');
                btnList.classList.add('text-[#42493f]');
            } else {
                listView.classList.remove('hidden');
                listView.classList.add('block');
                calendarView.classList.remove('block');
                calendarView.classList.add('hidden');
                btnList.classList.add('bg-white', 'shadow-sm', 'text-[#1a1c19]');
                btnList.classList.add('font-semibold');
                btnList.classList.remove('text-[#42493f]');
                btnCalendar.classList.remove('bg-white', 'shadow-sm', 'text-[#1a1c19]');
                btnCalendar.classList.remove('font-semibold');
                btnCalendar.classList.add('text-[#42493f]');
            }
        }

        applyScheduleViewState('@Model.SelectedView');

        // ── Popup logic ──────────────────────────────────────────
        document.querySelectorAll('.popup-trigger').forEach(btn => {
            btn.addEventListener('click', () => {
                const d = btn.dataset;

                document.getElementById('popup-day').textContent      = d.dayLabel;
                document.getElementById('popup-count').textContent    = '1 học phần / buổi học trong ngày này';
                document.getElementById('popup-course').textContent   = d.course;
                document.getElementById('popup-subtitle').textContent = `Lớp ${d.class} · ${d.sessionLabel}`;
                document.getElementById('popup-time').textContent     = d.time;
                document.getElementById('popup-teacher').textContent  = d.teacher || '—';
                document.getElementById('popup-room').textContent     = d.room || '—';
                document.getElementById('popup-topic').textContent    = d.topic;

                const badge = document.getElementById('popup-status-badge');
                badge.textContent = d.status;
                badge.style.cssText = d.badgeBg;

                document.getElementById('popup-att-badge').textContent = d.attLabel;
                document.getElementById('popup-detail-link').href     = d.detailUrl;

                // Border color của card trong popup
                const card = document.getElementById('popup-card');
                const status = d.status;
                if (status === 'Hôm nay') {
                    card.style.borderColor = '#16a34a';
                } else if (status === 'Sắp tới') {
                    card.style.borderColor = '#ea580c';
                } else {
                    card.style.borderColor = '#d1d5db';
                }

                const overlay = document.getElementById('session-popup-overlay');
                overlay.classList.remove('hidden');
                overlay.classList.add('flex');
            });
        });

        function closeSessionPopup(e) {
            if (e && e.target !== document.getElementById('session-popup-overlay')) return;
            const overlay = document.getElementById('session-popup-overlay');
            overlay.classList.add('hidden');
            overlay.classList.remove('flex');
        }
        // ESC để đóng
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') closeSessionPopup();
        });
        window.closeSessionPopup = closeSessionPopup;
    </script>
}
