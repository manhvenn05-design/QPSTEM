@model STEM.Web.Areas.Teacher.Models.TeacherScheduleDetailsViewModel

@{
    ViewData["Title"] = "Lịch dạy";
}

<section class="teacher-page">
    <div class="teacher-page-header">
        <div>
            <h1 class="teacher-page-title">@Model.SessionLabel · @Model.ClassCode</h1>
            <p class="teacher-page-subtitle">@Model.CourseName · @Model.DateText · @Model.TimeRangeText</p>
        </div>

        <div class="teacher-actions">
            @if (!Model.IsSubstituteAssignedToOther)
            {
                @if (!string.IsNullOrWhiteSpace(Model.TeachingMaterialUrl))
                {
                    <a asp-area="Teacher" asp-controller="Schedule" asp-action="Viewer" asp-route-id="@Model.SessionId" class="teacher-btn-secondary !text-[#f97316] !border-[#f97316] hover:!bg-[#fff7ed]">
                        <span class="material-symbols-outlined text-[18px]">smart_display</span>
                        <span>Trình chiếu</span>
                    </a>
                }
                <a asp-area="Teacher" asp-controller="Attendances" asp-action="Board" asp-route-sessionId="@Model.SessionId" class="teacher-btn-primary">
                    <span class="material-symbols-outlined text-[18px]">fact_check</span>
                    <span>Điểm danh</span>
                </a>
            }
        </div>
    </div>

    <div class="teacher-panel-grid">
        <div class="teacher-stack">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Thông tin buổi học</h2>
                    <div class="teacher-info-grid teacher-info-grid--2 mt-6">
                        <dl class="teacher-key-value">
                            <dt>Chủ đề</dt>
                            <dd>@Model.Topic</dd>
                        </dl>
                        <dl class="teacher-key-value">
                            <dt>Giáo viên</dt>
                            <dd>@Model.TeacherName</dd>
                        </dl>
                        <dl class="teacher-key-value">
                            <dt>Sĩ số</dt>
                            <dd>@Model.StudentCount học viên</dd>
                        </dl>
                        <dl class="teacher-key-value">
                            <dt>Đã điểm danh</dt>
                            <dd>@Model.AttendanceCount học viên</dd>
                        </dl>
                    </div>

                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Cập nhật sau buổi học</h2>
                    <p class="teacher-section-subtitle mt-1">Lưu lại hình ảnh/video của lớp và ghi chú về buổi học, trợ giảng.</p>
                    
                    @if (Model.IsSubstituteAssignedToOther)
                    {
                        <div class="mt-4 p-4 bg-[#fff7ed] border border-[#ffedd5] rounded-lg text-[#c2410c] text-sm font-medium">
                            Buổi học này đã được giao cho giáo viên khác dạy thay. Chỉ người dạy thay mới có quyền cập nhật nhận xét và tải media lên.
                        </div>
                    }
                    else
                    {
                        <form asp-area="Teacher" asp-controller="Schedule" asp-action="UpdateNotes" method="post" enctype="multipart/form-data" class="mt-6">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="SessionId" value="@Model.SessionId" />
                            
                            <div class="space-y-5">
                                <div class="rounded-2xl border border-[#dfe7da] bg-[#f8fbf7] p-4 md:p-5">
                                    <div class="flex items-start gap-3">
                                        <div class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-white text-[#456c3f] ring-1 ring-[#dfe7da]">
                                            <span class="material-symbols-outlined text-[24px]">upload_file</span>
                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <p class="text-sm font-semibold text-[#1a1c19]">Chọn ảnh/video từ Explorer</p>
                                            <p class="mt-1 text-sm text-[#5f6b57]">Media tải lên sẽ được lưu vào kho nội bộ của hệ thống và tự đi kèm phần minh chứng của học sinh trong buổi này.</p>
                                        </div>
                                    </div>

                                    <div class="mt-4">
                                        <label for="ClassMediaFiles" class="group flex cursor-pointer items-center justify-between gap-4 rounded-2xl border border-dashed border-[#a8c89a] bg-white px-4 py-4 transition-colors hover:border-[#6aa84f] hover:bg-[#f4faef]">
                                            <div class="flex items-center gap-3">
                                                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#edf7e8] text-[#456c3f]">
                                                    <span class="material-symbols-outlined text-[24px]">add_photo_alternate</span>
                                                </div>
                                                <div>
                                                    <p class="text-sm font-semibold text-[#1a1c19]">Chọn file từ máy</p>
                                                    <p class="mt-1 text-xs text-[#6b7a63]">Có thể chọn nhiều ảnh/video cùng lúc</p>
                                                </div>
                                            </div>
                                            <span class="inline-flex items-center rounded-full bg-[#0f2347] px-3 py-1.5 text-xs font-semibold text-white group-hover:bg-[#1c3b73]">
                                                Browse files
                                            </span>
                                        </label>
                                        <input id="ClassMediaFiles" name="ClassMediaFiles" type="file" multiple accept=".jpg,.jpeg,.png,.webp,.mp4,.webm,.mov,image/*,video/*" class="sr-only" />
                                        <div id="selected-media-files" class="mt-3 hidden rounded-xl border border-[#dfe7da] bg-white p-3">
                                            <p class="text-xs font-semibold uppercase tracking-wide text-[#6b7a63]">File đã chọn</p>
                                            <div id="selected-media-files-list" class="mt-2 flex flex-wrap gap-2"></div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div>
                                    <label for="ClassMediaUrls" class="block text-sm font-medium text-[#1a1c19] mb-1">Media cả lớp</label>
                                    <textarea id="ClassMediaUrls" name="ClassMediaUrls" class="w-full rounded-md border border-[#c2c9b9] bg-white px-3 py-2 text-sm text-[#1a1c19] outline-none transition-colors focus:border-[#f97316] focus:ring-1 focus:ring-[#f97316]" rows="3" placeholder="Dán URL ảnh hoặc video của học sinh/lớp học...">@Model.ClassMediaUrls</textarea>
                                </div>
                                
                                <div>
                                    <label for="AssistantNote" class="block text-sm font-medium text-[#1a1c19] mb-1">Ghi chú trợ giảng (Nếu có)</label>
                                    <textarea id="AssistantNote" name="AssistantNote" class="w-full rounded-md border border-[#c2c9b9] bg-white px-3 py-2 text-sm text-[#1a1c19] outline-none transition-colors focus:border-[#f97316] focus:ring-1 focus:ring-[#f97316]" rows="3" placeholder="Nhận xét trợ giảng, ghi chú lưu ý buổi học...">@Model.AssistantNote</textarea>
                                </div>
                            </div>
                            
                         

                            <div class="mt-4 flex justify-end">
                                <button type="submit" class="teacher-btn-primary">
                                    <span class="material-symbols-outlined text-[18px]">save</span>
                                    <span>Lưu cập nhật</span>
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Danh sách học viên</h2>

                    <div class="teacher-list mt-6">
                        @foreach (var student in Model.Students)
                        {
                            <article class="teacher-data-row">
                                <div>
                                    <p class="text-sm font-semibold text-[#1a1c19]">@student.FullName</p>
                                    <p class="teacher-section-subtitle mt-1">@student.Username</p>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="teacher-stack">
            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Thiết bị</h2>

                    <div class="teacher-list mt-6">
                        @if (Model.Equipments.Count == 0)
                        {
                            <p class="teacher-empty">Buổi này chưa có phiếu mượn thiết bị.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.Equipments)
                            {
                                <article class="teacher-data-row">
                                    <div>
                                        <p class="text-sm font-semibold text-[#1a1c19]">@item.SerialNumber</p>
                                        <p class="teacher-section-subtitle mt-1">@item.BorrowerName</p>
                                        <div class="teacher-meta-row mt-3">
                                            <span>@item.BorrowTimeText</span>
                                            <span>@item.ReturnTimeText</span>
                                        </div>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="teacher-card">
                <div class="teacher-card-section">
                    <h2 class="teacher-section-title">Thao tác</h2>
                    <div class="teacher-stack mt-6">
                        @if (!Model.IsSubstituteAssignedToOther)
                        {
                            <a asp-area="Teacher" asp-controller="Attendances" asp-action="Board" asp-route-sessionId="@Model.SessionId" class="teacher-btn-primary w-full">Mở sổ điểm danh</a>
                            <a asp-area="Teacher" asp-controller="Equipment" asp-action="Borrow" asp-route-sessionId="@Model.SessionId" class="teacher-btn-secondary w-full">Mượn thiết bị</a>
                        }
                        <a asp-area="Teacher" asp-controller="Schedule" asp-action="Index" class="teacher-btn-secondary w-full">Quay lại lịch dạy</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const fileInput = document.getElementById("ClassMediaFiles");
            const filePanel = document.getElementById("selected-media-files");
            const fileList = document.getElementById("selected-media-files-list");
            const mediaTextarea = document.getElementById("ClassMediaUrls");

            if (!fileInput || !filePanel || !fileList) {
                return;
            }

            if (mediaTextarea) {
                const mediaBlock = mediaTextarea.closest("div");
                const previousHint = mediaBlock?.previousElementSibling;
                if (mediaBlock && previousHint && previousHint.tagName === "P") {
                    previousHint.textContent = "Vẫn giữ ô URL này để dùng khi media nằm ở nguồn ngoài hoặc khi bạn cần dán link thủ công.";
                    previousHint.className = "mt-1 text-xs text-[#73796b]";
                    mediaBlock.appendChild(previousHint);
                }
            }

            fileInput.addEventListener("change", () => {
                const files = Array.from(fileInput.files || []);
                fileList.innerHTML = "";

                if (files.length === 0) {
                    filePanel.classList.add("hidden");
                    return;
                }

                filePanel.classList.remove("hidden");

                for (const file of files) {
                    const item = document.createElement("span");
                    item.className = "inline-flex items-center gap-2 rounded-full bg-[#edf7e8] px-3 py-1.5 text-xs font-medium text-[#2f5e2a]";
                    const sizeMb = (file.size / 1024 / 1024).toFixed(1);
                    item.textContent = `${file.name} (${sizeMb} MB)`;
                    fileList.appendChild(item);
                }
            });
        })();
    </script>
}
