@{
    ViewData["Title"] = "Lớp học";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Quản lý lớp học</h1>
            <p class="admin-page-subtitle">Giao diện quản lý bám theo schema <code>Classes</code>: khóa học, giáo viên, mã lớp, ngày bắt đầu và ngày kết thúc.</p>
        </div>

        <div class="admin-actions">
            <button type="button" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">add</span>
                <span>Thêm lớp học</span>
            </button>
        </div>
    </div>

    <div class="admin-card">
        <div class="admin-card-section">
            <div class="admin-toolbar">
                <div class="admin-chip-group">
                    <button type="button" class="admin-chip is-active">Tất cả</button>
                    <button type="button" class="admin-chip">Đang mở</button>
                    <button type="button" class="admin-chip">Sắp khai giảng</button>
                    <button type="button" class="admin-chip">Đã kết thúc</button>
                </div>

                <div class="flex w-full flex-col gap-3 lg:w-auto lg:flex-row">
                    <label class="relative block w-full lg:w-80">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-[20px] text-[#73796b]">search</span>
                        <input type="text" placeholder="Tìm theo mã lớp hoặc giáo viên..." class="admin-input pl-12" />
                    </label>
                    <button type="button" class="admin-btn-secondary">
                        <span class="material-symbols-outlined text-[18px]">tune</span>
                        <span>Lọc nâng cao</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="admin-grid-two">
        <div class="admin-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="admin-table min-w-full">
                    <thead>
                        <tr>
                            <th>Mã lớp</th>
                            <th>Khóa học</th>
                            <th>Giáo viên</th>
                            <th>Thời gian</th>
                            <th>Học viên</th>
                            <th class="text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>RBX-2405-A</strong></td>
                            <td>Robotics Explorer</td>
                            <td>Nguyễn Minh Khoa</td>
                            <td>12/05/2026 - 05/07/2026</td>
                            <td>18 học viên</td>
                            <td class="text-right"><button type="button" class="admin-btn-secondary !h-10">Xem</button></td>
                        </tr>
                        <tr>
                            <td><strong>SCR-2405-B</strong></td>
                            <td>Scratch Creative Lab</td>
                            <td>Trần Thu Hà</td>
                            <td>20/05/2026 - Đang mở</td>
                            <td>24 học viên</td>
                            <td class="text-right"><button type="button" class="admin-btn-secondary !h-10">Xem</button></td>
                        </tr>
                        <tr>
                            <td><strong>AIJ-2406-C</strong></td>
                            <td>AI Junior Builder</td>
                            <td>Lê Hoàng Việt</td>
                            <td>01/06/2026 - 10/08/2026</td>
                            <td>12 học viên</td>
                            <td class="text-right"><button type="button" class="admin-btn-secondary !h-10">Xem</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <aside class="space-y-6">
            <div class="admin-card">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Ghi chú dữ liệu</h2>
                    <ul class="admin-note-list mt-4">
                        <li><code>CourseId</code> lấy từ danh sách khóa học hiện có.</li>
                        <li><code>TeacherId</code> chỉ chọn người dùng có vai trò giáo viên.</li>
                        <li><code>ClassCode</code> là mã lớp duy nhất theo ràng buộc DB.</li>
                        <li><code>StartDate</code> và <code>EndDate</code> giữ đúng kiểu ngày của bảng <code>Classes</code>.</li>
                    </ul>
                </div>
            </div>
        </aside>
    </div>
</section>
