@model STEM.Web.Areas.Admin.Models.ClassManagementViewModel

@{
    ViewData["Title"] = "Lớp học";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Lớp học</h1>
            <p class="admin-page-subtitle">Theo dõi lớp, giáo viên và lịch học.</p>
        </div>

        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Classes" asp-action="Create" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">add</span>
                <span>Thêm lớp</span>
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="admin-alert admin-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="admin-alert admin-alert--error">@errorMessage</div>
    }

    <form method="get" asp-area="Admin" asp-controller="Classes" asp-action="Index" class="admin-card">
        <div class="admin-card-section">
            <div class="admin-toolbar">
                <div class="admin-chip-group">
                    @foreach (var filter in Model.Filters)
                    {
                        var isActive = filter.Key == Model.SelectedFilter;
                        <a asp-area="Admin"
                           asp-controller="Classes"
                           asp-action="Index"
                           asp-route-filter="@filter.Key"
                           asp-route-q="@Model.SearchTerm"
                           class="@(isActive ? "admin-chip is-active" : "admin-chip")">
                            @filter.Label
                        </a>
                    }
                </div>

                <div class="w-full lg:max-w-sm">
                    <input type="hidden" name="filter" value="@Model.SelectedFilter" />
                    <label class="relative block">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-[20px] text-[#73796b]">search</span>
                        <input type="text" name="q" value="@Model.SearchTerm" placeholder="Tìm mã lớp, khóa học, giáo viên..." class="admin-input pl-12" />
                    </label>
                </div>
            </div>
        </div>
    </form>

    <div class="admin-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="admin-table min-w-full">
                <thead>
                    <tr>
                        <th>Lớp</th>
                        <th>Khóa học</th>
                        <th>Giáo viên</th>
                        <th>Thời gian</th>
                        <th>Học viên / Buổi</th>
                        <th>Trạng thái</th>
                        <th class="text-right">Mở</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Classes.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="admin-empty">Không có lớp học phù hợp.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Classes)
                        {
                            <tr>
                                <td>
                                    <p class="font-semibold text-[#1a1c19]">@item.ClassCode</p>
                                </td>
                                <td>
                                    <div>
                                        <p class="font-semibold text-[#1a1c19]">@item.CourseName</p>
                                        <p class="mt-1 text-sm text-[#73796b]">@item.CourseCode</p>
                                    </div>
                                </td>
                                <td><strong>@item.TeacherName</strong></td>
                                <td>@item.ScheduleText</td>
                                <td>@item.EnrollmentText</td>
                                <td>
                                    <span class="inline-flex items-center gap-2 rounded-full px-3 py-2 text-xs font-semibold @item.StatusBadgeClass">
                                        <span class="h-2 w-2 rounded-full @(item.StatusLabel == "Đang mở" ? "bg-[#456c3f]" : item.StatusLabel == "Tạm dừng" ? "bg-[#9b682f]" : item.StatusLabel == "Đã hủy" ? "bg-[#b33a3a]" : "bg-[#42493d]")"></span>
                                        @item.StatusLabel
                                    </span>
                                </td>
                                <td>
                                    <div class="flex justify-end">
                                        <details class="relative" data-table-action>
                                            <summary class="admin-menu-button cursor-pointer list-none">
                                                <span class="material-symbols-outlined text-[18px]">more_horiz</span>
                                            </summary>
                                            <div data-table-menu class="hidden">
                                                <a asp-area="Admin" asp-controller="Classes" asp-action="Details" asp-route-id="@item.Id" class="admin-menu-item">
                                                    <span class="material-symbols-outlined text-[18px]">visibility</span>
                                                    <span>Chi tiết</span>
                                                </a>
                                                <a asp-area="Admin" asp-controller="Classes" asp-action="Edit" asp-route-id="@item.Id" class="admin-menu-item">
                                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                                    <span>Cập nhật</span>
                                                </a>
                                                <form asp-area="Admin" asp-controller="Classes" asp-action="Delete" asp-route-id="@item.Id" method="post" data-confirm-title="Xóa lớp học" data-confirm-message="Xóa lớp học này? Nếu có dữ liệu liên quan thì dùng 'Xóa toàn bộ dữ liệu'." data-confirm-submit-text="Xóa lớp học">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="admin-menu-item admin-menu-item--danger w-full text-left">
                                                        <span class="material-symbols-outlined text-[18px]">delete</span>
                                                        <span>Xóa</span>
                                                    </button>
                                                </form>
                                                <button type="button"
                                                        class="admin-menu-item admin-menu-item--danger w-full text-left"
                                                        data-purge-id="@item.Id"
                                                        data-purge-name="@item.ClassCode"
                                                        data-purge-code="@item.ClassCode">
                                                    <span class="material-symbols-outlined text-[18px]">delete_forever</span>
                                                    <span>Xóa toàn bộ dữ liệu</span>
                                                </button>
                                            </div>
                                        </details>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-divider flex flex-col gap-4 px-6 py-5 text-sm text-[#73796b] lg:flex-row lg:items-center lg:justify-between">
            <p>Hiển thị @((Model.TotalClasses == 0 ? 0 : ((Model.CurrentPage - 1) * 10) + 1))-@Math.Min(Model.CurrentPage * 10, Model.TotalClasses) / @Model.TotalClasses lớp học</p>

            <div class="admin-pagination">
                <a asp-area="Admin"
                   asp-controller="Classes"
                   asp-action="Index"
                   asp-route-filter="@Model.SelectedFilter"
                   asp-route-q="@Model.SearchTerm"
                   asp-route-page="@(Math.Max(1, Model.CurrentPage - 1))"
                   class="admin-page-link @(Model.CurrentPage == 1 ? "is-disabled" : string.Empty)">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </a>
                <span class="admin-page-link is-active">@Model.CurrentPage</span>
                <a asp-area="Admin"
                   asp-controller="Classes"
                   asp-action="Index"
                   asp-route-filter="@Model.SelectedFilter"
                   asp-route-q="@Model.SearchTerm"
                   asp-route-page="@(Math.Min(Model.TotalPages, Model.CurrentPage + 1))"
                   class="admin-page-link @(Model.CurrentPage == Model.TotalPages ? "is-disabled" : string.Empty)">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </a>
            </div>
        </div>
    </div>
</section>

@* Modal xác nhận Xóa toàn bộ dữ liệu lớp học *@
<div id="purge-modal" class="admin-modal fixed inset-0 z-[100] hidden items-center justify-center px-4">
    <div class="admin-modal-panel w-full max-w-md p-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="admin-section-title text-[#b54740]">Xóa toàn bộ dữ liệu lớp</h2>
                <p id="purge-desc" class="admin-section-subtitle !mt-2"></p>
            </div>
            <button id="purge-close" type="button" class="admin-btn-secondary !h-10 !w-10 !px-0">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
        </div>

        <div class="mt-4 rounded-[8px] bg-[#fff4f3] border border-[#f0c9c7] p-4 text-sm text-[#b54740]">
            ⚠️ Hành động này sẽ xóa <strong>toàn bộ</strong>: điểm danh, buổi học, thanh toán, hóa đơn, đăng ký và lớp học. Không thể hoàn tác.
        </div>

        <div class="mt-4">
            <label class="text-sm font-medium text-[#42493d]">Nhập mã lớp để xác nhận:</label>
            <input id="purge-confirm-input" type="text" placeholder="Ví dụ: PYTHON-K2" autocomplete="off"
                   class="admin-input mt-2 w-full" />
        </div>

        <form id="purge-form" asp-area="Admin" asp-controller="Classes" asp-action="Purge" method="post" class="mt-6 flex justify-end gap-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="purge-class-id" />
            <input type="hidden" name="confirmCode" id="purge-confirm-code" />
            <button type="button" id="purge-cancel" class="admin-btn-secondary">Hủy</button>
            <button type="submit" id="purge-submit" class="admin-btn-danger" disabled>Xóa toàn bộ</button>
        </form>
    </div>
</div>

@section Scripts {
<script>
    (() => {
        const modal       = document.getElementById('purge-modal');
        const desc        = document.getElementById('purge-desc');
        const input       = document.getElementById('purge-confirm-input');
        const classId     = document.getElementById('purge-class-id');
        const codeHidden  = document.getElementById('purge-confirm-code');
        const submit      = document.getElementById('purge-submit');

        let expectedCode = '';

        function openPurge(id, name, code) {
            expectedCode   = code;
            classId.value  = id;
            desc.textContent = `Bạn đang chuẩn bị xóa toàn bộ dữ liệu của lớp "${name}".`;
            input.value    = '';
            submit.disabled = true;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => input.focus(), 100);
        }

        function closePurge() {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        document.addEventListener('click', e => {
            const btn = e.target.closest('[data-purge-id]');
            if (!btn) return;
            openPurge(btn.dataset.purgeId, btn.dataset.purgeName, btn.dataset.purgeCode);
        });

        document.getElementById('purge-close').addEventListener('click', closePurge);
        document.getElementById('purge-cancel').addEventListener('click', closePurge);
        modal.addEventListener('click', e => { if (e.target === modal) closePurge(); });

        input.addEventListener('input', () => {
            const match = input.value.trim().toUpperCase() === expectedCode.toUpperCase();
            submit.disabled = !match;
            if (match) codeHidden.value = input.value.trim();
        });

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape' && !modal.classList.contains('hidden')) closePurge();
        });
    })();
</script>
}
