@model STEM.Web.Areas.Admin.Models.CreateEquipmentCategoryViewModel

@{
    ViewData["Title"] = "Thêm danh mục";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Thêm danh mục thiết bị</h1>
            <p class="admin-page-subtitle">Nhập tên nhóm thiết bị để bắt đầu quản lý kho.</p>
        </div>
        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-btn-secondary">Quay lại danh sách</a>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Inventory" asp-action="CreateCategory" method="post" class="admin-page">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="admin-alert admin-alert--error"></div>

        <div class="admin-card">
            <div class="admin-card-section">
                <label asp-for="Name" class="admin-label"></label>
                <input asp-for="Name" class="admin-input" placeholder="Ví dụ: Robot Kit" />
                <span asp-validation-for="Name" class="admin-validation"></span>
            </div>
        </div>

        <div class="admin-actions justify-end">
            <button type="submit" class="admin-btn-primary min-w-[192px]">Lưu danh mục</button>
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-btn-secondary">Hủy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
