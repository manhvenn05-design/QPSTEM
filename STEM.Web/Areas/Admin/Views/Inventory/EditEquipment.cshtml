@model STEM.Web.Areas.Admin.Models.EditEquipmentViewModel

@{
    ViewData["Title"] = "Cập nhật thiết bị";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Cập nhật thiết bị</h1>
            <p class="admin-page-subtitle">Điều chỉnh danh mục, mã thiết bị và trạng thái.</p>
        </div>
        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Inventory" asp-action="EquipmentDetails" asp-route-id="@Model.Id" class="admin-btn-secondary">Xem chi tiết</a>
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-btn-secondary">Quay lại danh sách</a>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Inventory" asp-action="EditEquipment" method="post" enctype="multipart/form-data" class="admin-page">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="admin-alert admin-alert--error"></div>

        <div class="admin-card">
            <div class="admin-card-section">
                <div class="admin-field-grid two-col">
                    <div>
                        <label asp-for="CategoryId" class="admin-label"></label>
                        <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="admin-select">
                            <option value="">Chọn danh mục</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="Status" class="admin-label"></label>
                        <select asp-for="Status" asp-items="Model.StatusOptions" class="admin-select">
                            <option value="">Chọn trạng thái</option>
                        </select>
                        <span asp-validation-for="Status" class="admin-validation"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="SerialNumber" class="admin-label"></label>
                        <input asp-for="SerialNumber" class="admin-input uppercase" />
                        <span asp-validation-for="SerialNumber" class="admin-validation"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="ImageFile" class="admin-label"></label>
                        @if (!string.IsNullOrWhiteSpace(Model.CurrentImageUrl))
                        {
                            <div class="mb-3 flex items-center gap-4 rounded-[8px] border border-[#e3e3de] bg-[#f4f4ee] p-3">
                                <img src="@Model.CurrentImageUrl" alt="@Model.SerialNumber" class="h-16 w-16 rounded-[8px] border border-[#e3e3de] object-cover" />
                                <div class="text-sm text-[#73796b]">Ảnh hiện tại của thiết bị.</div>
                            </div>
                        }
                        <input asp-for="ImageFile" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" class="admin-input admin-file" />
                        <p class="admin-hint">Chọn ảnh mới nếu muốn thay ảnh hiện tại.</p>
                        <span asp-validation-for="ImageFile" class="admin-validation"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-actions justify-end">
            <button type="submit" class="admin-btn-primary min-w-[192px]">Lưu cập nhật</button>
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-btn-secondary">Hủy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
