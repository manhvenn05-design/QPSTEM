@model STEM.Web.Areas.Admin.Models.EditEquipmentCategoryViewModel

@{
    ViewData["Title"] = "Cập nhật danh mục";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Cập nhật danh mục</h1>
            <p class="admin-page-subtitle">Điều chỉnh tên danh mục thiết bị.</p>
        </div>
        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-btn-secondary">Quay lại danh sách</a>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Inventory" asp-action="EditCategory" method="post" class="admin-page">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="admin-alert admin-alert--error"></div>

        <div class="admin-card">
            <div class="admin-card-section">
                <label asp-for="Name" class="admin-label"></label>
                <input asp-for="Name" class="admin-input" />
                <span asp-validation-for="Name" class="admin-validation"></span>
            </div>
        </div>

        <div class="admin-actions justify-end">
            <button type="submit" class="admin-btn-primary min-w-[192px]">Lưu cập nhật</button>
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-btn-secondary">Hủy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
