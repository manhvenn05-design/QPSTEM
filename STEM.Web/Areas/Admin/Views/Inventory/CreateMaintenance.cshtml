@model STEM.Web.Areas.Admin.Models.CreateMaintenanceLogViewModel

@{
    ViewData["Title"] = "Ghi nhận bảo trì";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Ghi nhận sự cố thiết bị</h1>
            <p class="admin-page-subtitle">Lưu lại thiết bị gặp sự cố và tình trạng xử lý hiện tại.</p>
        </div>
        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-btn-secondary">Quay lại danh sách</a>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Inventory" asp-action="CreateMaintenance" method="post" class="admin-page">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="admin-alert admin-alert--error"></div>

        <div class="admin-card">
            <div class="admin-card-section">
                <div class="admin-field-grid two-col">
                    <div class="md:col-span-2">
                        <label asp-for="EquipmentId" class="admin-label"></label>
                        <select asp-for="EquipmentId" asp-items="Model.EquipmentOptions" class="admin-select">
                            <option value="">Chọn thiết bị</option>
                        </select>
                        <span asp-validation-for="EquipmentId" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="ReportedBy" class="admin-label"></label>
                        <select asp-for="ReportedBy" asp-items="Model.ReporterOptions" class="admin-select">
                            <option value="">Chọn người báo</option>
                        </select>
                        <span asp-validation-for="ReportedBy" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="Status" class="admin-label"></label>
                        <select asp-for="Status" asp-items="Model.StatusOptions" class="admin-select">
                            <option value="">Chọn trạng thái</option>
                        </select>
                        <span asp-validation-for="Status" class="admin-validation"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="Issue" class="admin-label"></label>
                        <textarea asp-for="Issue" class="admin-textarea" rows="5" placeholder="Mô tả ngắn sự cố của thiết bị"></textarea>
                        <span asp-validation-for="Issue" class="admin-validation"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-actions justify-end">
            <button type="submit" class="admin-btn-primary min-w-[192px]">Lưu nhật ký</button>
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-btn-secondary">Hủy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
