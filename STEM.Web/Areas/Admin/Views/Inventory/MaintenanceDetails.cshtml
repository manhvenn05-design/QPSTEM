@model STEM.Web.Areas.Admin.Models.MaintenanceLogDetailsViewModel

@{
    ViewData["Title"] = "Chi tiết bảo trì";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Chi tiết nhật ký bảo trì</h1>
            <p class="admin-page-subtitle">Xem lại sự cố, người báo và trạng thái xử lý.</p>
        </div>
        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Inventory" asp-action="EditMaintenance" asp-route-id="@Model.Id" class="admin-btn-primary">Cập nhật</a>
            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-btn-secondary">Quay lại</a>
        </div>
    </div>

    <div class="admin-grid-two">
        <div class="space-y-6">
            <div class="admin-card">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Thông tin sự cố</h2>
                    <dl class="admin-data-grid two-col mt-6">
                        <div class="admin-data-item">
                            <dt>Thiết bị</dt>
                            <dd>@Model.EquipmentSerialNumber</dd>
                        </div>
                        <div class="admin-data-item">
                            <dt>Danh mục</dt>
                            <dd>@Model.CategoryName</dd>
                        </div>
                        <div class="admin-data-item">
                            <dt>Người báo</dt>
                            <dd>@Model.ReporterName</dd>
                        </div>
                        <div class="admin-data-item md:col-span-2">
                            <dt>Mô tả sự cố</dt>
                            <dd>@Model.Issue</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>

        <aside class="space-y-6">
            <div class="admin-card">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Trạng thái</h2>
                    <div class="mt-5">
                        <span class="inline-flex rounded-full px-3 py-2 text-sm font-semibold @Model.StatusBadgeClass">@Model.StatusLabel</span>
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Liên kết thiết bị</h2>
                    <a asp-area="Admin" asp-controller="Inventory" asp-action="EquipmentDetails" asp-route-id="@Model.EquipmentId" class="admin-btn-secondary mt-5 w-full">Xem thiết bị</a>
                    <form asp-area="Admin" asp-controller="Inventory" asp-action="DeleteMaintenance" asp-route-id="@Model.Id" method="post" class="mt-3" data-confirm-title="Xóa nhật ký bảo trì" data-confirm-message="Xóa nhật ký này? Hành động này không thể hoàn tác." data-confirm-submit-text="Xóa nhật ký">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="admin-btn-secondary w-full">Xóa nhật ký</button>
                    </form>
                </div>
            </div>
        </aside>
    </div>
</section>
