@{
    ViewData["Title"] = "Kho thiết bị";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Quản lý kho thiết bị</h1>
            <p class="admin-page-subtitle">Giao diện chia đúng ba nhóm dữ liệu: <code>EquipmentCategories</code>, <code>Equipments</code> và <code>MaintenanceLogs</code>.</p>
        </div>

        <div class="admin-actions">
            <button type="button" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">add</span>
                <span>Thêm thiết bị</span>
            </button>
        </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1fr_1.3fr]">
        <div class="admin-card">
            <div class="admin-card-section">
                <h2 class="admin-section-title">Danh mục thiết bị</h2>
                <div class="mt-5 space-y-4">
                    <div class="admin-card-soft p-4">
                        <div class="flex items-center justify-between">
                            <span class="font-semibold text-[#1a1c19]">Robot Kit</span>
                            <span class="text-sm text-[#73796b]">32 bộ</span>
                        </div>
                    </div>
                    <div class="admin-card-soft p-4">
                        <div class="flex items-center justify-between">
                            <span class="font-semibold text-[#1a1c19]">Laptop lớp học</span>
                            <span class="text-sm text-[#73796b]">18 máy</span>
                        </div>
                    </div>
                    <div class="admin-card-soft p-4">
                        <div class="flex items-center justify-between">
                            <span class="font-semibold text-[#1a1c19]">Cảm biến</span>
                            <span class="text-sm text-[#73796b]">54 thiết bị</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="admin-card overflow-hidden">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Thiết bị hiện có</h2>
                </div>
                <div class="overflow-x-auto">
                    <table class="admin-table min-w-full">
                        <thead>
                            <tr>
                                <th>SerialNumber</th>
                                <th>Category</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>RBX-KIT-001</strong></td>
                                <td>Robot Kit</td>
                                <td><span class="admin-tag admin-tag--success">Sẵn sàng</span></td>
                            </tr>
                            <tr>
                                <td><strong>LTP-014</strong></td>
                                <td>Laptop lớp học</td>
                                <td><span class="admin-tag admin-tag--warning">Đang mượn</span></td>
                            </tr>
                            <tr>
                                <td><strong>SNS-088</strong></td>
                                <td>Cảm biến</td>
                                <td><span class="admin-tag admin-tag--neutral">Bảo trì</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="admin-card overflow-hidden">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Nhật ký bảo trì</h2>
                </div>
                <div class="overflow-x-auto">
                    <table class="admin-table min-w-full">
                        <thead>
                            <tr>
                                <th>Thiết bị</th>
                                <th>Người báo</th>
                                <th>Issue</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>LTP-014</td>
                                <td>Nguyễn Minh Khoa</td>
                                <td>Pin sụt nhanh</td>
                                <td><span class="admin-tag admin-tag--warning">Đang xử lý</span></td>
                            </tr>
                            <tr>
                                <td>SNS-088</td>
                                <td>Lê Hoàng Việt</td>
                                <td>Không nhận tín hiệu</td>
                                <td><span class="admin-tag admin-tag--success">Đã thay mới</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
