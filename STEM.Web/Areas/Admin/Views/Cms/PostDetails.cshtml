@model STEM.Web.Areas.Admin.Models.PostDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">@Model.Title</h1>
            <p class="admin-page-subtitle">
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold @Model.StatusBadgeClass">
                    @Model.StatusLabel
                </span>
                @if (!string.IsNullOrEmpty(Model.Category))
                {
                    <span class="ml-2 text-xs text-[#73796b]">· @Model.Category</span>
                }
                <span class="ml-2 text-xs text-[#73796b]">· @Model.PublishedAtText</span>
            </p>
        </div>
        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Cms" asp-action="EditPost"
               asp-route-id="@Model.Id" class="admin-btn-primary">Chỉnh sửa</a>
            <a asp-area="Admin" asp-controller="Cms" asp-action="Index" class="admin-btn-secondary">Danh sách</a>
        </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.2fr_0.85fr]">

        @* ── Cột trái: nội dung ── *@
        <div class="space-y-6">

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="admin-card overflow-hidden">
                    <img src="@Model.ImageUrl" alt="@Model.Title"
                         style="width:100%; max-height:320px; object-fit:cover;" />
                </div>
            }

            <div class="admin-card">
                <div class="admin-card-section space-y-3">
                    <h2 class="admin-section-title">Mô tả ngắn (Excerpt)</h2>
                    @if (!string.IsNullOrEmpty(Model.Excerpt))
                    {
                        <p style="font-size:0.9rem; color:#42493d; line-height:1.7;">@Model.Excerpt</p>
                    }
                    else
                    {
                        <p style="font-size:0.9rem; color:#73796b; font-style:italic;">Chưa có mô tả ngắn.</p>
                    }
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-section space-y-3">
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
                        <h2 class="admin-section-title" style="margin:0;">Nội dung bài viết</h2>
                        @if (Model.IsPublished)
                        {
                            <a href="@Model.PublicUrl" target="_blank" class="admin-btn-secondary"
                               style="font-size:0.8rem;">Xem trang công khai</a>
                        }
                    </div>
                    <div class="admin-card-soft" style="border-radius:0.5rem; padding:1.25rem;
                                font-size:0.9rem; line-height:1.8; color:#42493d;">
                        @Html.Raw(Model.Content)
                    </div>
                </div>
            </div>
        </div>

        @* ── Cột phải: thông tin & thao tác ── *@
        <div class="space-y-6">

            <div class="admin-card">
                <div class="admin-card-section space-y-4">
                    <h2 class="admin-section-title">Thông tin</h2>
                    <dl style="display:grid; gap:0.75rem; font-size:0.875rem;">
                        <div>
                            <dt class="admin-detail-label">Tác giả</dt>
                            <dd class="admin-detail-value">@Model.AuthorName</dd>
                        </div>
                        <div>
                            <dt class="admin-detail-label">Slug (đường dẫn)</dt>
                            <dd class="admin-detail-value" style="font-family:monospace; font-size:0.8rem;">@Model.Slug</dd>
                        </div>
                        <div>
                            <dt class="admin-detail-label">Danh mục</dt>
                            <dd class="admin-detail-value">@(string.IsNullOrEmpty(Model.Category) ? "Chưa phân loại" : Model.Category)</dd>
                        </div>
                        <div>
                            <dt class="admin-detail-label">Ngày đăng</dt>
                            <dd class="admin-detail-value">@(string.IsNullOrEmpty(Model.PublishedAtText) ? "Chưa đặt ngày" : Model.PublishedAtText)</dd>
                        </div>
                        <div>
                            <dt class="admin-detail-label">Trạng thái</dt>
                            <dd>
                                <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold @Model.StatusBadgeClass">
                                    @Model.StatusLabel
                                </span>
                            </dd>
                        </div>
                    </dl>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-section space-y-3">
                    <h2 class="admin-section-title">Thao tác</h2>
                    <a asp-area="Admin" asp-controller="Cms" asp-action="EditPost"
                       asp-route-id="@Model.Id"
                       class="admin-btn-primary w-full text-center">Sửa bài viết</a>

                    @if (Model.IsPublished)
                    {
                        <a href="@Model.PublicUrl" target="_blank"
                           class="admin-btn-secondary w-full text-center">Xem trang công khai</a>
                    }

                    <form asp-area="Admin" asp-controller="Cms" asp-action="DeletePost"
                          asp-route-id="@Model.Id" method="post"
                          data-confirm-title="Xóa bài viết"
                          data-confirm-message="Xóa bài viết «@Model.Title»? Hành động này không thể hoàn tác."
                          data-confirm-submit-text="Xóa bài viết">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="admin-btn-danger w-full">Xóa bài viết</button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>
