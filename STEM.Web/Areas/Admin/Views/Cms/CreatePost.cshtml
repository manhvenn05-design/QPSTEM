@model STEM.Web.Areas.Admin.Models.CreatePostViewModel

@{
    ViewData["Title"] = "Tạo bài viết";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Tạo bài viết</h1>
            <p class="admin-page-subtitle">Nhập tiêu đề, slug và nội dung hiển thị.</p>
        </div>

        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Cms" asp-action="Index" class="admin-btn-secondary">Quay lại danh sách</a>
        </div>
    </div>

    <form method="post" asp-area="Admin" asp-controller="Cms" asp-action="CreatePost" class="grid gap-6 xl:grid-cols-[1.55fr_0.9fr]">
        @Html.AntiForgeryToken()

        <div class="space-y-6">
            <div class="admin-card">
                <div class="admin-card-section space-y-5">
                    <div>
                        <h2 class="admin-section-title">Nội dung bài viết</h2>
                        <p class="admin-section-subtitle">Slug nên ngắn gọn để dễ dùng cho đường dẫn.</p>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="admin-validation-summary"></div>

                    <div class="grid gap-5">
                        <div>
                            <label asp-for="AuthorId" class="admin-label"></label>
                            <select asp-for="AuthorId" asp-items="Model.AuthorOptions" class="admin-select">
                                <option value="">Chọn tác giả</option>
                            </select>
                            <span asp-validation-for="AuthorId" class="admin-field-validation"></span>
                        </div>

                        <div>
                            <label asp-for="Title" class="admin-label"></label>
                            <input asp-for="Title" class="admin-input" placeholder="Nhập tiêu đề bài viết" />
                            <span asp-validation-for="Title" class="admin-field-validation"></span>
                        </div>

                        <div>
                            <label asp-for="Slug" class="admin-label"></label>
                            <input asp-for="Slug" class="admin-input" placeholder="Vi-du-duong-dan" />
                            <span asp-validation-for="Slug" class="admin-field-validation"></span>
                        </div>

                        <div>
                            <label asp-for="Content" class="admin-label"></label>
                            <textarea asp-for="Content" rows="14" class="admin-textarea" placeholder="Nhập nội dung bài viết"></textarea>
                            <span asp-validation-for="Content" class="admin-field-validation"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <aside class="space-y-6">
            <div class="admin-card">
                <div class="admin-card-section space-y-4">
                    <label class="inline-flex items-center gap-3 text-sm font-medium text-[#1a1c19]">
                        <input asp-for="IsPublished" class="admin-checkbox" />
                        <span>Hiển thị ngay</span>
                    </label>
                    <button type="submit" class="admin-btn-primary w-full">Lưu bài viết</button>
                </div>
            </div>
        </aside>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
