@model STEM.Web.Areas.Admin.Models.CreateAttendanceViewModel

@{
    ViewData["Title"] = "Thêm điểm danh";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Ghi điểm danh</h1>
            <p class="admin-page-subtitle">Form này chỉ giữ các trường admin thực sự cần thao tác: học viên, trạng thái có mặt, ghi chú và minh chứng sản phẩm.</p>
        </div>

        <div class="admin-actions">
            @if (Model.SessionId.HasValue)
            {
                <a asp-area="Admin" asp-controller="Attendances" asp-action="Board" asp-route-sessionId="@Model.SessionId.Value" class="admin-btn-secondary">Quay lại sổ điểm danh</a>
            }
            else
            {
                <a asp-area="Admin" asp-controller="Attendances" asp-action="Index" class="admin-btn-secondary">Quay lại danh sách</a>
            }
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Attendances" asp-action="Create" method="post" class="admin-page">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="admin-alert admin-alert--error"></div>

        <div class="admin-card">
            <div class="admin-card-section">
                <div class="admin-field-grid two-col">
                    <div class="md:col-span-2">
                        <label asp-for="SessionId" class="admin-label"></label>
                        <select asp-for="SessionId" asp-items="Model.SessionOptions" class="admin-select" id="SessionId">
                            <option value="">Chọn buổi học</option>
                        </select>
                        <span asp-validation-for="SessionId" class="admin-validation"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="StudentId" class="admin-label"></label>
                        <select asp-for="StudentId" asp-items="Model.StudentOptions" class="admin-select" id="StudentId">
                            <option value="">Chọn học viên thuộc lớp</option>
                        </select>
                        <span asp-validation-for="StudentId" class="admin-validation"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label class="admin-checkbox-card">
                            <input asp-for="IsPresent" />
                            <span>
                                <span class="block text-sm font-semibold text-[#1a1c19]">Đánh dấu có mặt</span>
                                <span class="mt-1 block text-sm text-[#73796b]">Nếu bỏ chọn, hệ thống sẽ lưu học viên ở trạng thái vắng.</span>
                            </span>
                        </label>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="TeacherRawNote" class="admin-label"></label>
                        <textarea asp-for="TeacherRawNote" class="admin-textarea" rows="4" placeholder="Tóm tắt ngắn: thái độ, tiến độ, điểm cần lưu ý của học viên..."></textarea>
                        <span asp-validation-for="TeacherRawNote" class="admin-validation"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="ProductMediaUrls" class="admin-label"></label>
                        <textarea asp-for="ProductMediaUrls" class="admin-textarea" rows="4" placeholder="Dán URL ảnh/video sản phẩm của học viên nếu đã có"></textarea>
                        <span asp-validation-for="ProductMediaUrls" class="admin-validation"></span>
                    </div>
                </div>
            </div>
        </div>

        <details class="admin-card">
            <summary class="admin-card-section cursor-pointer">
                <div>
                    <h2 class="admin-section-title">Thông tin bổ sung</h2>
                    <p class="admin-section-subtitle">Mở khi cần cập nhật thêm dữ liệu liên quan.</p>
                </div>
            </summary>
            <div class="admin-divider"></div>
            <div class="admin-card-section">
                <div class="admin-field-grid">
                    <div>
                        <label asp-for="AiEvaluation" class="admin-label"></label>
                        <textarea asp-for="AiEvaluation" class="admin-textarea" rows="4"></textarea>
                        <span asp-validation-for="AiEvaluation" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="VideoTranscript" class="admin-label"></label>
                        <textarea asp-for="VideoTranscript" class="admin-textarea" rows="4"></textarea>
                        <span asp-validation-for="VideoTranscript" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="SoftSkillJson" class="admin-label"></label>
                        <input asp-for="SoftSkillJson" class="admin-input" />
                        <span asp-validation-for="SoftSkillJson" class="admin-validation"></span>
                    </div>
                </div>
            </div>
        </details>

        <div class="admin-actions justify-end">
            <button type="submit" class="admin-btn-primary min-w-[192px]">Lưu điểm danh</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const sessionSelect = document.getElementById("SessionId");
            const studentSelect = document.getElementById("StudentId");

            if (!sessionSelect || !studentSelect) {
                return;
            }

            const initialStudent = studentSelect.value;

            const renderDefault = (selectedValue = "") => {
                studentSelect.innerHTML = "";
                const option = document.createElement("option");
                option.value = "";
                option.textContent = "Chọn học viên thuộc lớp";
                studentSelect.appendChild(option);

                if (selectedValue) {
                    studentSelect.value = selectedValue;
                }
            };

            const loadStudents = async (sessionId, selectedValue = "") => {
                renderDefault();

                if (!sessionId) {
                    return;
                }

                const response = await fetch(`/Admin/Attendances/StudentsForSession?sessionId=${encodeURIComponent(sessionId)}`);
                if (!response.ok) {
                    return;
                }

                const items = await response.json();
                for (const item of items) {
                    const option = document.createElement("option");
                    option.value = item.value;
                    option.textContent = item.text;
                    studentSelect.appendChild(option);
                }

                if (selectedValue) {
                    studentSelect.value = selectedValue;
                }
            };

            sessionSelect.addEventListener("change", () => loadStudents(sessionSelect.value));
            loadStudents(sessionSelect.value, initialStudent);
        })();
    </script>
}
