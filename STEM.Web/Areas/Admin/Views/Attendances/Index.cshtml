@model STEM.Web.Areas.Admin.Models.AttendanceManagementViewModel

@{
    ViewData["Title"] = "Điểm danh";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Sổ điểm danh theo buổi học</h1>
            <p class="admin-page-subtitle">Mỗi buổi học là một lần điểm danh riêng. Chọn buổi để xem danh sách học viên.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="admin-alert admin-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="admin-alert admin-alert--error">@errorMessage</div>
    }

    <form method="get" asp-area="Admin" asp-controller="Attendances" asp-action="Index" class="admin-card">
        <div class="admin-card-section">
            <div class="admin-toolbar">
                <div class="admin-chip-group">
                    @foreach (var filter in Model.Filters)
                    {
                        var isActive = filter.Key == Model.SelectedFilter;
                        <a asp-area="Admin"
                           asp-controller="Attendances"
                           asp-action="Index"
                           asp-route-filter="@filter.Key"
                           asp-route-q="@Model.SearchTerm"
                           class="@(isActive ? "admin-chip is-active" : "admin-chip")">
                            @filter.Label
                        </a>
                    }
                </div>

                <div class="w-full lg:max-w-md">
                    <input type="hidden" name="filter" value="@Model.SelectedFilter" />
                    <label class="relative block">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-[20px] text-[#73796b]">search</span>
                        <input type="text" name="q" value="@Model.SearchTerm" placeholder="Tìm theo lớp, khóa học, giáo viên..." class="admin-input pl-12" />
                    </label>
                </div>
            </div>
        </div>
    </form>

    <div class="admin-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="admin-table min-w-full">
                <thead>
                    <tr>
                        <th>Buổi số / ngày học</th>
                        <th>Lớp / Khóa</th>
                        <th>Giáo viên</th>
                        <th>Sĩ số</th>
                        <th>Tiến độ điểm danh</th>
                        <th>Trạng thái</th>
                        <th class="text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Sessions.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="admin-empty">Không có buổi học nào phù hợp với bộ lọc hiện tại.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Sessions)
                        {
                            <tr>
                                <td>
                                    <div>
                                        <p class="font-semibold text-[#1a1c19]">@item.SessionLabel</p>
                                        <p class="mt-1 text-sm text-[#73796b]">@item.ScheduleText</p>
                                    </div>
                                </td>
                                <td>
                                    <div>
                                        <p class="font-semibold text-[#1a1c19]">@item.ClassCode</p>
                                        <p class="mt-1 text-sm text-[#73796b]">@item.CourseName</p>
                                    </div>
                                </td>
                                <td><strong>@item.TeacherName</strong></td>
                                <td>@item.StudentCount học viên</td>
                                <td>
                                    <div>
                                        <p class="font-semibold text-[#1a1c19]">@item.CompletionText</p>
                                        <p class="mt-1 text-sm text-[#73796b]">@item.PresentCount có mặt · @item.AbsentCount vắng</p>
                                    </div>
                                </td>
                                <td>
                                    <span class="inline-flex rounded-full px-3 py-2 text-xs font-semibold @item.StatusBadgeClass">
                                        @item.StatusLabel
                                    </span>
                                </td>
                                <td>
                                    <div class="flex justify-end">
                                        <a asp-area="Admin" asp-controller="Attendances" asp-action="Board" asp-route-sessionId="@item.SessionId" class="admin-btn-secondary !h-10">
                                            Mở sổ điểm danh
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-divider flex flex-col gap-4 px-6 py-5 text-sm text-[#73796b] lg:flex-row lg:items-center lg:justify-between">
            <p>Hiển thị @((Model.TotalSessions == 0 ? 0 : ((Model.CurrentPage - 1) * 10) + 1))-@Math.Min(Model.CurrentPage * 10, Model.TotalSessions) trong số @Model.TotalSessions buổi học</p>

            <div class="admin-pagination">
                <a asp-area="Admin"
                   asp-controller="Attendances"
                   asp-action="Index"
                   asp-route-filter="@Model.SelectedFilter"
                   asp-route-q="@Model.SearchTerm"
                   asp-route-page="@(Math.Max(1, Model.CurrentPage - 1))"
                   class="admin-page-link @(Model.CurrentPage == 1 ? "is-disabled" : string.Empty)">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </a>
                <span class="admin-page-link is-active">@Model.CurrentPage</span>
                <a asp-area="Admin"
                   asp-controller="Attendances"
                   asp-action="Index"
                   asp-route-filter="@Model.SelectedFilter"
                   asp-route-q="@Model.SearchTerm"
                   asp-route-page="@(Math.Min(Model.TotalPages, Model.CurrentPage + 1))"
                   class="admin-page-link @(Model.CurrentPage == Model.TotalPages ? "is-disabled" : string.Empty)">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </a>
            </div>
        </div>
    </div>
</section>
