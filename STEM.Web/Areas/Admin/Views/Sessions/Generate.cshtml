@model STEM.Web.Areas.Admin.Models.GenerateScheduleViewModel

@{
    ViewData["Title"] = "Sinh lịch tự động";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Sinh lịch tự động</h1>
            <p class="admin-page-subtitle">Tạo hàng loạt buổi học theo quy tắc cố định. Hệ thống sẽ kiểm tra trùng lịch phòng và giáo viên.</p>
        </div>

        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Classes" asp-action="Details" asp-route-id="@Model.ClassId" class="admin-btn-secondary">Quay lại lớp học</a>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Sessions" asp-action="Generate" method="post" class="admin-page">
        @Html.AntiForgeryToken()
        <input asp-for="ClassId" type="hidden" />

        <div asp-validation-summary="All" class="admin-alert admin-alert--error"></div>

        <div class="admin-grid-two">
            <div class="space-y-6">
                <div class="admin-card">
                    <div class="admin-card-section">
                        <div class="mb-6">
                            <h2 class="admin-section-title">Cấu hình lịch học</h2>
                            <p class="admin-section-subtitle">Thiết lập thời gian và quy luật lặp lại.</p>
                        </div>

                        <div class="admin-field-grid two-col">
                            <div class="md:col-span-2">
                                <label asp-for="RoomId" class="admin-label"></label>
                                <select asp-for="RoomId" asp-items="Model.RoomOptions" class="admin-select">
                                    <option value="">Chọn phòng học (sẽ áp dụng cho toàn bộ buổi)</option>
                                </select>
                                <span asp-validation-for="RoomId" class="admin-validation"></span>
                            </div>

                            <div class="md:col-span-2">
                                <label asp-for="StartDate" class="admin-label"></label>
                                <input asp-for="StartDate" type="date" class="admin-input" />
                                <span asp-validation-for="StartDate" class="admin-validation"></span>
                            </div>

                            <div>
                                <label asp-for="StartTime" class="admin-label"></label>
                                <input asp-for="StartTime" type="time" class="admin-input" />
                                <span asp-validation-for="StartTime" class="admin-validation"></span>
                            </div>

                            <div>
                                <label asp-for="EndTime" class="admin-label"></label>
                                <input asp-for="EndTime" type="time" class="admin-input" />
                                <span asp-validation-for="EndTime" class="admin-validation"></span>
                            </div>
                            
                            <div class="md:col-span-2">
                                <label asp-for="SessionCount" class="admin-label"></label>
                                <input asp-for="SessionCount" type="number" min="1" max="100" class="admin-input" />
                                <p class="admin-hint">Khóa học có tối đa @Model.TotalSessionsAllowed buổi. Đã tạo @Model.CurrentSessionCount buổi.</p>
                                <span asp-validation-for="SessionCount" class="admin-validation"></span>
                            </div>

                            <div class="md:col-span-2">
                                <label class="admin-label">Lặp lại vào các ngày</label>
                                <div class="mt-2 grid grid-cols-2 gap-4 md:grid-cols-4">
                                    @foreach (var day in Model.DayOptions)
                                    {
                                        <label class="inline-flex items-center gap-2">
                                            <input type="checkbox" name="SelectedDays" value="@day.Value" class="h-4 w-4 rounded border-[#c2c9b9] text-[#1a3a6e] focus:ring-[#1a3a6e]" @(Model.SelectedDays.Contains(Enum.Parse<DayOfWeek>(day.Value)) ? "checked" : "") />
                                            <span class="text-sm font-medium text-[#42493d]">@day.Text</span>
                                        </label>
                                    }
                                </div>
                                <span asp-validation-for="SelectedDays" class="admin-validation"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <aside class="space-y-6">
                <div class="admin-card">
                    <div class="admin-card-section bg-[#f8f9fa]">
                        <h2 class="admin-section-title">Lưu ý khi tạo tự động</h2>
                        <ul class="mt-4 list-disc pl-5 text-sm text-[#42493d] space-y-2">
                            <li>Hệ thống sẽ dựa vào ngày bắt đầu và các thứ bạn chọn để tự đếm số buổi cho đến khi đủ số lượng yêu cầu.</li>
                            <li>Nếu giữa chừng có 1 buổi bị <strong>trùng lịch giáo viên</strong> hoặc <strong>trùng phòng học</strong>, hệ thống sẽ hủy toàn bộ tiến trình để bạn xếp lại giờ, không có rác dữ liệu.</li>
                            <li>Sau khi tạo thành công, bạn vẫn có thể vào chi tiết từng buổi để đổi phòng hoặc giờ nếu hôm đó có sự thay đổi đột xuất.</li>
                        </ul>
                    </div>
                </div>
                
                <div class="admin-card">
                    <div class="admin-card-section">
                        <button type="submit" class="admin-btn-primary w-full justify-center">Sinh lịch ngay</button>
                    </div>
                </div>
            </aside>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
