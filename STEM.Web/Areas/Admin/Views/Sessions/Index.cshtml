@model STEM.Web.Areas.Admin.Models.SessionManagementViewModel

@{
    ViewData["Title"] = "Buổi học";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Quản lý buổi học</h1>
        </div>

        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Sessions" asp-action="Create" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">add</span>
                <span>Thêm buổi học</span>
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="admin-alert admin-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="admin-alert admin-alert--error">@errorMessage</div>
    }

    <form method="get" asp-area="Admin" asp-controller="Sessions" asp-action="Index" class="admin-card">
        <div class="admin-card-section">
            <div class="admin-toolbar">
                <div class="admin-chip-group">
                    @foreach (var filter in Model.Filters)
                    {
                        var isActive = filter.Key == Model.SelectedFilter;
                        <a asp-area="Admin"
                           asp-controller="Sessions"
                           asp-action="Index"
                           asp-route-filter="@filter.Key"
                           asp-route-q="@Model.SearchTerm"
                           class="@(isActive ? "admin-chip is-active" : "admin-chip")">
                            @filter.Label
                        </a>
                    }
                </div>

                <div class="w-full lg:max-w-md">
                    <input type="hidden" name="filter" value="@Model.SelectedFilter" />
                    <label class="relative block">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-[20px] text-[#73796b]">search</span>
                        <input type="text" name="q" value="@Model.SearchTerm" placeholder="Tìm theo lớp, khóa học, giáo viên hoặc chủ đề..." class="admin-input pl-12" />
                    </label>
                </div>
            </div>
        </div>
    </form>

    <div class="admin-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="admin-table min-w-full">
                <thead>
                    <tr>
                        <th>Buổi học</th>
                        <th>Lớp / Giáo viên</th>
                        <th>Lịch học</th>
                        <th>Nội dung</th>
                        <th>Tài nguyên</th>
                        <th>Điểm danh / Thiết bị</th>
                        <th>Trạng thái</th>
                        <th class="text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Sessions.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="admin-empty">Không có buổi học nào phù hợp với bộ lọc hiện tại.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Sessions)
                        {
                            <tr>
                                <td>
                                    <div>
                                        <p class="font-semibold text-[#1a1c19]">@item.SessionLabel</p>
                                        <p class="mt-1 text-sm text-[#73796b]">@item.ClassCode · @item.CourseName</p>
                                    </div>
                                </td>
                                <td>
                                    <div>
                                        <p class="font-semibold text-[#1a1c19]">@item.TeacherName</p>
                                        <p class="mt-1 text-sm text-[#73796b]">Phụ trách giảng dạy</p>
                                    </div>
                                </td>
                                <td>
                                    <div>
                                        <p class="font-semibold text-[#1a1c19]">@item.DateText</p>
                                        <p class="mt-1 text-sm text-[#73796b]">@item.TimeRangeText</p>
                                    </div>
                                </td>
                                <td>
                                    <div>
                                        <p class="font-medium text-[#1a1c19]">@item.TopicText</p>
                                        <p class="mt-1 text-sm text-[#73796b]">Đánh số theo tiến độ của từng lớp</p>
                                    </div>
                                </td>
                                <td>
                                    <div class="space-y-2">
                                        <span class="admin-tag admin-tag--neutral">@item.MaterialText</span>
                                        <div class="text-sm text-[#73796b]">@item.MediaText</div>
                                    </div>
                                </td>
                                <td>
                                    <div>
                                        <p class="font-semibold text-[#1a1c19]">@item.AttendanceCount bản ghi</p>
                                        <p class="mt-1 text-sm text-[#73796b]">@item.EquipmentBorrowCount lượt mượn trả</p>
                                    </div>
                                </td>
                                <td>
                                    <span class="inline-flex items-center gap-2 rounded-full px-3 py-2 text-xs font-semibold @item.StatusBadgeClass">
                                        <span class="h-2 w-2 rounded-full @(item.StatusLabel == "Hôm nay" ? "bg-[#6a994e]" : item.StatusLabel == "Sắp tới" ? "bg-[#9b682f]" : "bg-[#73796b]")"></span>
                                        @item.StatusLabel
                                    </span>
                                </td>
                                <td>
                                    <div class="flex justify-end">
                                        <details class="relative" data-table-action>
                                            <summary class="admin-menu-button cursor-pointer list-none">
                                                <span class="material-symbols-outlined text-[18px]">more_horiz</span>
                                            </summary>
                                            <div data-table-menu class="hidden">
                                                <a asp-area="Admin" asp-controller="Sessions" asp-action="Details" asp-route-id="@item.Id" class="admin-menu-item">
                                                    <span class="material-symbols-outlined text-[18px]">visibility</span>
                                                    <span>Chi tiết</span>
                                                </a>
                                                <a asp-area="Admin" asp-controller="Sessions" asp-action="Edit" asp-route-id="@item.Id" class="admin-menu-item">
                                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                                    <span>Cập nhật</span>
                                                </a>
                                                <form asp-area="Admin" asp-controller="Sessions" asp-action="Delete" asp-route-id="@item.Id" method="post" data-confirm-title="Xóa buổi học" data-confirm-message="Xóa buổi học này? Hành động này không thể hoàn tác." data-confirm-submit-text="Xóa buổi học">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="admin-menu-item admin-menu-item--danger w-full text-left">
                                                        <span class="material-symbols-outlined text-[18px]">delete</span>
                                                        <span>Xóa</span>
                                                    </button>
                                                </form>
                                            </div>
                                        </details>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-divider flex flex-col gap-4 px-6 py-5 text-sm text-[#73796b] lg:flex-row lg:items-center lg:justify-between">
            <p>Hiển thị @((Model.TotalSessions == 0 ? 0 : ((Model.CurrentPage - 1) * 10) + 1))-@Math.Min(Model.CurrentPage * 10, Model.TotalSessions) trong số @Model.TotalSessions buổi học</p>

            <div class="admin-pagination">
                <a asp-area="Admin"
                   asp-controller="Sessions"
                   asp-action="Index"
                   asp-route-filter="@Model.SelectedFilter"
                   asp-route-q="@Model.SearchTerm"
                   asp-route-page="@(Math.Max(1, Model.CurrentPage - 1))"
                   class="admin-page-link @(Model.CurrentPage == 1 ? "is-disabled" : string.Empty)">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </a>
                <span class="admin-page-link is-active">@Model.CurrentPage</span>
                <a asp-area="Admin"
                   asp-controller="Sessions"
                   asp-action="Index"
                   asp-route-filter="@Model.SelectedFilter"
                   asp-route-q="@Model.SearchTerm"
                   asp-route-page="@(Math.Min(Model.TotalPages, Model.CurrentPage + 1))"
                   class="admin-page-link @(Model.CurrentPage == Model.TotalPages ? "is-disabled" : string.Empty)">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </a>
            </div>
        </div>
    </div>
</section>
