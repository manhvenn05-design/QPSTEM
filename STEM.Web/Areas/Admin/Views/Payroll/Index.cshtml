@model STEM.Web.Areas.Admin.Models.PayrollManagementViewModel

@{
    ViewData["Title"] = "Bảng lương";
    var hasRecords = Model.Records.Count > 0;
    var allApproved = hasRecords && Model.ApprovedTeachers == Model.TotalTeachers;
    var draftTeachers = Model.TotalTeachers - Model.ApprovedTeachers;
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Bảng lương giáo viên</h1>
            <p class="admin-page-subtitle">Sinh bảng lương theo kỳ, rà soát tổng tiền và chốt để khóa chỉnh sửa attendance của tháng tương ứng.</p>
        </div>

        <div class="admin-actions">
            <form asp-area="Admin" asp-controller="Payroll" asp-action="Generate" method="post" class="flex items-center gap-3"
                  data-confirm-title="Tạo/Cập nhật bảng lương"
                  data-confirm-message="Hệ thống sẽ tính lại dữ liệu lương nháp cho toàn bộ giáo viên trong kỳ đang chọn. Bạn có muốn tiếp tục không?"
                  data-confirm-submit-text="Tạo/Cập nhật">
                @Html.AntiForgeryToken()
                <input type="hidden" name="year" value="@Model.Year" />
                <input type="hidden" name="month" value="@Model.Month" />
                <button type="submit" class="admin-btn-primary">Tạo/Cập nhật bảng lương</button>
            </form>

            <form asp-area="Admin" asp-controller="Payroll" asp-action="Approve" method="post" class="flex items-center gap-3"
                  data-confirm-title="Chốt kỳ lương"
                  data-confirm-message="Khi chốt, các bản ghi lương của kỳ này sẽ chuyển sang Approved và giáo viên không thể tiếp tục chỉnh sửa attendance thuộc tháng đó. Bạn có chắc chắn không?"
                  data-confirm-submit-text="Chốt kỳ lương">
                @Html.AntiForgeryToken()
                <input type="hidden" name="year" value="@Model.Year" />
                <input type="hidden" name="month" value="@Model.Month" />
                <button type="submit" class="admin-btn-secondary" disabled="@(!hasRecords || allApproved)">Chốt kỳ lương</button>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="admin-alert admin-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="admin-alert admin-alert--error">@errorMessage</div>
    }

    

    <form method="get" asp-area="Admin" asp-controller="Payroll" asp-action="Index" class="admin-card">
        <div class="admin-card-section">
            <div class="grid gap-4 md:grid-cols-[1fr_1fr_auto]">
                <div>
                    <label class="admin-label" for="year">Năm</label>
                    <input class="admin-input" id="year" name="year" type="number" min="2020" max="2100" value="@Model.Year" />
                </div>
                <div>
                    <label class="admin-label" for="month">Tháng</label>
                    <input class="admin-input" id="month" name="month" type="number" min="1" max="12" value="@Model.Month" />
                </div>
                <div class="flex items-end">
                    <button type="submit" class="admin-btn-secondary w-full">Xem kỳ lương</button>
                </div>
            </div>
        </div>
    </form>

    <div class="admin-stat-grid four-col">
        <article class="admin-stat-card">
            <span class="admin-stat-label">Kỳ lương</span>
            <div class="admin-stat-value">@Model.PeriodLabel</div>
            <p class="admin-kicker">Kỳ đang thao tác.</p>
        </article>
        <article class="admin-stat-card">
            <span class="admin-stat-label">Có bảng lương</span>
            <div class="admin-stat-value">@Model.TotalTeachers</div>
            <p class="admin-kicker">Số giáo viên đã có bản ghi payroll.</p>
        </article>
        <article class="admin-stat-card">
            <span class="admin-stat-label">Đã chốt</span>
            <div class="admin-stat-value">@Model.ApprovedTeachers</div>
            <p class="admin-kicker">Còn @draftTeachers bản nháp cần rà soát.</p>
        </article>
        <article class="admin-stat-card">
            <span class="admin-stat-label">Tổng chi dự kiến</span>
            <div class="admin-stat-value">@Model.TotalPayout.ToString("N0") đ</div>
            <p class="admin-kicker">Draft chưa chốt: @Model.DraftPayout.ToString("N0") đ</p>
        </article>
    </div>

    <div class="admin-card">
        <div class="admin-card-section flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
            <div>
                <h2 class="admin-section-title">Trạng thái kỳ hiện tại</h2>
                @if (!hasRecords)
                {
                    <p class="admin-section-subtitle">Chưa có bản ghi lương nào cho kỳ này. Hãy bấm <strong>Tạo/Cập nhật bảng lương</strong> để sinh dữ liệu.</p>
                }
                else if (allApproved)
                {
                    <p class="admin-section-subtitle">Toàn bộ bản ghi của kỳ này đã được chốt. Attendance tương ứng đã bị khóa chỉnh sửa từ phía giáo viên.</p>
                }
                else
                {
                    <p class="admin-section-subtitle">Kỳ này đang có <strong>@draftTeachers</strong> bản nháp. Bạn có thể điều chỉnh thưởng/phạt rồi chốt khi số liệu đã ổn.</p>
                }
            </div>
            <div class="flex flex-wrap gap-2">
                <span class="admin-tag admin-tag--neutral">Draft: @draftTeachers</span>
                <span class="admin-tag admin-tag--success">Approved: @Model.ApprovedTeachers</span>
            </div>
        </div>
    </div>

    <div class="admin-card">
        <div class="admin-card-section">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <h2 class="admin-section-title">Chi tiết theo giáo viên</h2>
                    <p class="admin-section-subtitle">Dữ liệu draft có thể tạo lại. Bản ghi đã chốt sẽ khóa khỏi thao tác cập nhật từ giáo viên.</p>
                </div>
                <div class="text-sm text-[#6b7c99]">Tổng draft chưa chốt: @Model.DraftPayout.ToString("N0") đ</div>
            </div>

            @if (!hasRecords)
            {
                <div class="mt-6 rounded-lg border border-dashed border-[#dce6f5] bg-[#f8fbff] px-4 py-6 text-sm text-[#6b7c99]">
                    Chưa có bản ghi lương cho kỳ này. Bấm <strong>Tạo/Cập nhật bảng lương</strong> để sinh dữ liệu.
                </div>
            }
            else
            {
                <div class="mt-6 overflow-x-auto">
                    <table class="admin-table min-w-full">
                        <thead>
                            <tr>
                                <th>Giáo viên</th>
                                <th>Tier</th>
                                <th>Buổi hợp lệ</th>
                                <th>Tiền buổi</th>
                                <th>Thưởng</th>
                                <th>Khấu trừ</th>
                                <th>Thực nhận</th>
                                <th>Trạng thái</th>
                                <th>Ghi chú điều chỉnh</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var record in Model.Records)
                            {
                                var isApproved = string.Equals(record.Status, STEM.Web.Services.AttendanceWorkflowService.PayrollRecordStatusApproved, StringComparison.OrdinalIgnoreCase);
                                var badgeClass = isApproved
                                    ? "bg-[#edf7e8] text-[#456c3f]"
                                    : "bg-[#fff4e8] text-[#9b682f]";

                                <tr>
                                    <td>
                                        <div class="font-medium text-[#0f1e38]">@record.TeacherName</div>
                                        <div class="text-xs text-[#6b7c99]">@record.TeacherUsername</div>
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(record.SalaryTier) ? "Chưa cấu hình" : record.SalaryTier)</td>
                                    <td>@record.TotalValidSessions</td>
                                    <td>@record.SessionEarnings.ToString("N0") đ</td>
                                    <td>@record.Bonuses.ToString("N0") đ</td>
                                    <td>@record.Deductions.ToString("N0") đ</td>
                                    <td class="font-semibold text-[#0f1e38]">@record.TotalPay.ToString("N0") đ</td>
                                    <td>
                                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold @badgeClass">@record.Status</span>
                                        @if (record.ApprovedAt.HasValue)
                                        {
                                            <div class="mt-1 text-xs text-[#6b7c99]">@record.ApprovedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                        }
                                    </td>
                                    <td class="text-xs text-[#6b7c99]">
                                        @(string.IsNullOrWhiteSpace(record.AdjustmentNotes) ? "-" : record.AdjustmentNotes)
                                    </td>
                                    <td class="text-right">
                                        @if (!isApproved)
                                        {
                                            <button type="button" class="admin-btn-secondary px-2 py-1 text-xs"
                                                    onclick="openEditDraftModal(this)"
                                                    data-id="@record.Id"
                                                    data-name="@record.TeacherName"
                                                    data-bonuses="@record.Bonuses"
                                                    data-deductions="@record.Deductions"
                                                    data-notes="@record.AdjustmentNotes">
                                                Điều chỉnh
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

<div id="editDraftModal" class="fixed inset-0 z-50 flex hidden items-center justify-center bg-[#0f1e38]/50 backdrop-blur-sm">
    <form asp-area="Admin" asp-controller="Payroll" asp-action="UpdateDraft" method="post" class="admin-card w-full max-w-lg">
        @Html.AntiForgeryToken()
        <input type="hidden" name="year" value="@Model.Year" />
        <input type="hidden" name="month" value="@Model.Month" />
        <input type="hidden" id="editDraftId" name="Id" value="" />

        <div class="admin-card-section border-b border-[#dce6f5]">
            <h3 class="admin-section-title">Điều chỉnh bảng lương</h3>
            <p class="admin-section-subtitle">Giáo viên: <strong id="editDraftName"></strong></p>
        </div>
        <div class="admin-card-section grid gap-4">
            <div>
                <label class="admin-label" for="editDraftBonuses">Thưởng (VNĐ)</label>
                <input type="number" id="editDraftBonuses" name="Bonuses" class="admin-input" min="0" step="10000" />
            </div>
            <div>
                <label class="admin-label" for="editDraftDeductions">Khấu trừ (VNĐ)</label>
                <input type="number" id="editDraftDeductions" name="Deductions" class="admin-input" min="0" step="10000" />
            </div>
            <div>
                <label class="admin-label" for="editDraftNotes">Ghi chú điều chỉnh</label>
                <textarea id="editDraftNotes" name="AdjustmentNotes" class="admin-input min-h-[80px]" placeholder="Lý do thưởng/phạt..."></textarea>
            </div>
        </div>
        <div class="admin-card-section flex justify-end gap-3 border-t border-[#dce6f5] bg-[#f8fbff]">
            <button type="button" class="admin-btn-secondary" onclick="closeEditDraftModal()">Hủy</button>
            <button type="submit" class="admin-btn-primary">Lưu thay đổi</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function openEditDraftModal(btn) {
            document.getElementById('editDraftId').value = btn.dataset.id;
            document.getElementById('editDraftName').innerText = btn.dataset.name;
            document.getElementById('editDraftBonuses').value = btn.dataset.bonuses;
            document.getElementById('editDraftDeductions').value = btn.dataset.deductions;
            document.getElementById('editDraftNotes').value = btn.dataset.notes;
            document.getElementById('editDraftModal').classList.remove('hidden');
        }

        function closeEditDraftModal() {
            document.getElementById('editDraftModal').classList.add('hidden');
        }
    </script>
}
