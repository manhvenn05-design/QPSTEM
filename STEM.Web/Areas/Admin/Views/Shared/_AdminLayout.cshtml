@using System.Security.Claims
@inject STEM.Web.Services.IAdminShellService AdminShellService

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - TIPY STEM Admin</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        :root {
            --admin-bg: #f5f7fb;
            --admin-surface: #ffffff;
            --admin-surface-soft: #eef2f8;
            --admin-surface-muted: #e4ecf7;
            --admin-border: #dce6f5;
            --admin-border-strong: #b0c4de;
            --admin-text: #0f1e38;
            --admin-text-muted: #3a4f6e;
            --admin-text-soft: #6b7c99;
            --admin-primary: #1a3a6e;
            --admin-primary-strong: #0f2347;
            --admin-primary-soft: #e8f0fb;
            --admin-danger: #ba1a1a;
            --admin-danger-soft: #ffdad6;
            --admin-warning: #9b682f;
            --admin-warning-soft: #fff4e8;
            --admin-success: #1a3a6e;
            --admin-success-soft: #e8f0fb;
            --admin-shadow: 0 20px 40px rgba(15, 30, 56, 0.08);
            /* Sidebar light theme */
            --sidebar-bg: #ffffff;
            --sidebar-bg2: #f8fafd;
            --sidebar-text: #4a5e7a;
            --sidebar-text-active: #0f1e38;
            --sidebar-hover: rgba(26,58,110,0.05);
            --sidebar-active: rgba(26,58,110,0.1);
            --sidebar-active-border: #f97316;
            --sidebar-border: #dce6f5;
            --sidebar-accent: #f97316;
        }

        .material-symbols-outlined {
            font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
        }

        html, body {
            background: var(--admin-bg);
            color: var(--admin-text);
            font-family: "Inter", sans-serif;
        }

        .admin-shell {
            min-height: 100vh;
            background: var(--admin-bg);
        }

        .admin-sidebar {
            background: linear-gradient(180deg, var(--sidebar-bg) 0%, var(--sidebar-bg2) 100%);
            border-right: 1px solid var(--sidebar-border);
            box-shadow: none;
            transition: transform 0.22s ease, width 0.22s ease;
            width: 17rem;
            z-index: 60;
        }

        .admin-sidebar-backdrop {
            background: rgba(0, 0, 0, 0.45);
            inset: 0;
            opacity: 0;
            pointer-events: none;
            position: fixed;
            transition: opacity 0.2s ease;
            z-index: 55;
        }

        .admin-logo {
            align-items: center;
            display: inline-flex;
            gap: 12px;
        }

        .admin-logo-mark {
            align-items: center;
            border-radius: 50%;
            box-shadow: 0 4px 16px rgba(249,115,22,0.3);
            display: inline-flex;
            height: 48px;
            justify-content: center;
            overflow: hidden;
            width: 48px;
        }

        .admin-logo-mark img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .admin-nav-link {
            align-items: center;
            border-radius: 8px;
            color: var(--sidebar-text);
            display: flex;
            gap: 12px;
            min-height: 44px;
            padding: 10px 14px;
            transition: background-color 0.18s ease, color 0.18s ease;
            font-size: 14px;
            font-weight: 500;
        }

        .admin-nav-link .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
            transition: font-variation-settings 0.18s ease;
        }

        .admin-nav-link:hover {
            background: var(--sidebar-hover);
            color: var(--sidebar-text-active);
        }

        .admin-nav-link:hover .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .admin-nav-link.is-active {
            background: var(--sidebar-active);
            border-left: 3px solid var(--sidebar-active-border);
            color: var(--sidebar-accent);
            font-weight: 600;
            padding-left: 11px;
        }

        .admin-nav-link.is-active .material-symbols-outlined {
            font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24;
        }

        .admin-nav-caption {
            color: rgba(0,0,0,0.3);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.12em;
            padding: 16px 14px 6px;
            text-transform: uppercase;
        }

        .admin-header {
            background: rgba(255,255,255,0.88);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(0,0,0,0.06);
            box-shadow: 0 1px 0 rgba(0,0,0,0.04);
            transition: width 0.22s ease;
        }

        .admin-body {
            margin-left: 17rem;
            min-height: 100vh;
            transition: margin-left 0.22s ease;
        }

        .admin-container {
            margin: 0 auto;
            max-width: none;
            padding: 96px 32px 48px;
            width: 100%;
        }

        .admin-page {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .admin-page-header {
            align-items: center;
            display: flex;
            flex-direction: column;
            gap: 12px;
            justify-content: flex-end;
        }

        @@media (min-width: 1024px) {
            .admin-page-header {
                flex-direction: row;
            }
        }

        .admin-shell.sidebar-open .admin-sidebar-backdrop {
            opacity: 1;
            pointer-events: auto;
        }

        .admin-shell.sidebar-collapsed .admin-sidebar {
            width: 5.5rem;
        }

        .admin-shell.sidebar-collapsed .admin-body {
            margin-left: 5.5rem;
        }

        .admin-shell.sidebar-collapsed .admin-header {
            width: calc(100% - 5.5rem) !important;
        }

        .admin-page-title {
            color: var(--admin-text);
            font-size: 32px;
            font-weight: 600;
            letter-spacing: -0.01em;
            line-height: 40px;
            margin: 0;
        }

        .admin-page-subtitle {
            color: var(--admin-text-soft);
            font-size: 16px;
            line-height: 24px;
            margin-top: 8px;
            max-width: 640px;
        }

        .admin-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .admin-card,
        .admin-card-soft,
        .admin-stat-card {
            border-radius: 8px;
        }

        .admin-card {
            background: var(--admin-surface);
            border: 1px solid var(--admin-border);
        }

        .admin-card-soft {
            background: var(--admin-surface-soft);
            border: 1px solid var(--admin-border);
        }

        .admin-card-section {
            padding: 24px;
        }

        .admin-section-title {
            color: var(--admin-text);
            font-size: 20px;
            font-weight: 600;
            line-height: 28px;
            margin: 0;
        }

        .admin-section-subtitle {
            color: var(--admin-text-soft);
            font-size: 14px;
            line-height: 20px;
            margin-top: 4px;
        }

        .admin-divider {
            border-top: 1px solid var(--admin-border);
        }

        .admin-btn-primary,
        .admin-btn-secondary,
        .admin-btn-danger {
            align-items: center;
            border-radius: 8px;
            display: inline-flex;
            font-size: 14px;
            font-weight: 600;
            gap: 8px;
            height: 48px;
            justify-content: center;
            padding: 0 20px;
            transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
            white-space: nowrap;
        }

        .admin-btn-primary {
            background: var(--admin-primary);
            color: #fff;
        }

        .admin-btn-primary:hover {
            background: var(--admin-primary-strong);
        }

        .admin-btn-secondary {
            background: transparent;
            border: 1px solid var(--admin-border-strong);
            color: var(--admin-text-muted);
        }

        .admin-btn-secondary:hover {
            background: var(--admin-primary-soft);
            border-color: var(--admin-primary);
            color: var(--admin-primary-strong);
        }

        .admin-btn-danger {
            background: var(--admin-danger);
            color: #fff;
        }

        .admin-btn-danger:hover {
            background: #93000a;
        }

        .admin-chip-group {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .admin-chip {
            align-items: center;
            background: transparent;
            border-radius: 9999px;
            border: 1px solid var(--admin-border);
            color: var(--admin-text-soft);
            display: inline-flex;
            font-size: 14px;
            font-weight: 500;
            height: 40px;
            padding: 0 14px;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .admin-chip:hover {
            background: var(--admin-primary-soft);
            border-color: var(--admin-primary);
            color: var(--admin-primary-strong);
        }

        .admin-chip.is-active {
            background: var(--admin-primary-soft);
            border-color: var(--admin-primary);
            color: var(--admin-primary-strong);
            font-weight: 600;
        }

        .admin-toolbar {
            align-items: center;
            display: flex;
            flex-direction: column;
            gap: 16px;
            justify-content: space-between;
        }

        @@media (min-width: 1024px) {
            .admin-toolbar {
                flex-direction: row;
            }
        }

        .admin-input,
        .admin-select,
        .admin-textarea {
            background: var(--admin-surface);
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            color: var(--admin-text);
            font-size: 14px;
            line-height: 20px;
            width: 100%;
        }

        .admin-input,
        .admin-select {
            height: 48px;
            padding: 0 16px;
        }

        .admin-textarea {
            min-height: 128px;
            padding: 12px 16px;
            resize: vertical;
        }

        .admin-input:focus,
        .admin-select:focus,
        .admin-textarea:focus {
            border-color: var(--admin-primary);
            box-shadow: 0 0 0 2px rgba(106, 153, 78, 0.12);
            outline: none;
        }

        .admin-file {
            padding: 10px 12px;
        }

        .admin-file::file-selector-button {
            background: var(--admin-primary-soft);
            border: 0;
            border-radius: 8px;
            color: var(--admin-primary-strong);
            cursor: pointer;
            font-family: "Inter", sans-serif;
            font-size: 14px;
            font-weight: 600;
            margin-right: 12px;
            padding: 10px 14px;
        }

        .admin-label {
            color: var(--admin-text-muted);
            display: block;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.01em;
            line-height: 20px;
            margin-bottom: 8px;
        }

        .admin-checkbox {
            border-color: var(--admin-border-strong);
            border-radius: 4px;
            color: var(--admin-primary);
            height: 18px;
            width: 18px;
        }

        .admin-checkbox:focus {
            --tw-ring-color: rgba(106, 153, 78, 0.16);
        }

        .admin-hint,
        .admin-validation {
            font-size: 14px;
            line-height: 20px;
            margin-top: 8px;
        }

        .admin-hint {
            color: var(--admin-text-soft);
        }

        .admin-validation {
            color: var(--admin-danger);
        }

        .admin-field-validation {
            color: var(--admin-danger);
            display: block;
            font-size: 13px;
            line-height: 18px;
            margin-top: 8px;
        }

        .admin-validation-summary {
            background: #fff4f3;
            border: 1px solid #f0c9c7;
            border-radius: 8px;
            color: #b54740;
            font-size: 14px;
            line-height: 20px;
            padding: 16px;
        }

        .admin-validation-summary ul {
            margin: 0;
            padding-left: 20px;
        }

        .admin-field-grid {
            display: grid;
            gap: 24px;
        }

        @@media (min-width: 768px) {
            .admin-field-grid.two-col {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        .admin-table {
            border-collapse: collapse;
            width: 100%;
        }

        .admin-table thead {
            background: var(--admin-surface-soft);
        }

        .admin-table th {
            color: var(--admin-text-soft);
            font-size: 14px;
            font-weight: 600;
            line-height: 20px;
            padding: 16px 24px;
            text-align: left;
        }

        .admin-table td {
            border-top: 1px solid var(--admin-border);
            color: var(--admin-text-muted);
            font-size: 14px;
            line-height: 20px;
            padding: 20px 24px;
            vertical-align: top;
        }

        .admin-table strong {
            color: var(--admin-text);
        }

        .admin-tag {
            border-radius: 9999px;
            display: inline-flex;
            font-size: 12px;
            font-weight: 600;
            gap: 8px;
            line-height: 16px;
            padding: 8px 12px;
        }

        .admin-tag--success {
            background: var(--admin-success-soft);
            color: var(--admin-success);
        }

        .admin-tag--warning {
            background: var(--admin-warning-soft);
            color: var(--admin-warning);
        }

        .admin-tag--neutral {
            background: var(--admin-surface-muted);
            color: var(--admin-text-muted);
        }

        .admin-tag--danger {
            background: var(--admin-danger-soft);
            color: var(--admin-danger);
        }

        /* ── Compact stat strip ─────────────────────────────── */
        .admin-stat-grid {
            display: grid;
            gap: 12px;
        }

        @@media (min-width: 640px) {
            .admin-stat-grid.four-col {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (min-width: 1024px) {
            .admin-stat-grid.four-col {
                grid-template-columns: repeat(4, minmax(0, 1fr));
            }
        }

        @@media (min-width: 640px) {
            .admin-stat-grid.five-col {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (min-width: 1024px) {
            .admin-stat-grid.five-col {
                grid-template-columns: repeat(5, minmax(0, 1fr));
            }
        }

        .admin-stat-card {
            background: var(--admin-surface);
            border: 1px solid var(--admin-border);
            border-radius: var(--admin-radius);
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            transition: box-shadow 0.15s, border-color 0.15s;
        }

        .admin-stat-card:hover {
            border-color: var(--admin-primary-light, #a8c89a);
            box-shadow: 0 2px 12px rgba(106,153,78,.10);
        }

        .admin-stat-card-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--admin-surface-soft);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .admin-stat-card-body {
            display: flex;
            flex-direction: column;
            gap: 2px;
            min-width: 0;
        }

        .admin-stat-label {
            color: var(--admin-text-soft);
            font-size: 12px;
            font-weight: 500;
            line-height: 16px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .admin-stat-value {
            color: var(--admin-text);
            font-size: 22px;
            font-weight: 700;
            letter-spacing: -0.01em;
            line-height: 28px;
        }

        .admin-static-field {
            align-items: center;
            background: var(--admin-surface-soft);
            border: 1px solid var(--admin-border);
            border-radius: 12px;
            color: var(--admin-text);
            display: flex;
            min-height: 52px;
            padding: 14px 16px;
        }

        .admin-kicker {
            color: var(--admin-text-soft);
            font-size: 14px;
            line-height: 20px;
            margin-top: 8px;
        }

        .admin-empty {
            color: var(--admin-text-soft);
            font-size: 14px;
            line-height: 24px;
            padding: 48px 24px;
            text-align: center;
        }

        .admin-modal {
            background: rgba(26, 28, 25, 0.38);
        }

        .admin-modal-panel,
        .admin-dropdown {
            background: var(--admin-surface);
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            box-shadow: var(--admin-shadow);
        }

        .admin-grid-two {
            display: grid;
            gap: 24px;
        }

        @@media (min-width: 1200px) {
            .admin-grid-two {
                grid-template-columns: minmax(0, 1.65fr) minmax(320px, 1fr);
            }
        }

        @@media (min-width: 1440px) {
            .admin-container {
                padding-left: 40px;
                padding-right: 40px;
            }
        }

        .admin-note-list {
            color: var(--admin-text-muted);
            display: grid;
            gap: 12px;
            font-size: 14px;
            line-height: 24px;
        }

        .admin-alert {
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            line-height: 20px;
            padding: 16px 20px;
        }

        .admin-alert--success {
            background: var(--admin-success-soft);
            border: 1px solid #cfe2c1;
            color: var(--admin-success);
        }

        .admin-alert--error {
            background: #fff4f3;
            border: 1px solid #f0c9c7;
            color: #b54740;
        }

        .admin-data-grid {
            display: grid;
            gap: 24px;
        }

        @@media (min-width: 768px) {
            .admin-data-grid.two-col {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        .admin-data-item dt {
            color: var(--admin-text-muted);
            font-size: 14px;
            font-weight: 500;
            line-height: 20px;
        }

        .admin-data-item dd {
            background: var(--admin-surface-soft);
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            color: var(--admin-text);
            font-size: 14px;
            line-height: 20px;
            margin-top: 8px;
            padding: 14px 16px;
        }

        .admin-detail-label {
            color: var(--admin-text-soft);
            font-size: 13px;
            font-weight: 500;
            line-height: 18px;
        }

        .admin-detail-value {
            color: var(--admin-text);
            font-size: 15px;
            font-weight: 600;
            line-height: 22px;
            margin-top: 6px;
        }

        .admin-detail-subvalue {
            color: var(--admin-text-soft);
            font-size: 13px;
            line-height: 18px;
            margin-top: 4px;
        }

        .admin-menu-button {
            align-items: center;
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            color: var(--admin-text-soft);
            display: inline-flex;
            height: 40px;
            justify-content: center;
            width: 40px;
        }

        .admin-menu-button:hover {
            border-color: var(--admin-primary);
            color: var(--admin-primary-strong);
        }

        .admin-icon-button {
            align-items: center;
            border: 1px solid var(--admin-border);
            border-radius: 9999px;
            color: var(--admin-text-soft);
            display: inline-flex;
            height: 40px;
            justify-content: center;
            position: relative;
            transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
            width: 40px;
        }

        .admin-icon-button:hover {
            background: var(--admin-surface-soft);
            border-color: var(--admin-primary);
            color: var(--admin-primary-strong);
        }

        .admin-badge-dot {
            background: var(--admin-danger);
            border: 2px solid #fff;
            border-radius: 9999px;
            height: 10px;
            position: absolute;
            right: 7px;
            top: 7px;
            width: 10px;
        }

        .admin-menu-item {
            align-items: center;
            color: var(--admin-text-muted);
            display: flex;
            gap: 12px;
            padding: 12px 16px;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .admin-menu-item:hover {
            background: var(--admin-primary-soft);
            color: var(--admin-primary-strong);
        }

        .admin-menu-item--danger {
            color: #c94d48;
        }

        .admin-menu-item--danger:hover {
            background: #fff4f3;
            color: #b54740;
        }

        .admin-checkbox-card {
            align-items: flex-start;
            background: var(--admin-surface-soft);
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            display: flex;
            gap: 12px;
            padding: 16px;
        }

        .admin-checkbox-card input[type="checkbox"] {
            border-radius: 4px;
            border-color: var(--admin-border-strong);
            color: var(--admin-primary);
            margin-top: 3px;
        }

        .admin-checkbox-card input[type="checkbox"]:focus {
            --tw-ring-color: rgba(106, 153, 78, 0.16);
        }

        .admin-preview {
            align-items: center;
            background: var(--admin-surface-soft);
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            display: flex;
            gap: 16px;
            padding: 16px;
        }

        .admin-popover {
            background: var(--admin-surface);
            border: 1px solid var(--admin-border);
            border-radius: 12px;
            box-shadow: var(--admin-shadow);
            min-width: 280px;
            overflow: hidden;
        }

        .admin-popover-header {
            border-bottom: 1px solid var(--admin-border);
            padding: 16px 18px;
        }

        .admin-popover-body {
            padding: 12px;
        }

        .admin-popover-item {
            align-items: flex-start;
            border-radius: 8px;
            color: var(--admin-text-muted);
            display: flex;
            gap: 12px;
            padding: 12px;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .admin-popover-item:hover {
            background: var(--admin-primary-soft);
            color: var(--admin-primary-strong);
        }

        .admin-profile-trigger {
            align-items: center;
            border-radius: 10px;
            display: flex;
            gap: 12px;
            padding: 8px;
            transition: background-color 0.2s ease;
            width: 100%;
        }

        .admin-profile-trigger:hover {
            background: var(--admin-surface-soft);
        }

        .admin-profile-summary {
            color: var(--admin-text-soft);
            font-size: 13px;
            line-height: 18px;
            margin-top: 2px;
        }

        .admin-pagination {
            display: flex;
            gap: 8px;
        }

        .admin-page-link {
            align-items: center;
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            color: var(--admin-text-soft);
            display: inline-flex;
            font-size: 14px;
            font-weight: 600;
            height: 40px;
            justify-content: center;
            min-width: 40px;
            padding: 0 12px;
        }

        .admin-page-link:hover {
            border-color: var(--admin-primary);
            color: var(--admin-primary-strong);
        }

        .admin-page-link.is-active {
            background: var(--admin-primary);
            border-color: var(--admin-primary);
            color: #fff;
        }

        .admin-page-link.is-disabled {
            opacity: 0.5;
            pointer-events: none;
        }

        /* ── Micro-animations ────────────────────────────────────── */
        @@keyframes adminFadeUp {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .admin-page > * {
            animation: adminFadeUp 0.28s ease both;
        }

        .admin-page > *:nth-child(2) { animation-delay: 0.05s; }
        .admin-page > *:nth-child(3) { animation-delay: 0.10s; }
        .admin-page > *:nth-child(4) { animation-delay: 0.14s; }
        .admin-page > *:nth-child(5) { animation-delay: 0.18s; }

        /* Stat card hover lift */
        .admin-stat-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .admin-stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.09);
        }

        /* Sidebar toggle */
        .admin-sidebar-toggle {
            align-items: center;
            background: var(--admin-surface-soft);
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            color: var(--admin-text-soft);
            display: inline-flex;
            height: 36px;
            justify-content: center;
            transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
            width: 36px;
        }

        .admin-sidebar-toggle:hover {
            background: var(--admin-primary-soft);
            border-color: var(--admin-primary);
            color: var(--admin-primary-strong);
        }

        /* Collapsed sidebar hides badge */
        .admin-shell.sidebar-collapsed .admin-nav-badge {
            display: none;
        }

        .admin-shell.sidebar-collapsed .admin-nav-link {
            border-left: none !important;
        }

        /* Admin avatar on dark bg */
        .admin-profile-avatar {
            border: 2px solid rgba(106,153,78,0.45);
            border-radius: 9999px;
            height: 36px;
            object-fit: cover;
            width: 36px;
        }

        .admin-profile-avatar-fallback {
            align-items: center;
            background: rgba(106,153,78,0.22);
            border: 2px solid rgba(106,153,78,0.4);
            border-radius: 9999px;
            color: var(--sidebar-accent);
            display: inline-flex;
            font-size: 13px;
            font-weight: 700;
            height: 36px;
            justify-content: center;
            width: 36px;
        }

        .admin-header-title {
            color: var(--admin-text);
            font-size: 15px;
            font-weight: 600;
            line-height: 20px;
        }

        .admin-shell.sidebar-collapsed .admin-nav-link span:last-child,
        .admin-shell.sidebar-collapsed .admin-profile-meta,
        .admin-shell.sidebar-collapsed .admin-logo-copy {
            display: none;
        }

        .admin-shell.sidebar-collapsed .admin-nav-link {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }

        .admin-shell.sidebar-collapsed .admin-sidebar .px-6,
        .admin-shell.sidebar-collapsed .admin-sidebar .px-4 {
            padding-left: 10px;
            padding-right: 10px;
        }

        .admin-shell.sidebar-collapsed .admin-logo {
            justify-content: center;
            width: 100%;
        }

        .admin-shell.sidebar-collapsed .admin-profile-trigger {
            justify-content: center;
        }

        @@media (max-width: 1023px) {
            .admin-sidebar {
                transform: translateX(-100%);
                width: 17rem;
            }

            .admin-shell.sidebar-open .admin-sidebar {
                transform: translateX(0);
            }

            .admin-body,
            .admin-shell.sidebar-collapsed .admin-body {
                margin-left: 0;
            }

            .admin-header {
                width: 100% !important;
                padding-left: 16px;
                padding-right: 16px;
            }

            .admin-container {
                padding: 88px 16px 32px;
            }
        }

        @@media (max-width: 767px) {
            .admin-card-section,
            .admin-stat-card {
                padding: 16px;
            }

            .admin-stat-card {
                min-height: 120px;
            }

            .admin-stat-value {
                font-size: 28px;
                line-height: 36px;
                margin-top: 16px;
            }

            .admin-page-title {
                font-size: 28px;
                line-height: 36px;
            }

            .admin-page-subtitle {
                font-size: 15px;
                line-height: 22px;
            }

            .admin-header > div:last-child {
                gap: 8px;
            }

            .admin-header > div:last-child .admin-btn-secondary,
            .admin-header > div:last-child .admin-btn-primary {
                min-width: 40px;
                padding-left: 10px !important;
                padding-right: 10px !important;
            }

            .admin-header > div:last-child .admin-btn-secondary span:last-child,
            .admin-header > div:last-child .admin-btn-primary span:last-child {
                display: none;
            }
        }
    </style>
</head>
<body class="admin-shell" data-admin-shell>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var shellState = await AdminShellService.BuildAsync(User);
        var currentUserId = shellState.UserId;
        var currentAdminName = shellState.DisplayName;
        var currentAdminAvatarUrl = shellState.AvatarUrl;
        var todaySessionCount = shellState.TodaySessionCount;
        var openMaintenanceCount = shellState.OpenMaintenanceCount;
        var unpaidInvoiceCount = shellState.UnpaidInvoiceCount;
        var pendingLeadsCount = shellState.PendingLeadsCount;
        var notificationCount = shellState.NotificationCount;
        string NavClass(string controller) => currentController == controller ? "admin-nav-link is-active" : "admin-nav-link";
    }

    <div class="admin-sidebar-backdrop" data-admin-sidebar-backdrop></div>

    <aside class="admin-sidebar fixed left-0 top-0 flex h-screen flex-col py-6">
        <div class="mb-6 flex items-center justify-between px-5 pt-2">
            <div class="admin-logo">
                <div class="admin-logo-mark">
                    <img src="/images/team/TIPY.jpg" alt="TIPY STEM" />
                </div>
                <div>
                    <div style="color:#1a3a6e;font-size:1rem;font-weight:700;letter-spacing:-0.02em;">TIPY STEM</div>
                </div>
            </div>
        </div>

        <nav class="flex-1 overflow-y-auto px-4">
            <div class="flex flex-col gap-1">
                <a class="@NavClass("Dashboard")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">dashboard</span>
                    <span>Tổng quan</span>
                </a>
                <a class="@NavClass("Users")" asp-area="Admin" asp-controller="Users" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">group</span>
                    <span>Người dùng</span>
                </a>
                <a class="@NavClass("Courses")" asp-area="Admin" asp-controller="Courses" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">school</span>
                    <span>Khóa học</span>
                </a>
                <a class="@NavClass("Classes")" asp-area="Admin" asp-controller="Classes" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">class</span>
                    <span>Lớp học</span>
                </a>
                <a class="@NavClass("Sessions")" asp-area="Admin" asp-controller="Sessions" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">event_note</span>
                    <span>Buổi học</span>
                </a>
                <a class="@NavClass("Attendances")" asp-area="Admin" asp-controller="Attendances" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">fact_check</span>
                    <span>Điểm danh</span>
                </a>
                <a class="@NavClass("Finance")" asp-area="Admin" asp-controller="Finance" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">payments</span>
                    <span>Tài chính</span>
                </a>
                <a class="@NavClass("Inventory")" asp-area="Admin" asp-controller="Inventory" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">inventory_2</span>
                    <span>Kho thiết bị</span>
                </a>
                <a class="@NavClass("Leads")" asp-area="Admin" asp-controller="Leads" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">support_agent</span>
                    <span class="flex-1">Khách tư vấn</span>
                    @if (pendingLeadsCount > 0)
                    {
                        <span class="admin-nav-badge flex h-5 items-center justify-center rounded-full bg-[#ba1a1a] px-2 text-[11px] font-medium text-white">@pendingLeadsCount</span>
                    }
                </a>
                <a class="@NavClass("Cms")" asp-area="Admin" asp-controller="Cms" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">article</span>
                    <span>CMS</span>
                </a>
                <a class="@NavClass("Settings")" asp-area="Admin" asp-controller="Settings" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">settings</span>
                    <span>Điều hành</span>
                </a>
            </div>
        </nav>

        <div class="mt-auto border-t px-4 pt-5" style="border-color: var(--sidebar-border)">
            <details class="relative">
                <summary class="admin-profile-trigger list-none cursor-pointer">
                    @if (!string.IsNullOrWhiteSpace(currentAdminAvatarUrl))
                    {
                        <img alt="@currentAdminName" class="admin-profile-avatar" src="@currentAdminAvatarUrl" />
                    }
                    else
                    {
                        <div class="admin-profile-avatar-fallback">
                            @currentAdminName.Trim()[0].ToString().ToUpperInvariant()
                        </div>
                    }
                    <div class="admin-profile-meta min-w-0 flex-1">
                        <p class="truncate text-sm font-semibold text-[#1a1c19]">@currentAdminName</p>
                        <p class="admin-profile-summary">Quản trị viên</p>
                    </div>
                    <span class="material-symbols-outlined text-[18px] text-[#73796b]">expand_more</span>
                </summary>

                <div class="admin-popover absolute bottom-[calc(100%+12px)] left-0 right-0 z-30">
                    <div class="admin-popover-header">
                        <p class="text-sm font-semibold text-[#1a1c19]">@currentAdminName</p>
                        <p class="mt-1 text-xs text-[#73796b]">Tài khoản quản trị</p>
                    </div>
                    <div class="admin-popover-body">
                        @if (currentUserId.HasValue)
                        {
                            <a asp-area="Admin" asp-controller="Users" asp-action="Details" asp-route-id="@currentUserId.Value" class="admin-popover-item">
                                <span class="material-symbols-outlined text-[20px]">badge</span>
                                <span>
                                    <span class="block text-sm font-medium text-[#1a1c19]">Thông tin tài khoản</span>
                                    <span class="mt-1 block text-xs text-[#73796b]">Xem nhanh hồ sơ của bạn</span>
                                </span>
                            </a>
                            <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@currentUserId.Value" class="admin-popover-item">
                                <span class="material-symbols-outlined text-[20px]">edit_square</span>
                                <span>
                                    <span class="block text-sm font-medium text-[#1a1c19]">Cập nhật hồ sơ</span>
                                    <span class="mt-1 block text-xs text-[#73796b]">Đổi ảnh, tên hiển thị hoặc mật khẩu</span>
                                </span>
                            </a>
                        }
                    </div>
                </div>
            </details>
        </div>
    </aside>

    <main class="admin-body">
        <header class="admin-header fixed right-0 top-0 z-40 flex h-16 w-[calc(100%-17rem)] items-center justify-between px-8 text-sm">
            <div class="flex items-center gap-3">
                <button type="button" class="admin-sidebar-toggle" data-admin-sidebar-toggle aria-label="Thu gọn menu">
                    <span class="material-symbols-outlined text-[18px]">menu</span>
                </button>
                <span class="admin-header-title">@ViewData["Title"]</span>
            </div>

            <div class="flex items-center gap-3">
                <details class="relative">
                    <summary class="admin-icon-button list-none cursor-pointer" title="Thông báo">
                        <span class="material-symbols-outlined text-[20px]">notifications</span>
                        @if (notificationCount > 0)
                        {
                            <span class="admin-badge-dot"></span>
                        }
                    </summary>
                    <div class="admin-popover absolute right-0 top-[calc(100%+12px)] z-30">
                        <div class="admin-popover-header">
                            <p class="text-sm font-semibold text-[#1a1c19]">Thông báo nhanh</p>
                            <p class="mt-1 text-xs text-[#73796b]">Các mục cần kiểm tra trong ngày.</p>
                        </div>
                        <div class="admin-popover-body">
                            <a asp-area="Admin" asp-controller="Sessions" asp-action="Index" class="admin-popover-item">
                                <span class="material-symbols-outlined text-[20px]">event</span>
                                <span>
                                    <span class="block text-sm font-medium text-[#1a1c19]">@todaySessionCount buổi học trong ngày</span>
                                    <span class="mt-1 block text-xs text-[#73796b]">Mở lịch buổi học</span>
                                </span>
                            </a>
                            <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="admin-popover-item">
                                <span class="material-symbols-outlined text-[20px]">construction</span>
                                <span>
                                    <span class="block text-sm font-medium text-[#1a1c19]">@openMaintenanceCount thiết bị đang xử lý</span>
                                    <span class="mt-1 block text-xs text-[#73796b]">Mở kho thiết bị</span>
                                </span>
                            </a>
                            <a asp-area="Admin" asp-controller="Finance" asp-action="Index" asp-route-filter="unpaid" class="admin-popover-item">
                                <span class="material-symbols-outlined text-[20px]">receipt_long</span>
                                <span>
                                    <span class="block text-sm font-medium text-[#1a1c19]">@unpaidInvoiceCount hóa đơn cần theo dõi</span>
                                    <span class="mt-1 block text-xs text-[#73796b]">Mở danh sách công nợ</span>
                                </span>
                            </a>
                        </div>
                    </div>
                </details>

                <details class="relative" id="admin-help-details">
                    <summary class="admin-icon-button list-none cursor-pointer" title="Trợ giúp">
                        <span class="material-symbols-outlined text-[20px]">help</span>
                    </summary>
                    <div class="admin-popover absolute right-0 top-[calc(100%+12px)] z-[200]" style="min-width:280px;">
                        <div class="admin-popover-header">
                            <p class="text-sm font-semibold text-[#0f1e38]">Trợ giúp nhanh</p>
                            <p class="mt-1 text-xs text-[#6b7c99]">Mở nhanh các khu vực thường dùng.</p>
                        </div>
                        <div class="admin-popover-body">
                            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="admin-popover-item">
                                <span class="material-symbols-outlined text-[20px]">group</span>
                                <span>
                                    <span class="block text-sm font-medium text-[#0f1e38]">Người dùng</span>
                                    <span class="mt-1 block text-xs text-[#6b7c99]">Tài khoản, vai trò và trạng thái</span>
                                </span>
                            </a>
                            <a asp-area="Admin" asp-controller="Classes" asp-action="Index" class="admin-popover-item">
                                <span class="material-symbols-outlined text-[20px]">class</span>
                                <span>
                                    <span class="block text-sm font-medium text-[#0f1e38]">Lớp học</span>
                                    <span class="mt-1 block text-xs text-[#6b7c99]">Lịch khai giảng và giáo viên</span>
                                </span>
                            </a>
                            <a asp-area="Admin" asp-controller="Settings" asp-action="Index" class="admin-popover-item">
                                <span class="material-symbols-outlined text-[20px]">settings</span>
                                <span>
                                    <span class="block text-sm font-medium text-[#0f1e38]">Điều hành</span>
                                    <span class="mt-1 block text-xs text-[#6b7c99]">Đi đến trung tâm điều hành quản trị</span>
                                </span>
                            </a>
                        </div>
                    </div>
                </details>

                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" data-confirm-title="Đăng xuất" data-confirm-message="Bạn có muốn đăng xuất khỏi khu vực quản trị không?" data-confirm-submit-text="Đăng xuất">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="admin-icon-button" title="Đăng xuất">
                        <span class="material-symbols-outlined text-[20px]">logout</span>
                    </button>
                </form>
            </div>
        </header>

        <div class="admin-container">
            @RenderBody()
        </div>
    </main>

    <div id="admin-confirm-modal" class="admin-modal fixed inset-0 z-[100] hidden items-center justify-center px-4">
        <div class="admin-modal-panel w-full max-w-md p-6">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 id="admin-confirm-title" class="admin-section-title">Xác nhận</h2>
                    <p id="admin-confirm-message" class="admin-section-subtitle !mt-2">Bạn có chắc muốn tiếp tục không?</p>
                </div>
                <button id="admin-confirm-close" type="button" class="admin-btn-secondary !h-10 !w-10 !px-0">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>
            </div>

            <div class="mt-6 flex justify-end gap-3">
                <button id="admin-confirm-cancel" type="button" class="admin-btn-secondary">Hủy</button>
                <button id="admin-confirm-submit" type="button" class="admin-btn-danger">Xác nhận</button>
            </div>
        </div>
    </div>

    <script>
        (() => {
            const shell = document.querySelector("[data-admin-shell]");
            const toggle = document.querySelector("[data-admin-sidebar-toggle]");
            const backdrop = document.querySelector("[data-admin-sidebar-backdrop]");
            const headerTitle = document.querySelector(".admin-header-title");
            const mediaQuery = window.matchMedia("(max-width: 1023px)");

            if (shell && toggle) {
                const storageKey = "admin-sidebar-collapsed";

                const syncLayout = () => {
                    if (mediaQuery.matches) {
                        shell.classList.remove("sidebar-collapsed");
                    } else if (window.localStorage.getItem(storageKey) === "true") {
                        shell.classList.add("sidebar-collapsed");
                    }
                };

                syncLayout();

                toggle.addEventListener("click", () => {
                    if (mediaQuery.matches) {
                        shell.classList.toggle("sidebar-open");
                        return;
                    }

                    const nextCollapsed = !shell.classList.contains("sidebar-collapsed");
                    shell.classList.toggle("sidebar-collapsed", nextCollapsed);
                    window.localStorage.setItem(storageKey, String(nextCollapsed));
                });

                backdrop?.addEventListener("click", () => {
                    shell.classList.remove("sidebar-open");
                });

                mediaQuery.addEventListener("change", () => {
                    shell.classList.remove("sidebar-open");
                    syncLayout();
                });
            }

            document.querySelectorAll(".admin-page-header").forEach((header) => {
                const titleBlock = header.firstElementChild;
                if (!(titleBlock instanceof HTMLElement)) {
                    return;
                }

                if (!titleBlock.querySelector(".admin-page-title") && !titleBlock.querySelector(".admin-page-subtitle")) {
                    return;
                }

                const pageTitle = titleBlock.querySelector(".admin-page-title");
                if (headerTitle && pageTitle) {
                    headerTitle.textContent = pageTitle.textContent?.trim() || headerTitle.textContent;
                }

                titleBlock.remove();

                if (!header.children.length) {
                    header.remove();
                }
            });

            const modal = document.getElementById("admin-confirm-modal");
            const title = document.getElementById("admin-confirm-title");
            const message = document.getElementById("admin-confirm-message");
            const submitButton = document.getElementById("admin-confirm-submit");
            const cancelButton = document.getElementById("admin-confirm-cancel");
            const closeButton = document.getElementById("admin-confirm-close");

            if (!modal || !title || !message || !submitButton || !cancelButton || !closeButton) {
                return;
            }

            let pendingForm = null;

            const closeModal = () => {
                modal.classList.add("hidden");
                modal.classList.remove("flex");
                pendingForm = null;
            };

            document.addEventListener("submit", (event) => {
                const form = event.target;
                if (!(form instanceof HTMLFormElement) || !form.hasAttribute("data-confirm-message")) {
                    return;
                }

                if (form.dataset.confirmApproved === "true") {
                    form.dataset.confirmApproved = "false";
                    return;
                }

                event.preventDefault();
                pendingForm = form;
                title.textContent = form.getAttribute("data-confirm-title") || "Xác nhận";
                message.textContent = form.getAttribute("data-confirm-message") || "Bạn có chắc muốn tiếp tục không?";
                submitButton.textContent = form.getAttribute("data-confirm-submit-text") || "Xác nhận";
                modal.classList.remove("hidden");
                modal.classList.add("flex");
            });

            submitButton.addEventListener("click", () => {
                if (!pendingForm) {
                    closeModal();
                    return;
                }

                pendingForm.dataset.confirmApproved = "true";
                pendingForm.requestSubmit();
            });

            cancelButton.addEventListener("click", closeModal);
            closeButton.addEventListener("click", closeModal);

            modal.addEventListener("click", (event) => {
                if (event.target === modal) {
                    closeModal();
                }
            });

            document.addEventListener("keydown", (event) => {
                if (event.key === "Escape" && !modal.classList.contains("hidden")) {
                    closeModal();
                }
            });
            // ── Table Action Dropdown – định vị bằng fixed để thoát overflow:hidden ──
            (() => {
                // Dropdown panel cố định duy nhất được inject vào body
                const panel = document.createElement('div');
                panel.id = 'table-action-panel';
                panel.className = 'admin-dropdown';
                panel.style.cssText = 'position:fixed;z-index:9999;min-width:11rem;display:none;';
                document.body.appendChild(panel);

                let activeDetails = null;

                // Mở panel tại vị trí nút
                function openPanel(details) {
                    const menu = details.querySelector('[data-table-menu]');
                    if (!menu) return;

                    // Clone nội dung menu vào panel cố định
                    panel.innerHTML = menu.innerHTML;

                    // Tính toán vị trí
                    const btn = details.querySelector('summary');
                    const rect = btn.getBoundingClientRect();
                    const panelW = 176; // w-44 = 11rem = 176px
                    const spaceBelow = window.innerHeight - rect.bottom;

                    panel.style.display = 'block';

                    // Ưu tiên hiện bên dưới, nếu không đủ chỗ thì hiện phía trên
                    if (spaceBelow >= 140) {
                        panel.style.top = (rect.bottom + 4) + 'px';
                    } else {
                        panel.style.top = (rect.top - panel.offsetHeight - 4) + 'px';
                    }

                    // Căn phải theo nút, nhưng không vượt trái màn hình
                    let left = rect.right - panelW;
                    if (left < 8) left = 8;
                    panel.style.left = left + 'px';

                    activeDetails = details;
                }

                function closePanel() {
                    panel.style.display = 'none';
                    if (activeDetails) {
                        activeDetails.removeAttribute('open');
                        activeDetails = null;
                    }
                }

                // Lắng nghe tất cả <details> có data-table-action
                document.addEventListener('toggle', (e) => {
                    const details = e.target;
                    if (!(details instanceof HTMLElement) || !details.hasAttribute('data-table-action')) return;

                    if (details.open) {
                        // Đóng panel cũ nếu có
                        if (activeDetails && activeDetails !== details) {
                            activeDetails.removeAttribute('open');
                        }
                        openPanel(details);
                    } else {
                        closePanel();
                    }
                }, true);

                // Đóng khi click ra ngoài
                document.addEventListener('click', (e) => {
                    if (activeDetails && !activeDetails.contains(e.target) && !panel.contains(e.target)) {
                        closePanel();
                    }
                });

                // Đóng khi scroll hoặc resize
                window.addEventListener('scroll', closePanel, true);
                window.addEventListener('resize', closePanel);
            })();

            document.addEventListener('click', (e) => {
                const panel = document.getElementById('table-action-panel');
                if (!panel || panel.style.display === 'none') return;
                // Cho phép click bên trong panel hoạt động bình thường
            });

            // Generic script to close all open <details> (popovers, dropdowns) when clicking outside
            document.addEventListener('click', (e) => {
                const openDetails = document.querySelectorAll('details[open]');
                openDetails.forEach((details) => {
                    if (!details.contains(e.target) && !details.hasAttribute('data-table-action')) {
                        details.removeAttribute('open');
                    }
                });
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
