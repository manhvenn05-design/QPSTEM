@model STEM.Web.Areas.Admin.Models.FinanceManagementViewModel

@{
    ViewData["Title"] = "Tài chính";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Quản lý tài chính</h1>
            <p class="admin-page-subtitle">Theo dõi hóa đơn và lịch sử thanh toán.</p>
        </div>

        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Finance" asp-action="CreatePayment" class="admin-btn-secondary">Ghi nhận thanh toán</a>
            <a asp-area="Admin" asp-controller="Finance" asp-action="CreateInvoice" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">add</span>
                <span>Tạo hóa đơn</span>
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="admin-alert admin-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="admin-alert admin-alert--error">@errorMessage</div>
    }

    <div class="admin-stat-grid four-col">
        <article class="admin-stat-card">
            <span class="admin-stat-label">Đã thu</span>
            <div class="admin-stat-value">@Model.TotalRevenue.ToString("N0")đ</div>
            <p class="admin-kicker">Tổng tiền đã ghi nhận.</p>
        </article>
        <article class="admin-stat-card">
            <span class="admin-stat-label">Còn phải thu</span>
            <div class="admin-stat-value">@Model.TotalOutstanding.ToString("N0")đ</div>
            <p class="admin-kicker">Công nợ còn lại của học viên.</p>
        </article>
        <article class="admin-stat-card">
            <span class="admin-stat-label">Hóa đơn chưa thu</span>
            <div class="admin-stat-value">@Model.UnpaidInvoiceCount</div>
            <p class="admin-kicker">Cần theo dõi thêm.</p>
        </article>
        <article class="admin-stat-card">
            <span class="admin-stat-label">Lượt thanh toán</span>
            <div class="admin-stat-value">@Model.PaymentCount</div>
            <p class="admin-kicker">Tổng giao dịch đã lưu.</p>
        </article>
    </div>

    <form method="get" asp-area="Admin" asp-controller="Finance" asp-action="Index" class="admin-card">
        <div class="admin-card-section">
            <div class="admin-toolbar">
                <div class="admin-chip-group">
                    @foreach (var filter in Model.Filters)
                    {
                        var isActive = filter.Key == Model.SelectedFilter;
                        <a asp-area="Admin"
                           asp-controller="Finance"
                           asp-action="Index"
                           asp-route-filter="@filter.Key"
                           asp-route-q="@Model.SearchTerm"
                           class="@(isActive ? "admin-chip is-active" : "admin-chip")">
                            @filter.Label
                        </a>
                    }
                </div>

                <div class="w-full lg:max-w-md">
                    <input type="hidden" name="filter" value="@Model.SelectedFilter" />
                    <label class="relative block">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-[20px] text-[#73796b]">search</span>
                        <input type="text" name="q" value="@Model.SearchTerm" placeholder="Tìm theo số hóa đơn, học viên hoặc lớp..." class="admin-input pl-12" />
                    </label>
                </div>
            </div>
        </div>
    </form>

    <div class="grid gap-6 xl:grid-cols-[1.55fr_1fr]">
        <div class="admin-card overflow-hidden">
            <div class="admin-card-section">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <h2 class="admin-section-title">Danh sách hóa đơn</h2>
                        <p class="admin-section-subtitle">Chọn hóa đơn để xem công nợ và lịch sử thu tiền.</p>
                    </div>
                    <a asp-area="Admin" asp-controller="Finance" asp-action="CreateInvoice" class="admin-btn-secondary !h-10">Thêm</a>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="admin-table min-w-full">
                    <thead>
                        <tr>
                            <th>Hóa đơn</th>
                            <th>Học viên</th>
                            <th>Đã thu / Còn lại</th>
                            <th>Trạng thái</th>
                            <th class="text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Invoices.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="admin-empty">Chưa có hóa đơn phù hợp với bộ lọc hiện tại.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var invoice in Model.Invoices)
                            {
                                <tr>
                                    <td>
                                        <div>
                                            <p class="font-semibold text-[#1a1c19]">@invoice.InvoiceNo</p>
                                            <p class="mt-1 text-sm text-[#73796b]">@invoice.ClassCode</p>
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <p class="font-semibold text-[#1a1c19]">@invoice.StudentName</p>
                                            <p class="mt-1 text-sm text-[#73796b]">@invoice.StudentUsername</p>
                                        </div>
                                    </td>
                                    <td>
                                        <p class="font-semibold text-[#1a1c19]">@invoice.PaidAmountText</p>
                                        <p class="mt-1 text-sm text-[#73796b]">Còn @invoice.DueAmountText</p>
                                    </td>
                                    <td>
                                        <span class="inline-flex rounded-full px-3 py-2 text-xs font-semibold @invoice.StatusBadgeClass">
                                            @invoice.StatusLabel
                                        </span>
                                    </td>
                                    <td>
                                        <div class="flex justify-end">
                                            <details class="relative">
                                                <summary class="admin-menu-button cursor-pointer list-none">
                                                    <span class="material-symbols-outlined text-[18px]">more_horiz</span>
                                                </summary>
                                                <div class="admin-dropdown absolute right-0 top-11 z-20 w-44 overflow-hidden">
                                                    <a asp-area="Admin" asp-controller="Finance" asp-action="InvoiceDetails" asp-route-id="@invoice.Id" class="admin-menu-item">
                                                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                                                        <span>Chi tiết</span>
                                                    </a>
                                                    <a asp-area="Admin" asp-controller="Finance" asp-action="EditInvoice" asp-route-id="@invoice.Id" class="admin-menu-item">
                                                        <span class="material-symbols-outlined text-[18px]">edit</span>
                                                        <span>Cập nhật</span>
                                                    </a>
                                                    <a asp-area="Admin" asp-controller="Finance" asp-action="CreatePayment" asp-route-invoiceId="@invoice.Id" class="admin-menu-item">
                                                        <span class="material-symbols-outlined text-[18px]">payments</span>
                                                        <span>Thu tiền</span>
                                                    </a>
                                                    <form asp-area="Admin" asp-controller="Finance" asp-action="DeleteInvoice" asp-route-id="@invoice.Id" method="post" data-confirm-title="Xóa hóa đơn" data-confirm-message="Xóa hóa đơn này? Hành động này không thể hoàn tác." data-confirm-submit-text="Xóa hóa đơn">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="admin-menu-item admin-menu-item--danger w-full text-left">
                                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                                            <span>Xóa</span>
                                                        </button>
                                                    </form>
                                                </div>
                                            </details>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="admin-card overflow-hidden">
            <div class="admin-card-section">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <h2 class="admin-section-title">Thanh toán gần đây</h2>
                        <p class="admin-section-subtitle">Theo dõi các khoản đã ghi nhận.</p>
                    </div>
                    <a asp-area="Admin" asp-controller="Finance" asp-action="CreatePayment" class="admin-btn-secondary !h-10">Thêm</a>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="admin-table min-w-full">
                    <thead>
                        <tr>
                            <th>Hóa đơn</th>
                            <th>Số tiền</th>
                            <th>Thời gian</th>
                            <th class="text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Payments.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="admin-empty">Chưa có thanh toán nào.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var payment in Model.Payments)
                            {
                                <tr>
                                    <td>
                                        <div>
                                            <p class="font-semibold text-[#1a1c19]">@payment.InvoiceNo</p>
                                            <p class="mt-1 text-sm text-[#73796b]">@payment.StudentName</p>
                                        </div>
                                    </td>
                                    <td>
                                        <p class="font-semibold text-[#1a1c19]">@payment.AmountText</p>
                                        <p class="mt-1 text-sm text-[#73796b]">@payment.PaymentMethod</p>
                                    </td>
                                    <td>@payment.TransDateText</td>
                                    <td>
                                        <div class="flex justify-end gap-2">
                                            <a asp-area="Admin" asp-controller="Finance" asp-action="PaymentDetails" asp-route-id="@payment.Id" class="admin-btn-secondary !h-10">Chi tiết</a>
                                            <a asp-area="Admin" asp-controller="Finance" asp-action="EditPayment" asp-route-id="@payment.Id" class="admin-btn-secondary !h-10">Sửa</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
