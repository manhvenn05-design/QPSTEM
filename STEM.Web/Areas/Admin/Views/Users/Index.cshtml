@model STEM.Web.Areas.Admin.Models.UserManagementViewModel

@{
    ViewData["Title"] = "Người dùng";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Quản lý người dùng</h1>
            <p class="admin-page-subtitle">Quản lý tài khoản, phân quyền và trạng thái truy cập của người dùng trong hệ thống.</p>
        </div>

        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Users" asp-action="Create" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">add</span>
                <span>Thêm người dùng mới</span>
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="admin-alert admin-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="admin-alert admin-alert--error">@errorMessage</div>
    }

    <form method="get" asp-area="Admin" asp-controller="Users" asp-action="Index" class="admin-card">
        <div class="admin-card-section">
            <div class="admin-toolbar">
                <div class="admin-chip-group">
                    @foreach (var filter in Model.Filters)
                    {
                        var isActive = filter.Key == Model.SelectedRole;
                        <a asp-area="Admin"
                           asp-controller="Users"
                           asp-action="Index"
                           asp-route-role="@filter.Key"
                           asp-route-q="@Model.SearchTerm"
                           class="@(isActive ? "admin-chip is-active" : "admin-chip")">
                            @filter.Label
                        </a>
                    }
                </div>

                <div class="w-full lg:max-w-sm">
                    <input type="hidden" name="role" value="@Model.SelectedRole" />
                    <label class="relative block">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-[20px] text-[#73796b]">search</span>
                        <input type="text" name="q" value="@Model.SearchTerm" placeholder="Tìm kiếm người dùng..." class="admin-input pl-12" />
                    </label>
                </div>
            </div>
        </div>
    </form>

    <div class="admin-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="admin-table min-w-full">
                <thead>
                    <tr>
                        <th>Người dùng</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Ngày tham gia</th>
                        <th class="text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>
                                <div class="flex items-center gap-4">
                                    @if (!string.IsNullOrWhiteSpace(user.AvatarUrl))
                                    {
                                        <img src="@user.AvatarUrl" alt="@user.Name" class="h-11 w-11 rounded-full border border-[#e3e3de] object-cover" />
                                    }
                                    else
                                    {
                                        <div class="flex h-11 w-11 items-center justify-center rounded-full text-lg font-semibold @user.AvatarClass">
                                            @user.AvatarText
                                        </div>
                                    }

                                    <div>
                                        <p class="font-semibold text-[#1a1c19]">@user.Name</p>
                                        <p class="mt-1 text-sm text-[#73796b]">@user.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="inline-flex rounded-full px-3 py-2 text-xs font-semibold @user.RoleBadgeClass">@user.Role</span>
                            </td>
                            <td>
                                <span class="inline-flex items-center gap-2 rounded-full px-3 py-2 text-xs font-semibold @user.StatusBadgeClass">
                                    <span class="h-2 w-2 rounded-full @(user.Status == "Hoạt động" ? "bg-[#1a3a6e]" : "bg-[#ba1a1a]")"></span>
                                    @user.Status
                                </span>
                            </td>
                            <td class="text-[#42493d]">@user.JoinedAt</td>
                            <td>
                                <div class="flex justify-end">
                                    <details class="relative" data-table-action>
                                        <summary class="admin-menu-button cursor-pointer list-none">
                                            <span class="material-symbols-outlined text-[18px]">more_horiz</span>
                                        </summary>
                                        <div data-table-menu class="hidden">
                                            <a asp-area="Admin" asp-controller="Users" asp-action="Details" asp-route-id="@user.Id" class="admin-menu-item">
                                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                                                <span>Chi tiết</span>
                                            </a>
                                            <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id" class="admin-menu-item">
                                                <span class="material-symbols-outlined text-[18px]">edit</span>
                                                <span>Cập nhật</span>
                                            </a>
                                            @* Khóa/Mở khóa — hành động an toàn, có thể hoàn tác *@
                                            <form asp-area="Admin" asp-controller="Users" asp-action="ToggleLock" asp-route-id="@user.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="admin-menu-item admin-menu-item--danger w-full text-left">
                                                    @if (user.Status == "Hoạt động")
                                                    {
                                                        <span class="material-symbols-outlined text-[18px]">lock</span>
                                                        <span>Khóa tài khoản</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="material-symbols-outlined text-[18px]">lock_open</span>
                                                        <span>Mở khóa tài khoản</span>
                                                    }
                                                </button>
                                            </form>
                                            @* Phân cách — bên dưới là hành động không thể hoàn tác *@
                                            <div class="my-1 border-t border-[#e8ece3]"></div>
                                            <form asp-area="Admin" asp-controller="Users" asp-action="Delete" asp-route-id="@user.Id" method="post" data-confirm-title="Xóa người dùng" data-confirm-message="Chỉ xóa được nếu tài khoản chưa có dữ liệu. Nếu có dữ liệu hãy dùng 'Khóa tài khoản'." data-confirm-submit-text="Xóa người dùng">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="admin-menu-item admin-menu-item--danger w-full text-left">
                                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                                    <span>Xóa tài khoản</span>
                                                </button>
                                            </form>
                                            <button type="button"
                                                    class="admin-menu-item admin-menu-item--danger w-full text-left"
                                                    data-purge-id="@user.Id"
                                                    data-purge-name="@user.Name"
                                                    data-purge-username="@user.Username">
                                                <span class="material-symbols-outlined text-[18px]">delete_forever</span>
                                                <span>Xóa toàn bộ dữ liệu</span>
                                            </button>
                                        </div>
                                    </details>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-divider flex flex-col gap-4 px-6 py-5 text-sm text-[#73796b] lg:flex-row lg:items-center lg:justify-between">
            <p>Hiển thị 1-@Model.Users.Count trong số @Model.TotalUsers người dùng</p>

            <div class="admin-pagination">
                <button type="button" class="admin-page-link">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </button>
                <span class="admin-page-link is-active">1</span>
                <button type="button" class="admin-page-link">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
</section>

@* Modal xác nhận Xóa toàn bộ dữ liệu *@
<div id="purge-modal" class="admin-modal fixed inset-0 z-[100] hidden items-center justify-center px-4">
    <div class="admin-modal-panel w-full max-w-md p-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="admin-section-title text-[#b54740]">Xóa toàn bộ dữ liệu</h2>
                <p id="purge-desc" class="admin-section-subtitle !mt-2"></p>
            </div>
            <button id="purge-close" type="button" class="admin-btn-secondary !h-10 !w-10 !px-0">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
        </div>

        <div class="mt-4 flex gap-3 rounded-[8px] bg-[#fff4f3] border border-[#f0c9c7] p-4 text-sm text-[#b54740]">
            <span class="material-symbols-outlined shrink-0 text-[20px]">warning</span>
            <div>
                Hành động này sẽ xóa <strong>toàn bộ</strong> dữ liệu: điểm danh, minh chứng, đăng ký lớp, hóa đơn, thanh toán và tài khoản. Không thể hoàn tác.
            </div>
        </div>

        <div class="mt-4">
            <label class="text-sm font-medium text-[#42493d]">Nhập tên đăng nhập để xác nhận:</label>
            <input id="purge-confirm-input" type="text" placeholder="username" autocomplete="off"
                   class="admin-input mt-2 w-full" />
        </div>

        <form id="purge-form" asp-area="Admin" asp-controller="Users" asp-action="Purge" method="post" class="mt-6 flex justify-end gap-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="purge-user-id" />
            <input type="hidden" name="confirmUsername" id="purge-confirm-username" />
            <button type="button" id="purge-cancel" class="admin-btn-secondary">Hủy</button>
            <button type="submit" id="purge-submit" class="admin-btn-danger" disabled>Xóa toàn bộ</button>
        </form>
    </div>
</div>

@section Scripts {
<script>
    (() => {
        const modal   = document.getElementById('purge-modal');
        const desc    = document.getElementById('purge-desc');
        const input   = document.getElementById('purge-confirm-input');
        const userId  = document.getElementById('purge-user-id');
        const confirmHidden = document.getElementById('purge-confirm-username');
        const submit  = document.getElementById('purge-submit');

        let expectedUsername = '';

        function openPurge(id, name, username) {
            expectedUsername = username;
            userId.value = id;
            desc.textContent = `Bạn đang chuẩn bị xóa toàn bộ dữ liệu của "${name}" (${username}).`;
            input.value = '';
            submit.disabled = true;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => input.focus(), 100);
        }

        function closePurge() {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        // Mở modal khi click nút trong panel
        document.addEventListener('click', e => {
            const btn = e.target.closest('[data-purge-id]');
            if (!btn) return;
            openPurge(
                btn.dataset.purgeId,
                btn.dataset.purgeName,
                btn.dataset.purgeUsername
            );
        });

        document.getElementById('purge-close').addEventListener('click', closePurge);
        document.getElementById('purge-cancel').addEventListener('click', closePurge);
        modal.addEventListener('click', e => { if (e.target === modal) closePurge(); });

        // Enable nút xóa khi nhập đúng username
        input.addEventListener('input', () => {
            const match = input.value.trim().toLowerCase() === expectedUsername.toLowerCase();
            submit.disabled = !match;
            if (match) confirmHidden.value = input.value.trim();
        });

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape' && !modal.classList.contains('hidden')) closePurge();
        });
    })();
</script>
}
