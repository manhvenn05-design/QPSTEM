@model STEM.Web.Areas.Admin.Models.CreateUserViewModel

@{
    ViewData["Title"] = "Thêm người dùng";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Thêm người dùng mới</h1>
            <p class="admin-page-subtitle">Tạo tài khoản, tải ảnh đại diện và phân quyền người dùng theo đúng dữ liệu hiện có của hệ thống.</p>
        </div>

        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="admin-btn-secondary">Quay lại danh sách</a>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Users" asp-action="Create" method="post" enctype="multipart/form-data" class="admin-page">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="admin-alert admin-alert--error"></div>

        <div class="admin-card">
            <div class="admin-card-section">
                <div class="mb-6">
                    <h2 class="admin-section-title">Thông tin tài khoản</h2>
                    <p class="admin-section-subtitle">Nhập thông tin cơ bản, ảnh đại diện, vai trò và trạng thái truy cập.</p>
                </div>

                <div class="admin-field-grid two-col">
                    <div class="md:col-span-2">
                        <label asp-for="FullName" class="admin-label"></label>
                        <input asp-for="FullName" class="admin-input" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="FullName" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="Username" class="admin-label"></label>
                        <input asp-for="Username" class="admin-input" placeholder="nguyenvana" />
                        <span asp-validation-for="Username" class="admin-validation"></span>
                        @if (Model.SuggestedUsernames.Count > 0)
                        {
                            <div class="admin-card-soft mt-3 p-4">
                                <p class="text-sm font-semibold text-[#0f2347]">Gợi ý tên đăng nhập khả dụng</p>
                                <div class="mt-3 flex flex-wrap gap-2">
                                    @foreach (var suggestion in Model.SuggestedUsernames)
                                    {
                                        <button type="button" class="admin-chip is-active !h-9 !bg-white !text-[#0f2347] !border !border-[#c2c9b9]" data-username-suggestion="@suggestion">
                                            @suggestion
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div>
                        <label asp-for="RoleId" class="admin-label"></label>
                        <select asp-for="RoleId" asp-items="Model.RoleOptions" class="admin-select">
                            <option value="">Chọn vai trò</option>
                        </select>
                        <span asp-validation-for="RoleId" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="Email" class="admin-label"></label>
                        <input asp-for="Email" class="admin-input" placeholder="name@qpstem.vn" />
                        <span asp-validation-for="Email" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="Phone" class="admin-label"></label>
                        <input asp-for="Phone" class="admin-input" placeholder="0901234567" />
                        <span asp-validation-for="Phone" class="admin-validation"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="AvatarFile" class="admin-label"></label>
                        <input asp-for="AvatarFile" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" class="admin-input admin-file" />
                        <p class="admin-hint">Hỗ trợ JPG, PNG, WEBP. Dung lượng tối đa 5MB.</p>
                        <span asp-validation-for="AvatarFile" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="Password" class="admin-label"></label>
                        <input asp-for="Password" class="admin-input" />
                        <span asp-validation-for="Password" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="ConfirmPassword" class="admin-label"></label>
                        <input asp-for="ConfirmPassword" class="admin-input" />
                        <span asp-validation-for="ConfirmPassword" class="admin-validation"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label class="admin-checkbox-card">
                            <input asp-for="IsActive" />
                            <span>
                                <span class="block text-sm font-semibold text-[#1a1c19]">Cho phép đăng nhập ngay</span>
                                <span class="mt-1 block text-sm text-[#73796b]">Nếu tắt, tài khoản sẽ được tạo ở trạng thái bị khóa.</span>
                            </span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div id="student-profile-card" class="admin-card @(Model.IsStudentRoleSelected ? string.Empty : "hidden")">
            <div class="admin-card-section">
                <div class="mb-6">
                    <h2 class="admin-section-title">Thông tin học sinh</h2>
                    <p class="admin-section-subtitle">Chỉ cần nhập khi vai trò là học sinh.</p>
                </div>

                <div class="admin-field-grid two-col">
                    <div class="md:col-span-2">
                        <label asp-for="CurrentSchool" class="admin-label"></label>
                        <input asp-for="CurrentSchool" class="admin-input" placeholder="THCS Nguyễn Du" />
                        <span asp-validation-for="CurrentSchool" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="GuardianName" class="admin-label"></label>
                        <input asp-for="GuardianName" class="admin-input" placeholder="Nguyễn Thị B" />
                        <span asp-validation-for="GuardianName" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="GuardianPhone" class="admin-label"></label>
                        <input asp-for="GuardianPhone" class="admin-input" placeholder="0912345678" />
                        <span asp-validation-for="GuardianPhone" class="admin-validation"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="MedicalNotes" class="admin-label"></label>
                        <textarea asp-for="MedicalNotes" rows="4" class="admin-textarea" placeholder="Dị ứng, lưu ý sức khỏe, thuốc đang dùng..."></textarea>
                        <span asp-validation-for="MedicalNotes" class="admin-validation"></span>
                    </div>
                </div>
            </div>
        </div>

        <div id="teacher-profile-card" class="admin-card @(Model.IsTeacherRoleSelected ? string.Empty : "hidden")">
            <div class="admin-card-section">
                <div class="mb-6">
                    <h2 class="admin-section-title">Thông tin bảng lương giáo viên</h2>
                    <p class="admin-section-subtitle">Thiết lập bậc lương để tự động tính theo ma trận, hoặc nhập lương khoán để ghi đè.</p>
                </div>

                <div class="admin-field-grid two-col">
                    <div>
                        <label asp-for="SalaryTier" class="admin-label"></label>
                        <select asp-for="SalaryTier" class="admin-select">
                            <option value="1">Tier 1 (Cơ bản)</option>
                            <option value="2">Tier 2</option>
                            <option value="3">Tier 3</option>
                            <option value="4">Tier 4</option>
                            <option value="5">Tier 5 (Chuyên gia)</option>
                        </select>
                        <span asp-validation-for="SalaryTier" class="admin-validation"></span>
                    </div>

                    <div>
                        <label asp-for="CustomSessionRate" class="admin-label"></label>
                        <div class="relative">
                            <input asp-for="CustomSessionRate" type="number" step="10000" class="admin-input pr-12 text-right" placeholder="Ví dụ: 300000" />
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-[#6b7c99] text-sm pointer-events-none">VNĐ</span>
                        </div>
                        <p class="admin-hint mt-1">Bỏ trống để tính theo ma trận Tier.</p>
                        <span asp-validation-for="CustomSessionRate" class="admin-validation"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-actions justify-end">
            <button type="submit" class="admin-btn-primary min-w-[192px]">Lưu người dùng</button>
            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="admin-btn-secondary">Hủy</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const usernameInput = document.getElementById("Username");
            const roleSelect = document.getElementById("RoleId");
            const studentCard = document.getElementById("student-profile-card");
            const teacherCard = document.getElementById("teacher-profile-card");

            if (!roleSelect) return;

            const updateProfileCards = () => {
                const selectedText = roleSelect.options[roleSelect.selectedIndex]?.text?.trim().toLowerCase() ?? "";
                if (studentCard) studentCard.classList.toggle("hidden", selectedText !== "học sinh");
                if (teacherCard) teacherCard.classList.toggle("hidden", selectedText !== "giáo viên");
            };

            roleSelect.addEventListener("change", updateProfileCards);
            updateProfileCards();

            document.querySelectorAll("[data-username-suggestion]").forEach((button) => {
                button.addEventListener("click", () => {
                    if (!usernameInput) {
                        return;
                    }

                    usernameInput.value = button.getAttribute("data-username-suggestion") ?? "";
                    usernameInput.focus();
                });
            });
        })();
    </script>
}
