@model STEM.Web.Areas.Admin.Models.UserDetailsViewModel

@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Chi tiết người dùng</h1>
            <p class="admin-page-subtitle">Xem toàn bộ thông tin tài khoản, vai trò và hồ sơ nghiệp vụ tương ứng.</p>
        </div>

        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@Model.Id" class="admin-btn-primary">Cập nhật</a>
            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="admin-btn-secondary">Quay lại</a>
        </div>
    </div>

    <div class="admin-grid-two">
        <div class="space-y-6">
            <div class="admin-card">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Thông tin tài khoản</h2>

                    @if (!string.IsNullOrWhiteSpace(Model.AvatarUrl))
                    {
                        <div class="mt-6">
                            <img src="@Model.AvatarUrl" alt="@Model.FullName" class="h-24 w-24 rounded-full border border-[#e3e3de] object-cover" />
                        </div>
                    }

                    <dl class="admin-data-grid two-col mt-6">
                        <div class="admin-data-item md:col-span-2">
                            <dt>Họ và tên</dt>
                            <dd>@Model.FullName</dd>
                        </div>
                        <div class="admin-data-item">
                            <dt>Tên đăng nhập</dt>
                            <dd>@Model.Username</dd>
                        </div>
                        <div class="admin-data-item">
                            <dt>Vai trò</dt>
                            <dd>@Model.RoleName</dd>
                        </div>
                        <div class="admin-data-item">
                            <dt>Email</dt>
                            <dd>@(string.IsNullOrWhiteSpace(Model.Email) ? "Chưa cập nhật" : Model.Email)</dd>
                        </div>
                        <div class="admin-data-item">
                            <dt>Số điện thoại</dt>
                            <dd>@(string.IsNullOrWhiteSpace(Model.Phone) ? "Chưa cập nhật" : Model.Phone)</dd>
                        </div>
                        <div class="admin-data-item md:col-span-2">
                            <dt>Ảnh đại diện</dt>
                            <dd>@(string.IsNullOrWhiteSpace(Model.AvatarUrl) ? "Chưa cập nhật" : Model.AvatarUrl)</dd>
                        </div>
                    </dl>
                </div>
            </div>

            @if (Model.IsStudentRole)
            {
                <div class="admin-card">
                    <div class="admin-card-section">
                        <h2 class="admin-section-title">Thông tin học sinh</h2>
                        <dl class="admin-data-grid two-col mt-6">
                            <div class="admin-data-item md:col-span-2">
                                <dt>Trường đang theo học</dt>
                                <dd>@(string.IsNullOrWhiteSpace(Model.CurrentSchool) ? "Chưa cập nhật" : Model.CurrentSchool)</dd>
                            </div>
                            <div class="admin-data-item">
                                <dt>Người giám hộ</dt>
                                <dd>@(string.IsNullOrWhiteSpace(Model.GuardianName) ? "Chưa cập nhật" : Model.GuardianName)</dd>
                            </div>
                            <div class="admin-data-item">
                                <dt>Số điện thoại giám hộ</dt>
                                <dd>@(string.IsNullOrWhiteSpace(Model.GuardianPhone) ? "Chưa cập nhật" : Model.GuardianPhone)</dd>
                            </div>
                            <div class="admin-data-item md:col-span-2">
                                <dt>Ghi chú y tế</dt>
                                <dd>@(string.IsNullOrWhiteSpace(Model.MedicalNotes) ? "Không có" : Model.MedicalNotes)</dd>
                            </div>
                        </dl>
                    </div>
                </div>
            }

            @if (Model.IsTeacherRole)
            {
                <div class="admin-card">
                    <div class="admin-card-section">
                        <h2 class="admin-section-title">Thông tin bảng lương giáo viên</h2>
                        <dl class="admin-data-grid two-col mt-6">
                            <div class="admin-data-item">
                                <dt>Bậc lương</dt>
                                <dd>@(Model.SalaryTier.HasValue ? $"Bậc {Model.SalaryTier.Value}" : "Chưa cấu hình")</dd>
                            </div>
                            <div class="admin-data-item">
                                <dt>Lương khoán / ca</dt>
                                <dd>@(Model.CustomSessionRate.HasValue ? $"{Model.CustomSessionRate.Value:N0} VNĐ" : "Tính theo Tier")</dd>
                            </div>
                        </dl>
                    </div>
                </div>
            }
        </div>

        <aside class="space-y-6">
            <div class="admin-card">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Trạng thái</h2>
                    <div class="mt-5">
                        <span class="inline-flex items-center gap-2 rounded-full px-3 py-2 text-sm font-semibold @Model.StatusBadgeClass">
                            <span class="h-2 w-2 rounded-full @(Model.IsActive ? "bg-[#1a3a6e]" : "bg-[#ba1a1a]")"></span>
                            @Model.StatusLabel
                        </span>
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Thao tác nhanh</h2>
                    <div class="mt-5 space-y-3">
                        <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@Model.Id" class="admin-btn-primary w-full">Cập nhật người dùng</a>
                        <form asp-area="Admin" asp-controller="Users" asp-action="Delete" asp-route-id="@Model.Id" method="post" data-confirm-title="Xóa người dùng" data-confirm-message="Xóa người dùng này? Hành động này không thể hoàn tác." data-confirm-submit-text="Xóa người dùng">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="admin-btn-secondary w-full !border-[#f0c9c7] !text-[#ba1a1a] hover:!bg-[#fff4f3] hover:!border-[#e3a7a2]">Xóa người dùng</button>
                        </form>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</section>
