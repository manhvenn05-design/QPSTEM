@model STEM.Web.Areas.Admin.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Tổng quan";
}

<section class="admin-page">
    <div class="admin-stat-grid four-col">
        @foreach (var metric in Model.Metrics)
        {
            <article class="admin-stat-card">
                <div class="admin-stat-card-icon">
                    <span class="material-symbols-outlined text-[20px] text-[#6a994e]" style="font-variation-settings:'FILL' 1;">@metric.Icon</span>
                </div>
                <div class="admin-stat-card-body">
                    <span class="admin-stat-label">@metric.Label</span>
                    <span class="admin-stat-value">@metric.Value</span>
                </div>
            </article>
        }
    </div>

    <div class="admin-grid-two">
        <div class="space-y-6">
            <div class="admin-card overflow-hidden">
                <div class="admin-card-section">
                    <div class="flex items-center justify-between gap-4">
                        <h2 class="admin-section-title">Buổi hôm nay</h2>
                        <a asp-area="Admin" asp-controller="Sessions" asp-action="Index" class="admin-btn-secondary !h-10">Mở lịch</a>
                    </div>
                </div>

                <div class="px-6 pb-6">
                    @if (Model.TodaySessions.Count == 0)
                    {
                        <div class="admin-empty rounded-[12px] border border-dashed border-[#c2c9b9] bg-[#fafaf4] !py-10">Hôm nay chưa có buổi học.</div>
                    }
                    else
                    {
                        <div class="space-y-3">
                            @foreach (var session in Model.TodaySessions)
                            {
                                <article class="rounded-[12px] border border-[#e3e3de] bg-[#fafaf4] p-4">
                                    <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
                                        <div>
                                            <div class="flex flex-wrap items-center gap-2">
                                                <p class="font-semibold text-[#1a1c19]">@session.ClassCode</p>
                                                <span class="text-sm text-[#73796b]">@session.CourseName</span>
                                            </div>
                                            <p class="mt-1 text-sm text-[#73796b]">@session.TimeRange · @session.TeacherName</p>
                                        </div>

                                        <div class="xl:w-[240px]">
                                            <div class="mb-2 flex items-center justify-between text-sm">
                                                <span class="text-[#42493d]">@session.AttendanceCount/@session.EnrollmentCount đã ghi</span>
                                                <span class="font-medium text-[#1a1c19]">@session.AttendancePercent%</span>
                                            </div>
                                            <div class="h-2 rounded-full bg-[#e8ebe4]">
                                                <div class="h-2 rounded-full bg-[#6a994e]" style="width:@session.AttendancePercent%;"></div>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-section">
                    <div class="flex items-center justify-between gap-4">
                        <h2 class="admin-section-title">Doanh thu 6 tháng</h2>
                        <a asp-area="Admin" asp-controller="Finance" asp-action="Index" class="admin-btn-secondary !h-10">Tài chính</a>
                    </div>

                    <div class="mt-8 grid grid-cols-6 items-end gap-3">
                        @foreach (var point in Model.RevenueSeries)
                        {
                            <div class="flex flex-col items-center gap-2">
                                <div class="flex h-48 w-full items-end rounded-[12px] border border-[#e3e3de] bg-[#fafaf4] p-2">
                                    <div class="w-full rounded-[8px] bg-[#6a994e]" style="height:@(point.HeightPercent)% ;" title="@point.AmountText"></div>
                                </div>
                                <p class="text-xs font-medium text-[#42493d]">@point.Label</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="admin-card">
                <div class="admin-card-section">
                    <div class="flex items-center justify-between gap-4">
                        <h2 class="admin-section-title">Cần xử lý</h2>
                        <a asp-area="Admin" asp-controller="Finance" asp-action="Index" asp-route-filter="unpaid" class="admin-btn-secondary !h-10">Mở việc</a>
                    </div>

                    <div class="mt-6 space-y-3">
                        @if (Model.InvoiceAlerts.Count == 0 && Model.MaintenanceAlerts.Count == 0)
                        {
                            <div class="admin-empty rounded-[12px] border border-dashed border-[#c2c9b9] bg-[#fafaf4] !py-8">Không có mục tồn đọng nổi bật.</div>
                        }
                        else
                        {
                            @foreach (var invoice in Model.InvoiceAlerts)
                            {
                                <article class="rounded-[12px] border border-[#e3e3de] bg-[#fafaf4] px-4 py-4">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <p class="font-semibold text-[#1a1c19]">@invoice.InvoiceNo</p>
                                            <p class="mt-1 text-sm text-[#73796b]">@invoice.StudentName</p>
                                        </div>
                                        <span class="admin-tag admin-tag--warning">@invoice.DueAmountText</span>
                                    </div>
                                </article>
                            }

                            @foreach (var item in Model.MaintenanceAlerts)
                            {
                                <article class="rounded-[12px] border border-[#e3e3de] bg-[#fafaf4] px-4 py-4">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <p class="font-semibold text-[#1a1c19]">@item.EquipmentSerialNumber</p>
                                            <p class="mt-1 text-sm text-[#73796b]">@item.Issue</p>
                                        </div>
                                        <span class="admin-tag @(item.StatusLabel == "Mới ghi nhận" ? "admin-tag--warning" : "admin-tag--neutral")">@item.StatusLabel</span>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-section">
                    <div class="flex items-center justify-between gap-4">
                        <h2 class="admin-section-title">Sắp khai giảng</h2>
                        <a asp-area="Admin" asp-controller="Classes" asp-action="Index" asp-route-filter="upcoming" class="admin-btn-secondary !h-10">Xem lớp</a>
                    </div>

                    <div class="mt-6 space-y-3">
                        @if (Model.UpcomingClasses.Count == 0)
                        {
                            <div class="admin-empty rounded-[12px] border border-dashed border-[#c2c9b9] bg-[#fafaf4] !py-8">Chưa có lớp sắp khai giảng.</div>
                        }
                        else
                        {
                            @foreach (var item in Model.UpcomingClasses)
                            {
                                <article class="admin-card-soft p-4">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <p class="font-semibold text-[#1a1c19]">@item.ClassCode</p>
                                            <p class="mt-1 text-sm text-[#73796b]">@item.CourseName</p>
                                            <p class="mt-2 text-xs text-[#8b8f85]">@item.StartDateText · @item.TeacherName</p>
                                        </div>
                                        <span class="admin-tag admin-tag--neutral">@item.EnrollmentCount học viên</span>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="admin-card-section">
                    <h2 class="admin-section-title">Hệ thống</h2>

                    <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                        <div class="rounded-[12px] border border-[#e3e3de] bg-[#fafaf4] p-4">
                            <p class="text-sm font-medium text-[#73796b]">Nội dung</p>
                            <p class="mt-2 text-2xl font-semibold text-[#1a1c19]">@Model.PublishedPostCount bài viết</p>
                            <p class="mt-1 text-sm text-[#73796b]">@Model.ActiveBannerCount banner đang bật</p>
                        </div>
                        <div class="rounded-[12px] border border-[#e3e3de] bg-[#fafaf4] p-4">
                            <p class="text-sm font-medium text-[#73796b]">Bảo trì</p>
                            <p class="mt-2 text-2xl font-semibold text-[#1a1c19]">@Model.OpenMaintenanceCount</p>
                            <p class="mt-1 text-sm text-[#73796b]">phiếu đang mở</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
