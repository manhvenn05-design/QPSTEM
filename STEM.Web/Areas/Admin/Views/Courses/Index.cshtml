@model STEM.Web.Areas.Admin.Models.CourseManagementViewModel

@{
    ViewData["Title"] = "Khóa học";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Quản lý khóa học</h1>
            <p class="admin-page-subtitle">Quản lý danh sách khóa học, học phí, số buổi, lớp đang mở và số lượng học viên liên quan.</p>
        </div>

        <div class="admin-actions">
            <a asp-area="Admin" asp-controller="Courses" asp-action="Create" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">add</span>
                <span>Thêm khóa học mới</span>
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="admin-alert admin-alert--success">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="admin-alert admin-alert--error">@errorMessage</div>
    }

    <form method="get" asp-area="Admin" asp-controller="Courses" asp-action="Index" class="admin-card">
        <div class="admin-card-section">
            <div class="admin-toolbar">
                <div class="admin-chip-group">
                    @foreach (var filter in Model.Filters)
                    {
                        var isActive = filter.Key == Model.SelectedFilter;
                        <a asp-area="Admin"
                           asp-controller="Courses"
                           asp-action="Index"
                           asp-route-filter="@filter.Key"
                           asp-route-q="@Model.SearchTerm"
                           class="@(isActive ? "admin-chip is-active" : "admin-chip")">
                            @filter.Label
                        </a>
                    }
                </div>

                <div class="w-full lg:max-w-sm">
                    <input type="hidden" name="filter" value="@Model.SelectedFilter" />
                    <label class="relative block">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-[20px] text-[#73796b]">search</span>
                        <input type="text" name="q" value="@Model.SearchTerm" placeholder="Tìm kiếm khóa học..." class="admin-input pl-12" />
                    </label>
                </div>
            </div>
        </div>
    </form>

    <div class="admin-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="admin-table min-w-full">
                <thead>
                    <tr>
                        <th>Khóa học</th>
                        <th>Độ tuổi</th>
                        <th>Học phí</th>
                        <th>Lớp / Học viên</th>
                        <th>Trạng thái</th>
                        <th class="text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Courses.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="admin-empty">Không có khóa học nào phù hợp với bộ lọc hiện tại.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var course in Model.Courses)
                        {
                            <tr>
                                <td>
                                    <div class="flex items-center gap-4">
                                        @if (!string.IsNullOrWhiteSpace(course.ImageUrl))
                                        {
                                            <img src="@course.ImageUrl" alt="@course.Name" class="h-12 w-12 rounded-[8px] border border-[#e3e3de] object-cover" />
                                        }
                                        else
                                        {
                                            <div class="flex h-12 w-12 items-center justify-center rounded-[8px] bg-[#f2f7f0] text-[#0f2347]">
                                                <span class="material-symbols-outlined">school</span>
                                            </div>
                                        }

                                        <div>
                                            <p class="font-semibold text-[#1a1c19]">@course.Name</p>
                                            <p class="mt-1 text-sm text-[#73796b]">@course.Code · @course.TotalSessionsText</p>
                                        </div>
                                    </div>
                                </td>
                                <td>@course.AgeRange</td>
                                <td><strong>@course.PriceText</strong></td>
                                <td>@course.ClassCount lớp · @course.EnrollmentCount học viên</td>
                                <td>
                                    <span class="inline-flex items-center gap-2 rounded-full px-3 py-2 text-xs font-semibold @course.StatusBadgeClass">
                                        <span class="h-2 w-2 rounded-full @(course.StatusLabel == "Đang diễn ra" ? "bg-[#1a3a6e]" : course.StatusLabel == "Sắp khai giảng" ? "bg-[#9b682f]" : course.StatusLabel == "Đã kết thúc" ? "bg-[#73796b]" : "bg-[#c2c9b9]")"></span>
                                        @course.StatusLabel
                                    </span>
                                </td>
                                <td>
                                    <div class="flex justify-end">
                                        <details class="relative" data-table-action>
                                            <summary class="admin-menu-button cursor-pointer list-none">
                                                <span class="material-symbols-outlined text-[18px]">more_horiz</span>
                                            </summary>
                                            <div data-table-menu class="hidden">
                                                <a asp-area="Admin" asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id" class="admin-menu-item">
                                                    <span class="material-symbols-outlined text-[18px]">visibility</span>
                                                    <span>Chi tiết</span>
                                                </a>
                                                <a asp-area="Admin" asp-controller="Courses" asp-action="Edit" asp-route-id="@course.Id" class="admin-menu-item">
                                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                                    <span>Cập nhật</span>
                                                </a>
                                                <form asp-area="Admin" asp-controller="Courses" asp-action="Delete" asp-route-id="@course.Id" method="post" data-confirm-title="Xóa khóa học" data-confirm-message="Xóa khóa học này? Hành động này không thể hoàn tác." data-confirm-submit-text="Xóa khóa học">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="admin-menu-item admin-menu-item--danger w-full text-left">
                                                        <span class="material-symbols-outlined text-[18px]">delete</span>
                                                        <span>Xóa</span>
                                                    </button>
                                                </form>
                                            </div>
                                        </details>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-divider flex flex-col gap-4 px-6 py-5 text-sm text-[#73796b] lg:flex-row lg:items-center lg:justify-between">
            <p>Hiển thị @((Model.TotalCourses == 0 ? 0 : ((Model.CurrentPage - 1) * 10) + 1))-@Math.Min(Model.CurrentPage * 10, Model.TotalCourses) trong số @Model.TotalCourses khóa học</p>

            <div class="admin-pagination">
                <a asp-area="Admin"
                   asp-controller="Courses"
                   asp-action="Index"
                   asp-route-filter="@Model.SelectedFilter"
                   asp-route-q="@Model.SearchTerm"
                   asp-route-page="@(Math.Max(1, Model.CurrentPage - 1))"
                   class="admin-page-link @(Model.CurrentPage == 1 ? "is-disabled" : string.Empty)">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </a>
                <span class="admin-page-link is-active">@Model.CurrentPage</span>
                <a asp-area="Admin"
                   asp-controller="Courses"
                   asp-action="Index"
                   asp-route-filter="@Model.SelectedFilter"
                   asp-route-q="@Model.SearchTerm"
                   asp-route-page="@(Math.Min(Model.TotalPages, Model.CurrentPage + 1))"
                   class="admin-page-link @(Model.CurrentPage == Model.TotalPages ? "is-disabled" : string.Empty)">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </a>
            </div>
        </div>
    </div>
</section>
